        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.medium}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.normal}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.lg}",
        "$type": "dimension"
      }
