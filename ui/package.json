{
  "name": "seaclaw-control-ui",
  "version": "0.3.0",
  "description": "SeaClaw Control — real-time AI assistant dashboard",
  "author": "SeaClaw Contributors",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:component": "bash scripts/check-component.sh",
    "check:components": "bash scripts/check-all-components.sh",
    "check:bundle-size": "bash scripts/check-bundle-size.sh",
    "visual:snapshot": "bash scripts/visual-regression.sh",
    "docs": "(cd ../design-tokens && npm run docs) && bash scripts/icon-inventory.sh && bash scripts/component-docs.sh",
    "docs:icons": "bash scripts/icon-inventory.sh",
    "docs:components": "bash scripts/component-docs.sh",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
