              <tr><td class="p-3">Peak RAM</td><td class="p-3 text-center font-medium" style="color: var(--sc-accent);">&lt;6 MB</td><td class="p-3 text-center opacity-60">~300 MB</td><td class="p-3 text-center opacity-60">~100 MB</td></tr>
              <tr><td class="p-3">Dependencies</td><td class="p-3 text-center font-medium" style="color: var(--sc-accent);">0</td><td class="p-3 text-center opacity-60">900+</td><td class="p-3 text-center opacity-60">200+</td></tr>
              <tr><td class="p-3">Providers</td><td class="p-3 text-center font-medium" style="color: var(--sc-accent);">50+</td><td class="p-3 text-center opacity-60">1</td><td class="p-3 text-center opacity-60">1</td></tr>
              <tr><td class="p-3">Channels</td><td class="p-3 text-center font-medium" style="color: var(--sc-accent);">26</td><td class="p-3 text-center opacity-60">1</td><td class="p-3 text-center opacity-60">1</td></tr>
