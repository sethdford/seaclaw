        // Generate crystal grid for reduced motion
        const rmCrystalGrid = document.getElementById("crystalGrid");
        if (rmCrystalGrid) {
          const rmModules = [
            { name: "core", core: true },
            { name: "json", core: true },
            { name: "http", core: true },
            { name: "str", core: true },
            { name: "arena", core: true },
            { name: "err", core: true },
            { name: "agent" },
            { name: "ctx" },
            { name: "plan" },
            { name: "disp" },
            { name: "comp" },
            { name: "turn" },
            { name: "prov" },
            { name: "chan" },
            { name: "tool" },
            { name: "mem" },
            { name: "sec" },
            { name: "run" },
            { name: "sse" },
            { name: "ws" },
            { name: "log" },
            { name: "cfg" },
            { name: "gw" },
            { name: "cli" },
            { name: "pers" },
            { name: "emb" },
            { name: "sql" },
            { name: "lru" },
            { name: "vec" },
            { name: "obs" },
            {},
            {},
            {},
            {},
            {},
            {},
          ];
          rmModules.forEach((m) => {
            const cell = document.createElement("div");
            cell.className =
              "crystal-cell on" + (m.core ? " core" : m.name ? " filled" : "");
            cell.textContent = m.name || "";
            rmCrystalGrid.appendChild(cell);
          });
        }
        document.querySelectorAll(".crystal-cell").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
          (el as HTMLElement).style.transform = "none";
