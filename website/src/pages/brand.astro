      }
      .brand-section-nav a:hover {
        color: var(--color-text);
        background: var(--hu-hover-overlay);
      }
      .brand-section-nav a.active {
        color: var(--hu-accent);
        background: color-mix(in srgb, var(--hu-accent) 10%, transparent);
      }

      /* Color ramp */
      .brand-ramp-strip {
        display: flex;
        border-radius: var(--hu-radius-lg);
        overflow: hidden;
      }
      .brand-ramp-chip {
        flex: 1;
        aspect-ratio: 1;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-bottom: var(--hu-space-xs);
        min-width: 40px;
      }
      .brand-ramp-label-dark {
        font-size: var(--hu-text-2xs);
        color: rgba(0, 0, 0, 0.7);
      }
      .brand-ramp-label-light {
        font-size: var(--hu-text-2xs);
        color: rgba(255, 255, 255, 0.8);
      }

      /* Color swatches */
      .brand-color-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: var(--hu-space-md);
      }
      .brand-swatch {
        aspect-ratio: 1;
        border-radius: var(--hu-radius-lg);
        padding: var(--hu-space-md);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        font-size: var(--hu-text-xs);
      }
      .brand-swatch-primary {
        background: var(--hu-accent);
        color: var(--hu-on-accent);
      }
      .brand-swatch-secondary {
        background: var(--hu-accent-secondary);
        color: var(--hu-on-accent-secondary);
      }
      .brand-swatch-tertiary {
        background: var(--hu-accent-tertiary);
        color: var(--hu-on-accent-tertiary);
      }
      .brand-swatch-error {
        background: var(--hu-error);
        color: var(--hu-on-accent-secondary, #060b12);
      }
      .brand-swatch code {
        font-size: 0.65rem;
        opacity: 0.9;
        margin-top: var(--hu-space-xs);
      }

      /* Contrast table */
      .brand-contrast-table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--hu-text-sm);
      }
      .brand-contrast-table th,
      .brand-contrast-table td {
        padding: var(--hu-space-sm) var(--hu-space-md);
        text-align: left;
        border-bottom: 1px solid var(--color-border);
      }
      .brand-contrast-table th {
        font-weight: 600;
        font-size: var(--hu-text-xs);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .brand-pass-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: var(--hu-radius-sm);
        font-size: var(--hu-text-2xs);
        font-weight: 600;
        background: color-mix(in srgb, var(--hu-accent) 15%, transparent);
        color: var(--hu-accent);
      }

      /* Misuse cards */
      .brand-misuse-card {
        text-align: center;
      }
      .brand-misuse-demo {
        border-radius: var(--hu-radius-lg);
        padding: var(--hu-space-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        aspect-ratio: 1;
      }

      /* Type specimens */
      .brand-type-spec {
        padding-bottom: var(--hu-space-lg);
        border-bottom: 1px solid var(--color-border);
      }
      .brand-type-spec:last-of-type {
        border-bottom: none;
      }

      @media (prefers-reduced-motion: reduce) {
        [data-reveal] {
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>

    <script>
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (prefersReducedMotion) {
        document.querySelectorAll("[data-reveal]").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
          (el as HTMLElement).style.transform = "none";
          (el as HTMLElement).style.transitionDuration = "0s";
        });
      } else {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -50px 0px" },
        );
        document.querySelectorAll("[data-reveal]").forEach((el) => {
          revealObserver.observe(el);
        });
      }

      const nav = document.getElementById("site-nav");
      if (nav) {
        const onScroll = () => {
          if (window.scrollY > 80) {
            nav.classList.add("glass-nav");
          } else {
            nav.classList.remove("glass-nav");
          }
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      // Section nav active state
      const sectionNav = document.querySelector(".brand-section-nav");
      if (sectionNav) {
        const navLinks = Array.from(sectionNav.querySelectorAll("a"));
        const sectionIds = navLinks.map((a) =>
          a.getAttribute("href")!.slice(1),
        );
        const sections = sectionIds
          .map((id) => document.getElementById(id))
          .filter(Boolean) as HTMLElement[];

        const sectionObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                navLinks.forEach((a) => {
                  a.classList.toggle(
                    "active",
                    a.getAttribute("href") === `#${id}`,
                  );
                });
                const activeLink = sectionNav.querySelector(`a[href="#${id}"]`);
                if (activeLink) {
                  activeLink.scrollIntoView({
                    block: "nearest",
                    inline: "center",
                    behavior: "smooth",
                  });
                }
              }
            });
          },
          { threshold: 0.2, rootMargin: "-80px 0px -60% 0px" },
        );
        sections.forEach((s) => sectionObs.observe(s));
      }
    </script>
  </body>
</html>
