{
  "name": "human-control-ui",
  "version": "0.5.0",
  "description": "h-uman Control — not quite human. Real-time AI assistant dashboard.",
  "author": "h-uman Contributors",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cd ../design-tokens && npm run build 2>/dev/null || true",
    "dev": "vite",
    "prebuild": "cd ../design-tokens && npm run build 2>/dev/null || true",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:strict": "bash scripts/lint-strict.sh",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --config playwright-smoke.config.ts",
    "check:component": "bash scripts/check-component.sh",
    "check:components": "bash scripts/check-all-components.sh",
    "check:bundle-size": "bash scripts/check-bundle-size.sh",
    "visual:snapshot": "bash scripts/visual-regression.sh",
    "docs": "(cd ../design-tokens && npm run docs) && bash scripts/icon-inventory.sh && bash scripts/component-docs.sh",
    "docs:icons": "bash scripts/icon-inventory.sh",
    "docs:components": "bash scripts/component-docs.sh",
    "lint:tokens": "bash scripts/lint-raw-values.sh",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run lint:tokens && npm run test"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "dompurify": "^3.3.2",
    "katex": "^0.16.37",
    "lit": "^3.2.0",
    "marked": "^17.0.4",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
