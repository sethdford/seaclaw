        </div>
        <p class="text-[13px] hidden md:block" style="color: var(--sc-web-text-tertiary)">Bring AI to every device on Earth.</p>
        <div class="flex items-center gap-6 text-[13px]" style="color: var(--sc-web-text-tertiary)">
          <span>MIT License</span>
          <span>Made with C11</span>
          <a href="https://github.com/sethdford/seaclaw" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity" aria-label="SeaClaw on GitHub (opens in new tab)">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);
      gsap.config({ nullTargetWarn: false, force3D: true });

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const isMobile = window.innerWidth < 768;

      if (prefersReducedMotion) {
        document.querySelectorAll(".opacity-0").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
        });

        const outputEl = document.getElementById("terminal-output");
        if (outputEl) {
          outputEl.innerHTML = [
            '<div><span style="color:#6ee7b7">$ </span><span style="color:#e2e8f0">git clone https://github.com/sethdford/seaclaw.git</span></div>',
            '<div><span style="color:#6ee7b7">$ </span><span style="color:#e2e8f0">cd seaclaw && mkdir -p build && cd build</span></div>',
            '<div><span style="color:#6ee7b7">$ </span><span style="color:#e2e8f0">cmake .. -DCMAKE_BUILD_TYPE=MinSizeRel -DSC_ENABLE_LTO=ON && cmake --build .</span></div>',
            '<div><span style="color:rgba(255,255,255,0.45)">[100%] Built target seaclaw</span></div>',
            '<div><span style="color:#6ee7b7">$ </span><span style="color:#e2e8f0">ls -lh seaclaw</span></div>',
            '<div><span style="color:rgba(255,255,255,0.45)">-rwxr-xr-x  1 user  staff  </span><span style="color:var(--sc-accent)">430K</span><span style="color:rgba(255,255,255,0.45)">  seaclaw</span></div>',
          ].join("");
        }

        document.querySelectorAll("[data-count]").forEach((el) => {
          const target = parseInt((el as HTMLElement).dataset.count || "0");
          const valSpan = el.querySelector(".count-value");
          if (valSpan) valSpan.textContent = target > 100 ? target.toLocaleString() : target.toString();
        });
        document.querySelectorAll(".dash-count").forEach((el) => {
          el.textContent = (el as HTMLElement).dataset.target || "0";
        });
      } else {
        const ctx = gsap.context(() => {

          /* ─── Custom spring ease for Pixar-quality motion ─── */
          const springOut = "back.out(1.4)";
          const springIn  = "back.in(1.2)";
          const silkOut   = "expo.out";

          ScrollTrigger.create({
            start: "top -80",
            onEnter: () => { const n = document.getElementById("site-nav"); n?.classList.add("glass-nav", "glass-subtle"); },
            onLeaveBack: () => { const n = document.getElementById("site-nav"); n?.classList.remove("glass-nav", "glass-subtle"); },
          });

          /* ─── PARALLAX: ambient gradients drift at different scroll speeds ─── */
          if (!isMobile) {
            document.querySelectorAll(".ambient-accent").forEach((el) => {
              gsap.to(el, {
                y: -120, ease: "none",
                scrollTrigger: { trigger: el.parentElement, start: "top bottom", end: "bottom top", scrub: 0.8 },
              });
            });
            document.querySelectorAll(".ambient-indigo").forEach((el) => {
              gsap.to(el, {
                y: -80, ease: "none",
                scrollTrigger: { trigger: el.parentElement, start: "top bottom", end: "bottom top", scrub: 1.2 },
              });
            });
          }

          // ═══ HERO — cinematic entrance ═══
          const heroTl = gsap.timeline({ defaults: { ease: silkOut } });
          heroTl
            .fromTo(".hero-logo", { opacity: 0, scale: 0.6, rotation: -8 }, { opacity: 1, scale: 1, rotation: 0, duration: 1.2, ease: springOut }, 0.15)
            .fromTo(".hero-headline", { opacity: 0, y: 60, clipPath: "inset(100% 0 0 0)" }, { opacity: 1, y: 0, clipPath: "inset(0% 0 0 0)", duration: 1.1 }, 0.4)
            .fromTo(".hero-desc", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.9 }, 0.7)
            .fromTo(".hero-buttons", { opacity: 0, y: 20, scale: 0.95 }, { opacity: 1, y: 0, scale: 1, duration: 0.8, ease: springOut }, 0.95);

          /* Hero logo subtle parallax on scroll */
          if (!isMobile) {
            gsap.to(".hero-logo", {
              y: 80, scale: 0.9, opacity: 0.3, ease: "none",
              scrollTrigger: { trigger: ".hero-content", start: "top top", end: "bottom top", scrub: true },
            });
          }

          // ═══ NUMBERS — spring-pop counter animation ═══
          document.querySelectorAll(".number-item").forEach((item, i) => {
            const el = item.querySelector("[data-count]") as HTMLElement;
            if (!el) return;
            const target = parseInt(el.dataset.count || "0");
            const valSpan = el.querySelector(".count-value");
            if (!valSpan) return;
            const obj = { val: 0 };
            gsap.fromTo(item, { opacity: 0, y: 40, scale: 0.9 }, {
              opacity: 1, y: 0, scale: 1, duration: 0.8, delay: i * 0.06, ease: springOut,
              scrollTrigger: { trigger: ".numbers-grid", start: "top 85%" },
            });
            gsap.to(obj, {
              val: target, duration: 1.8, ease: "expo.out", delay: i * 0.06,
              scrollTrigger: { trigger: ".numbers-grid", start: "top 85%" },
              onUpdate: () => {
                valSpan.textContent = target > 100 ? Math.round(obj.val).toLocaleString() : Math.round(obj.val).toString();
              },
              onComplete: () => {
                gsap.fromTo(item, { scale: 1 }, { scale: 1.06, duration: 0.2, yoyo: true, repeat: 1, ease: springOut });
              },
            });
          });

          // ═══ THE PROBLEM — dramatic stagger with anticipation ═══
          gsap.fromTo(".bloat-title", { opacity: 0, y: 30, scale: 0.96 }, {
            opacity: 1, y: 0, scale: 1, duration: 1, ease: silkOut,
            scrollTrigger: { trigger: ".bloat-title", start: "top 85%" },
          });
          gsap.fromTo(".bloat-card", { opacity: 0, y: 50, scale: 0.92, rotateX: 8 }, {
            opacity: 1, y: 0, scale: 1, rotateX: 0, duration: 0.7, stagger: 0.12, ease: springOut,
            scrollTrigger: { trigger: ".bloat-stack", start: "top 80%" },
          });
          gsap.fromTo(".bloat-answer", { opacity: 0, y: 20, scale: 0.95 }, {
            opacity: 1, y: 0, scale: 1, duration: 0.9, delay: 0.9, ease: springOut,
            scrollTrigger: { trigger: ".bloat-stack", start: "top 80%" },
          });

          // ═══ DEVICE SPECTRUM — staggered card entrance with depth ═══
          gsap.fromTo(".spectrum-title", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, ease: silkOut, scrollTrigger: { trigger: ".spectrum-title", start: "top 85%" } });
          gsap.fromTo(".spectrum-sub", { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.9, ease: silkOut, scrollTrigger: { trigger: ".spectrum-sub", start: "top 85%" } });
          gsap.fromTo(".spectrum-card", { opacity: 0, y: 60, scale: 0.92, rotateY: isMobile ? 0 : -4 }, {
            opacity: 1, y: 0, scale: 1, rotateY: 0, duration: 0.9, stagger: 0.1, ease: springOut,
            scrollTrigger: { trigger: ".spectrum-card", start: "top 85%" },
          });

          // ═══ ARCHITECTURE — scrub-linked diagram ═══
          gsap.fromTo(".arch-title", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, ease: silkOut, scrollTrigger: { trigger: ".arch-title", start: "top 85%" } });
          gsap.fromTo(".arch-sub", { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.9, ease: silkOut, scrollTrigger: { trigger: ".arch-sub", start: "top 85%" } });

          const archTl = gsap.timeline({
            scrollTrigger: {
              trigger: "#arch-diagram",
              start: "top 80%",
              end: "center 50%",
              scrub: 0.6,
            },
            defaults: { ease: "none" },
          });
          archTl
            .to("#arch-core", { opacity: 1, scale: 1, duration: 0.3 })
            .fromTo(".arch-line",
              { attr: { "stroke-dasharray": "200", "stroke-dashoffset": "200" } },
              { attr: { "stroke-dashoffset": "0", stroke: "var(--sc-accent)" }, duration: 0.4, stagger: 0.04 }, 0.15)
            .to(".arch-node", { opacity: 1, duration: 0.3, stagger: 0.06 }, 0.35);

          /* Architecture node hover — magnetic pull + glow */
          document.querySelectorAll(".arch-node").forEach((node) => {
            const circle = node.querySelector("circle");
            const text = node.querySelector("text");
            node.addEventListener("mouseenter", () => {
              if (circle) gsap.to(circle, { attr: { stroke: "var(--sc-accent)", r: 34 }, duration: 0.3, ease: springOut });
              if (text) gsap.to(text, { attr: { fill: "var(--sc-web-text)" }, duration: 0.2 });
            });
            node.addEventListener("mouseleave", () => {
              if (circle) gsap.to(circle, { attr: { stroke: "var(--sc-web-node-stroke)", r: 30 }, duration: 0.4, ease: silkOut });
              if (text) gsap.to(text, { attr: { fill: "var(--sc-web-text-secondary)" }, duration: 0.3 });
            });
          });

          // ═══ ECOSYSTEM — particle-burst pill reveal ═══
          gsap.fromTo(".providers-title", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, ease: silkOut, scrollTrigger: { trigger: ".providers-title", start: "top 85%" } });
          gsap.fromTo(".providers-sub", { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.9, ease: silkOut, scrollTrigger: { trigger: ".providers-sub", start: "top 85%" } });
          gsap.fromTo(".provider-pill", { opacity: 0, scale: 0.6, y: 20 }, {
            opacity: 1, scale: 1, y: 0, duration: 0.6, ease: springOut,
            stagger: { each: 0.02, from: "random" },
            scrollTrigger: { trigger: "#provider-grid", start: "top 80%" },
          });

          // ═══ TERMINAL — typewriter with smooth entrance ═══
          gsap.fromTo(".terminal-title", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, ease: silkOut, scrollTrigger: { trigger: ".terminal-title", start: "top 85%" } });
          gsap.fromTo(".terminal-sub", { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.9, ease: silkOut, scrollTrigger: { trigger: ".terminal-sub", start: "top 85%" } });

          const terminalEl = document.getElementById("terminal");
          const outputEl = document.getElementById("terminal-output");
          if (terminalEl && outputEl) {
            let played = false;
            ScrollTrigger.create({
              trigger: terminalEl, start: "top 80%",
              onEnter: () => {
                if (played) return;
                played = true;
                gsap.fromTo(terminalEl, { opacity: 0, y: 30, scale: 0.97 }, { opacity: 1, y: 0, scale: 1, duration: 0.8, ease: springOut });
                typeTerminal(outputEl);
              },
            });
          }

          interface TermLine { prompt: boolean; text: string; highlights?: Array<{ text: string; cls: string }>; }

          function typeTerminal(container: HTMLElement) {
            const accentColor = "var(--sc-accent)";
            const lines: TermLine[] = [
              { prompt: true, text: "git clone https://github.com/sethdford/seaclaw.git" },
              { prompt: true, text: "cd seaclaw && mkdir -p build && cd build" },
              { prompt: true, text: "cmake .. -DCMAKE_BUILD_TYPE=MinSizeRel -DSC_ENABLE_LTO=ON" },
              { prompt: true, text: "cmake --build ." },
              { prompt: false, text: "[100%] Built target seaclaw" },
              { prompt: true, text: "ls -lh seaclaw" },
              { prompt: false, text: "-rwxr-xr-x  1 user  staff  430K  seaclaw", highlights: [{ text: "430K", cls: accentColor }] },
              { prompt: true, text: "./seaclaw agent -m \"Hello from a 430 KB binary.\"" },
              { prompt: false, text: "Hello! I'm SeaClaw — a fully autonomous AI assistant", highlights: [{ text: "SeaClaw", cls: accentColor }] },
              { prompt: false, text: "running in 430 kilobytes. How can I help?" },
            ];

            let lineIdx = 0;
            function nextLine() {
              if (lineIdx >= lines.length) {
                const cursor = document.createElement("span");
                cursor.className = "terminal-cursor";
                container.lastElementChild?.appendChild(cursor);
                return;
              }
              const line = lines[lineIdx];
              const div = document.createElement("div");
              div.className = "terminal-line";

              if (line.prompt) {
                const p = document.createElement("span");
                p.style.color = "#6ee7b7";
                p.textContent = "$ ";
                div.appendChild(p);
                const t = document.createElement("span");
                t.style.color = "#e2e8f0";
                div.appendChild(t);
                container.appendChild(div);
                let ci = 0;
                const speed = isMobile ? 12 : 16;
                const tc = () => {
                  if (ci < line.text.length) { t.textContent += line.text[ci]; ci++; requestAnimationFrame(() => setTimeout(tc, speed)); }
                  else { lineIdx++; setTimeout(nextLine, 250); }
                };
                tc();
              } else {
                const w = document.createElement("span");
                w.style.color = "rgba(255,255,255,0.45)";
                if (line.highlights?.length) {
                  let rem = line.text;
                  for (const hl of line.highlights) {
                    const idx = rem.indexOf(hl.text);
                    if (idx >= 0) {
                      if (idx > 0) w.appendChild(document.createTextNode(rem.slice(0, idx)));
                      const s = document.createElement("span");
                      s.style.color = hl.cls;
                      s.textContent = hl.text;
                      w.appendChild(s);
                      rem = rem.slice(idx + hl.text.length);
                    }
                  }
                  if (rem) w.appendChild(document.createTextNode(rem));
                } else {
                  w.textContent = line.text;
                }
                div.appendChild(w);
                div.style.opacity = "0";
                div.style.transform = "translateY(4px)";
                container.appendChild(div);
                gsap.to(div, { opacity: 1, y: 0, duration: 0.3, ease: "power2.out" });
                lineIdx++;
                setTimeout(nextLine, 180);
              }
            }
            nextLine();
          }

          // ═══ DASHBOARD PREVIEW — cinematic reveal ═══
          gsap.fromTo(".dash-title", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 1, ease: silkOut, scrollTrigger: { trigger: ".dash-title", start: "top 85%" } });
          gsap.fromTo(".dash-sub", { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.9, ease: silkOut, scrollTrigger: { trigger: ".dash-sub", start: "top 85%" } });
          gsap.fromTo(".dash-cta", { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.7, ease: silkOut, scrollTrigger: { trigger: ".dash-cta", start: "top 90%" } });

          const dashPreview = document.querySelector(".dash-preview");
          if (dashPreview) {
            let dashPlayed = false;
            ScrollTrigger.create({
              trigger: dashPreview, start: "top 80%",
              onEnter: () => {
                if (dashPlayed) return;
                dashPlayed = true;
                gsap.fromTo(dashPreview, { opacity: 0, y: 40, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: 0.9, ease: springOut });
                document.querySelectorAll(".dash-count").forEach((el, i) => {
                  const target = parseInt((el as HTMLElement).dataset.target || "0");
                  const obj = { val: 0 };
                  gsap.to(obj, {
                    val: target, duration: 1.4, ease: "expo.out", delay: 0.3 + i * 0.08,
                    onUpdate: () => { el.textContent = Math.round(obj.val).toString(); },
                  });
                });
                const actContainer = document.getElementById("dash-activity");
                if (actContainer) {
                  const activities = [
                    { icon: "[msg]", text: "Alice via Telegram: Can you review the PR?", time: "just now" },
                    { icon: "[cmd]", text: "Tool shell: git status", time: "1m ago" },
                    { icon: "[msg]", text: "Bob via Discord: Deploy looks good", time: "2m ago" },
                    { icon: "[ok]", text: "Session \"Code Review\" started", time: "3m ago" },
                  ];
                  activities.forEach((act, i) => {
                    setTimeout(() => {
                      const div = document.createElement("div");
                      div.className = "flex items-center gap-2";
                      div.style.opacity = "0";
                      div.style.transform = "translateX(-8px)";
                      div.innerHTML = `<span style="color: var(--sc-text-faint)">${act.icon}</span><span style="color: var(--sc-text); flex: 1;">${act.text}</span><span class="text-[11px]" style="color: var(--sc-text-faint)">${act.time}</span>`;
                      actContainer.appendChild(div);
                      gsap.to(div, { opacity: 1, x: 0, duration: 0.4, ease: "power2.out" });
                    }, 600 + i * 350);
                  });
                }
              },
            });
          }

          // ═══ CTA — dramatic entrance ═══
          gsap.fromTo(".cta-title", { opacity: 0, y: 60, scale: 0.95 }, { opacity: 1, y: 0, scale: 1, duration: 1.1, ease: silkOut, scrollTrigger: { trigger: ".cta-title", start: "top 80%" } });
          gsap.fromTo(".cta-sub", { opacity: 0, y: 35 }, { opacity: 1, y: 0, duration: 1, ease: silkOut, scrollTrigger: { trigger: ".cta-sub", start: "top 85%" } });
          gsap.fromTo(".cta-buttons", { opacity: 0, y: 25, scale: 0.95 }, { opacity: 1, y: 0, scale: 1, duration: 0.9, ease: springOut, scrollTrigger: { trigger: ".cta-buttons", start: "top 85%" } });

          // ═══ COMPARISON TABLE — row stagger ═══
          gsap.fromTo(".comparison-table tbody tr", { opacity: 0, x: -20 }, {
            opacity: 1, x: 0, duration: 0.5, stagger: 0.08, ease: "power2.out",
            scrollTrigger: { trigger: ".comparison-table", start: "top 85%" },
          });

          // ═══ MAGNETIC BUTTONS — cursor-attracted physics ═══
          if (!isMobile) {
            document.querySelectorAll(".btn-primary, .btn-outline").forEach((btn) => {
              const el = btn as HTMLElement;
              const strength = 0.3;
              el.addEventListener("mousemove", (e: Event) => {
                const me = e as MouseEvent;
                const rect = el.getBoundingClientRect();
                const cx = rect.left + rect.width / 2;
                const cy = rect.top + rect.height / 2;
                const dx = (me.clientX - cx) * strength;
                const dy = (me.clientY - cy) * strength;
                gsap.to(el, { x: dx, y: dy, duration: 0.4, ease: "power3.out" });
              });
              el.addEventListener("mouseleave", () => {
                gsap.to(el, { x: 0, y: 0, duration: 0.6, ease: "elastic.out(1, 0.4)" });
              });
            });
          }

          // ═══ SPOTLIGHT CARDS — GPU-optimized ═══
          document.querySelectorAll(".card-spotlight").forEach((card) => {
            const el = card as HTMLElement;
            el.addEventListener("mousemove", (e) => {
              const rect = el.getBoundingClientRect();
              el.style.setProperty("--mouse-x", (e as MouseEvent).clientX - rect.left + "px");
              el.style.setProperty("--mouse-y", (e as MouseEvent).clientY - rect.top + "px");
            });
            if (!isMobile) {
              el.addEventListener("mouseenter", () => {
                gsap.to(el, { scale: 1.02, duration: 0.4, ease: springOut });
              });
              el.addEventListener("mouseleave", () => {
                gsap.to(el, { scale: 1, duration: 0.5, ease: "elastic.out(1, 0.5)" });
              });
            }
          });

          // ═══ PILL HOVER — subtle scale on desktop ═══
          if (!isMobile) {
            document.querySelectorAll(".provider-pill").forEach((pill) => {
              pill.addEventListener("mouseenter", () => {
                gsap.to(pill, { scale: 1.08, duration: 0.25, ease: springOut });
              });
              pill.addEventListener("mouseleave", () => {
                gsap.to(pill, { scale: 1, duration: 0.35, ease: "power2.out" });
              });
            });
          }
        });
      }
    </script>
    <script>
      import gsap from "gsap";
      const bar = document.getElementById("scroll-progress");
      if (bar) {
        gsap.to(bar, {
          scaleX: 1,
          ease: "none",
          scrollTrigger: {
            start: "top top",
            end: "max",
            scrub: 0.3,
          },
        });
      }
    </script>
  </body>
</html>
