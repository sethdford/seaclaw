{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "com.human.platform": "all",
    "com.human.version": "0.3.0"
  },
  "$description": "Motion tokens — duration, easing, spring, choreography, and purpose-based transitions",
  "duration": {
    "instant": {
      "$value": "50ms",
      "$type": "duration",
      "$description": "Imperceptible delay"
    },
    "fast": {
      "$value": "100ms",
      "$type": "duration",
      "$description": "Micro-interactions"
    },
    "normal": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Standard transitions"
    },
    "moderate": {
      "$value": "300ms",
      "$type": "duration",
      "$description": "Moderate transitions"
    },
    "slow": {
      "$value": "350ms",
      "$type": "duration",
      "$description": "Complex transitions"
    },
    "slower": {
      "$value": "500ms",
      "$type": "duration",
      "$description": "Dramatic reveals"
    },
    "slowest": {
      "$value": "700ms",
      "$type": "duration",
      "$description": "Hero/page transitions"
    },
    "ambient": {
      "$value": "25s",
      "$type": "duration",
      "$description": "Ambient background animations (drift, gradient) — not UI interaction"
    },
    "ambient-slow": {
      "$value": "30s",
      "$type": "duration",
      "$description": "Slower ambient background animations"
    }
  },
  "easing": {
    "linear": { "$value": "linear", "$type": "cubicBezier" },
    "ease-out": {
      "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
      "$type": "cubicBezier"
    },
    "ease-in-out": {
      "$value": "cubic-bezier(0.65, 0, 0.35, 1)",
      "$type": "cubicBezier"
    },
    "ease-in": {
      "$value": "cubic-bezier(0.55, 0, 1, 0.45)",
      "$type": "cubicBezier"
    },
    "spring-out": {
      "$value": "linear(0, 0.006, 0.025 2.8%, 0.101 6.1%, 0.539 18.9%, 0.721 25.3%, 0.849 31.5%, 0.937 38.1%, 0.968 41.8%, 0.991 45.7%, 1.006 50.1%, 1.015 55%, 1.017 63.9%, 1.001 85.9%, 1)",
      "$type": "cubicBezier",
      "$description": "CSS linear() approximation of spring(stiffness:200, damping:20)"
    },
    "spring-bounce": {
      "$value": "linear(0, 0.004, 0.016, 0.035 4%, 0.147 8%, 0.51 17.2%, 0.726 23.1%, 0.884 28.9%, 0.976 34%, 1.019 38.3%, 1.045 42.5%, 1.054 47.7%, 1.04 56.7%, 1.017 64.3%, 1.003 76%, 1)",
      "$type": "cubicBezier",
      "$description": "CSS linear() with slight bounce overshoot"
    },
    "emphasize": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier",
      "$description": "Material 3 standard — dramatic deceleration without overshoot"
    },
    "emphasize-overshoot": {
      "$value": "cubic-bezier(0.2, 0, 0, 1.2)",
      "$type": "cubicBezier",
      "$description": "Material 3 expressive — deceleration with spring overshoot for hero moments"
    },
    "spring": {
      "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "$type": "cubicBezier",
      "$description": "CSS cubic-bezier spring approximation — overshoot with quick settle for buttons, toggles, cards"
    },
    "spring-gentle": {
      "$value": "cubic-bezier(0.22, 1.2, 0.36, 1)",
      "$type": "cubicBezier",
      "$description": "Gentle spring — subtle overshoot for modals, panels, hover states"
    }
  },
  "spring": {
    "$description": "Physics-based spring parameters for native platforms and JS animation libs",
    "micro": {
      "stiffness": { "$value": 400, "$type": "number" },
      "damping": { "$value": 30, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Button press, toggle (~100ms settle)"
    },
    "standard": {
      "stiffness": { "$value": 200, "$type": "number" },
      "damping": { "$value": 20, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Panel slide, dropdown open (~250ms settle)"
    },
    "expressive": {
      "stiffness": { "$value": 120, "$type": "number" },
      "damping": { "$value": 14, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Page transition, modal enter (~400ms settle)"
    },
    "dramatic": {
      "stiffness": { "$value": 80, "$type": "number" },
      "damping": { "$value": 10, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Hero reveal, onboarding (~600ms settle)"
    },
    "interactive": {
      "stiffness": { "$value": 322, "$type": "number" },
      "damping": { "$value": 31, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Interactive elements — buttons, toggles, list items (response 0.35, dampingFraction 0.86)"
    }
  },
  "purpose": {
    "$description": "Purpose-based motion presets for specific interaction types",
    "enter": {
      "duration": { "$value": "{duration.normal}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-out}", "$type": "cubicBezier" },
      "$description": "Element enters viewport or DOM"
    },
    "exit": {
      "duration": { "$value": "{duration.fast}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-in}", "$type": "cubicBezier" },
      "$description": "Element leaves viewport or DOM"
    },
    "emphasize": {
      "duration": { "$value": "{duration.slow}", "$type": "duration" },
      "easing": { "$value": "{easing.emphasize}", "$type": "cubicBezier" },
      "$description": "Attention-drawing animation"
    },
    "move": {
      "duration": { "$value": "{duration.normal}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-in-out}", "$type": "cubicBezier" },
      "$description": "Element repositioning (layout shift, reorder)"
    },
    "page-enter": {
      "duration": { "$value": "{duration.slow}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-out}", "$type": "cubicBezier" },
      "$description": "Page/view entering"
    },
    "page-exit": {
      "duration": { "$value": "{duration.fast}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-in}", "$type": "cubicBezier" },
      "$description": "Page/view exiting"
    },
    "shared-element": {
      "duration": { "$value": "{duration.slow}", "$type": "duration" },
      "easing": { "$value": "{easing.spring-out}", "$type": "cubicBezier" },
      "$description": "Shared element transition between views"
    }
  },
  "choreography": {
    "$description": "Stagger and cascade timing",
    "stagger-delay": { "$value": "50ms", "$type": "duration" },
    "stagger-max": { "$value": "300ms", "$type": "duration" },
    "cascade-delay": { "$value": "30ms", "$type": "duration" },
    "cascade-max": { "$value": "200ms", "$type": "duration" }
  },
  "reduced-motion": {
    "$description": "Alternative values when prefers-reduced-motion: reduce is active",
    "duration-override": { "$value": "0ms", "$type": "duration" },
    "spring-override-damping": {
      "$value": 100,
      "$type": "number",
      "$description": "Overdamped — no bounce"
    }
  },
  "transition": {
    "default": {
      "$value": "150ms cubic-bezier(0.16, 1, 0.3, 1)",
      "$type": "transition",
      "$description": "Standard transition using ease-out curve"
    }
  },
  "micro-physics": {
    "$description": "Pixar-inspired micro-physics presets — anticipation, follow-through, squash/stretch for UI elements",
    "button-press": {
      "scaleX": { "$value": 1.01, "$type": "number" },
      "scaleY": { "$value": 0.97, "$type": "number" },
      "$description": "Squash on press — slight horizontal expand, vertical compress"
    },
    "button-release": {
      "scaleX": { "$value": 0.99, "$type": "number" },
      "scaleY": { "$value": 1.02, "$type": "number" },
      "$description": "Stretch on release — vertical overshoot before settling"
    },
    "modal-anticipate": {
      "scale": { "$value": 0.97, "$type": "number" },
      "pause": { "$value": "50ms", "$type": "duration" },
      "$description": "Modal shrinks slightly before expanding (anticipation)"
    },
    "card-hover": {
      "translateY": { "$value": "-2px", "$type": "string" },
      "$description": "Subtle lift on hover — perceived lightness"
    },
    "dropdown-anticipate": {
      "scaleY": { "$value": 0.98, "$type": "number" },
      "$description": "Dropdown compresses from origin before expanding"
    },
    "toggle-squash": {
      "scaleX": { "$value": 1.15, "$type": "number" },
      "scaleY": { "$value": 0.85, "$type": "number" },
      "$description": "Toggle thumb squashes during slide"
    },
    "secondary-delay": {
      "$value": "60ms",
      "$type": "duration",
      "$description": "Pixar secondary action — subsidiary elements react after primary, creating depth"
    },
    "secondary-damping": {
      "$value": 0.85,
      "$type": "number",
      "$description": "Secondary action damping ratio — slightly underdamped for follow-through"
    }
  },
  "container-transform": {
    "$description": "Material 3-style container transforms — one element morphs into another",
    "duration": {
      "$value": "{duration.slow}",
      "$type": "duration",
      "$description": "Shared-element morph duration"
    },
    "easing": {
      "$value": "{easing.emphasize}",
      "$type": "cubicBezier",
      "$description": "Dramatic deceleration for container morphs"
    },
    "fade-through-duration": {
      "$value": "{duration.fast}",
      "$type": "duration",
      "$description": "Cross-fade portion of container transform"
    },
    "scale-start": {
      "$value": 0.85,
      "$type": "number",
      "$description": "Origin container starts at this scale during morph"
    },
    "scale-end": {
      "$value": 1.0,
      "$type": "number",
      "$description": "Destination container reaches full scale"
    }
  },
  "path-motion": {
    "$description": "Arc and curve motion for elements following natural paths instead of straight lines",
    "arc-easing": {
      "$value": "cubic-bezier(0.35, 0, 0.25, 1)",
      "$type": "cubicBezier",
      "$description": "Natural arc path easing — elements travel along a curve"
    },
    "arc-duration": {
      "$value": "{duration.moderate}",
      "$type": "duration",
      "$description": "Duration for arc-based transitions"
    },
    "offset-distance-start": {
      "$value": "0%",
      "$type": "string",
      "$description": "CSS offset-distance start for path-based motion"
    },
    "offset-distance-end": {
      "$value": "100%",
      "$type": "string",
      "$description": "CSS offset-distance end for path-based motion"
    }
  },
  "view-transition": {
    "$description": "Native View Transitions API tokens for page/view transitions",
    "duration": {
      "$value": "{duration.moderate}",
      "$type": "duration",
      "$description": "View transition cross-fade duration"
    },
    "easing": {
      "$value": "{easing.ease-out}",
      "$type": "cubicBezier",
      "$description": "View transition easing curve"
    },
    "old-exit": {
      "$value": "ease-in",
      "$type": "cubicBezier",
      "$description": "Old view exits with ease-in"
    },
    "new-enter": {
      "$value": "ease-out",
      "$type": "cubicBezier",
      "$description": "New view enters with ease-out"
    }
  },
  "haptic": {
    "$description": "Haptic feedback tokens mapped to micro-physics presets — native platforms only (iOS UIImpactFeedbackGenerator, Android HapticFeedbackType)",
    "light": {
      "$value": "light",
      "$type": "string",
      "$extensions": {
        "com.human.ios": "UIImpactFeedbackGenerator.FeedbackStyle.light",
        "com.human.android": "HapticFeedbackConstants.KEYBOARD_TAP",
        "com.human.maps-to": "micro-physics.button-press"
      },
      "$description": "Light tap — button press, toggle, list item select"
    },
    "medium": {
      "$value": "medium",
      "$type": "string",
      "$extensions": {
        "com.human.ios": "UIImpactFeedbackGenerator.FeedbackStyle.medium",
        "com.human.android": "HapticFeedbackConstants.CONTEXT_CLICK",
        "com.human.maps-to": "micro-physics.card-hover"
      },
      "$description": "Medium impact — connection events, significant state changes"
    },
    "heavy": {
      "$value": "heavy",
      "$type": "string",
      "$extensions": {
        "com.human.ios": "UIImpactFeedbackGenerator.FeedbackStyle.heavy",
        "com.human.android": "HapticFeedbackConstants.LONG_PRESS",
        "com.human.maps-to": "micro-physics.modal-anticipate"
      },
      "$description": "Heavy impact — destructive actions, major transitions"
    },
    "success": {
      "$value": "success",
      "$type": "string",
      "$extensions": {
        "com.human.ios": "UINotificationFeedbackGenerator.FeedbackType.success",
        "com.human.android": "HapticFeedbackConstants.CONFIRM"
      },
      "$description": "Success notification — task complete, connection established"
    },
    "warning": {
      "$value": "warning",
      "$type": "string",
      "$extensions": {
        "com.human.ios": "UINotificationFeedbackGenerator.FeedbackType.warning",
        "com.human.android": "HapticFeedbackConstants.REJECT"
      },
      "$description": "Warning notification — failed action, connection lost"
    },
    "selection": {
      "$value": "selection",
      "$type": "string",
      "$extensions": {
        "com.human.ios": "UISelectionFeedbackGenerator",
        "com.human.android": "HapticFeedbackConstants.CLOCK_TICK"
      },
      "$description": "Selection change — picker scroll, settings toggle, tab switch"
    }
  }
}
