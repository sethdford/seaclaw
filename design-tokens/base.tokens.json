  "spacing-adaptive": {
    "$description": "Fluid spacing that scales with viewport. Use for page-level padding, section gaps, and card interiors instead of static spacing tokens at layout boundaries.",
    "page-x": {
      "$value": "clamp(1rem, 3vw, 2.5rem)",
      "$type": "dimension",
      "$description": "Horizontal page padding: 16px on mobile → 40px on desktop"
    },
    "page-y": {
      "$value": "clamp(1rem, 2vw, 2rem)",
      "$type": "dimension",
      "$description": "Vertical page padding: 16px on mobile → 32px on desktop"
    },
    "section-gap": {
      "$value": "clamp(1.5rem, 3vw, 3rem)",
      "$type": "dimension",
      "$description": "Gap between major sections: 24px on mobile → 48px on desktop"
    },
    "card-padding": {
      "$value": "clamp(1rem, 2vw, 1.5rem)",
      "$type": "dimension",
      "$description": "Card interior padding: 16px on mobile → 24px on desktop"
    },
    "content-gap": {
      "$value": "clamp(0.75rem, 1.5vw, 1.5rem)",
      "$type": "dimension",
      "$description": "Gap between content items: 12px on mobile → 24px on desktop"
    }
  },
