        /** Compact 3D classic Perlin noise (-1..1-ish). Inline — no extra deps. */
        function createNoise3D(): (x: number, y: number, z: number) => number {
          const p = new Uint8Array(512);
          for (let i = 0; i < 256; i++) p[i] = i;
          let seed = 2463534242;
          for (let i = 255; i > 0; i--) {
            seed = (seed * 1664525 + 1013904223) >>> 0;
            const j = seed % (i + 1);
            const tmp = p[i];
            p[i] = p[j];
            p[j] = tmp;
          }
          for (let i = 0; i < 256; i++) p[i + 256] = p[i];
          const fade = (t: number) => t * t * t * (t * (t * 6 - 15) + 10);
          const lerp = (t: number, a: number, b: number) => a + t * (b - a);
          const grad = (hash: number, x: number, y: number, z: number) => {
            const h = hash & 15;
            const u = h < 8 ? x : y;
            const v = h < 4 ? y : h === 12 || h === 14 ? x : z;
            return ((h & 1) === 0 ? u : -u) + ((h & 2) === 0 ? v : -v);
          };
          return (x: number, y: number, z: number) => {
            const X = Math.floor(x) & 255;
            const Y = Math.floor(y) & 255;
            const Z = Math.floor(z) & 255;
            let xf = x - Math.floor(x);
            let yf = y - Math.floor(y);
            let zf = z - Math.floor(z);
            const u = fade(xf);
            const v = fade(yf);
            const w = fade(zf);
            const A = p[X] + Y;
            const AA = p[A] + Z;
            const AB = p[A + 1] + Z;
            const B = p[X + 1] + Y;
            const BA = p[B] + Z;
            const BB = p[B + 1] + Z;
            return lerp(
              w,
              lerp(
                v,
                lerp(u, grad(p[AA], xf, yf, zf), grad(p[BA], xf - 1, yf, zf)),
                lerp(
                  u,
                  grad(p[AB], xf, yf - 1, zf),
                  grad(p[BB], xf - 1, yf - 1, zf),
                ),
              ),
              lerp(
                v,
                lerp(
                  u,
                  grad(p[AA + 1], xf, yf, zf - 1),
                  grad(p[BA + 1], xf - 1, yf, zf - 1),
                ),
                lerp(
                  u,
                  grad(p[AB + 1], xf, yf - 1, zf - 1),
                  grad(p[BB + 1], xf - 1, yf - 1, zf - 1),
                ),
              ),
            );
          };
        }

        // ═══ WebGL Hero — lazy-load Three.js only when hero visible, defer until idle ═══
        const heroCanvas = document.getElementById(
          "hero-webgl",
        ) as HTMLCanvasElement;
        const isDesktop = window.matchMedia("(min-width: 769px)").matches;
        if (heroCanvas && isDesktop) {
          const heroObs = new IntersectionObserver(
            (entries) => {
              if (!entries[0]?.isIntersecting) return;
              heroObs.disconnect();
              const ric = (
                window as unknown as {
                  requestIdleCallback?: (
                    cb: () => void,
                    opts?: { timeout: number },
                  ) => number;
                }
              ).requestIdleCallback;
              if (ric) ric(() => initHeroWebGL(heroCanvas), { timeout: 4000 });
              else setTimeout(() => initHeroWebGL(heroCanvas), 2000);
            },
            { threshold: 0.01 },
          );
          heroObs.observe(heroCanvas);
        } else if (heroCanvas) {
          heroCanvas.style.display = "none";
          const fallback = heroCanvas.parentElement?.querySelector(
            ".hero-static-constellation",
          );
          if (fallback instanceof HTMLElement) fallback.style.display = "block";
        }

        async function initHeroWebGL(canvas: HTMLCanvasElement) {
          try {
            const THREE = await import("three");
            const section = canvas.closest("section")!;
            const w = () => section.clientWidth;
            const h = () => section.clientHeight;
            const renderer = new THREE.WebGLRenderer({
              canvas,
              alpha: true,
              antialias: true,
              powerPreference: "low-power",
            });
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.setSize(w(), h());

            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(60, w() / h(), 0.1, 100);
            camera.position.z = 30;

            const noise3D = createNoise3D();

            const accentColor =
              getComputedStyle(document.documentElement)
                .getPropertyValue("--hu-accent")
                .trim() || "#7AB648";
            const accentSecondary =
              getComputedStyle(document.documentElement)
                .getPropertyValue("--hu-accent-secondary")
                .trim() || "#f59e0b";

            // Neural network topology: 5 layers, 8–15 nodes per layer
            const layerSizes = [10, 12, 10, 12, 10];
            const layerZ = [-14, -7, 0, 7, 14];
            const layerWidth = 18;
            const nodeBasePos: number[][] = [];
            for (let L = 0; L < layerSizes.length; L++) {
              const n = layerSizes[L];
              const z = layerZ[L];
              for (let i = 0; i < n; i++) {
                const t = n > 1 ? i / (n - 1) : 0.5;
                const x = (t - 0.5) * layerWidth;
                const y = Math.sin(i * 0.7) * 1.5;
                nodeBasePos.push([x, y, z]);
              }
            }
            const nodeCount = nodeBasePos.length;

            // Orbital/breathing params per node
            const orbitRadius = new Float32Array(nodeCount);
            const orbitPhase = new Float32Array(nodeCount);
            const breathPhase = new Float32Array(nodeCount);
            const isAccent = new Uint8Array(nodeCount);
            for (let i = 0; i < nodeCount; i++) {
              orbitRadius[i] = 0.15 + Math.random() * 0.25;
              orbitPhase[i] = Math.random() * Math.PI * 2;
              breathPhase[i] = Math.random() * Math.PI * 2;
              isAccent[i] = Math.random() < 0.2 ? 1 : 0;
            }

            // Connections between adjacent layers (each node → 2–4 random next-layer nodes)
            const connections: [number, number][] = [];
            let layerStart = 0;
            for (let L = 0; L < layerSizes.length - 1; L++) {
              const nCur = layerSizes[L];
              const nNext = layerSizes[L + 1];
              const nextStart = layerStart + nCur;
              for (let i = 0; i < nCur; i++) {
                const src = layerStart + i;
                const k = 2 + Math.floor(Math.random() * 3);
                const used = new Set<number>();
                for (let c = 0; c < Math.min(k, nNext); c++) {
                  let t = Math.floor(Math.random() * nNext);
                  while (used.has(t)) t = (t + 1) % nNext;
                  used.add(t);
                  connections.push([src, nextStart + t]);
                }
              }
              layerStart = nextStart;
            }

            const FLOW_TOTAL_CAP = 5000;
            const flowCount = Math.max(0, FLOW_TOTAL_CAP - nodeCount);
            const FLOW_WRAP = 20;
            const flowPosArr = new Float32Array(flowCount * 3);
            for (let fi = 0; fi < flowCount; fi++) {
              flowPosArr[fi * 3] = (Math.random() - 0.5) * FLOW_WRAP * 1.8;
              flowPosArr[fi * 3 + 1] = (Math.random() - 0.5) * FLOW_WRAP * 1.8;
              flowPosArr[fi * 3 + 2] = (Math.random() - 0.5) * FLOW_WRAP * 1.8;
            }
            const flowGeo = new THREE.BufferGeometry();
            flowGeo.setAttribute(
              "position",
              new THREE.BufferAttribute(flowPosArr, 3),
            );
            const flowMat = new THREE.PointsMaterial({
              color: new THREE.Color(accentColor),
              size: 0.055,
              sizeAttenuation: true,
              transparent: true,
              opacity: 0.22,
              blending: THREE.AdditiveBlending,
              depthWrite: false,
            });
            const flowPoints = new THREE.Points(flowGeo, flowMat);
            scene.add(flowPoints);

            const linePositions = new Float32Array(connections.length * 6);
            const lineColors = new Float32Array(connections.length * 6);
            const lineGeo = new THREE.BufferGeometry();
            lineGeo.setAttribute(
              "position",
              new THREE.BufferAttribute(linePositions, 3),
            );
            lineGeo.setAttribute(
              "color",
              new THREE.BufferAttribute(lineColors, 3),
            );
            const lineMat = new THREE.LineBasicMaterial({
              vertexColors: true,
              transparent: true,
              opacity: 0.18,
              blending: THREE.AdditiveBlending,
              depthWrite: false,
            });
            const lines = new THREE.LineSegments(lineGeo, lineMat);
            scene.add(lines);

            const posArr = new Float32Array(nodeCount * 3);
            const colorArr = new Float32Array(nodeCount * 3);
            const geo = new THREE.BufferGeometry();
            geo.setAttribute("position", new THREE.BufferAttribute(posArr, 3));
            geo.setAttribute("color", new THREE.BufferAttribute(colorArr, 3));

            const accentCol = new THREE.Color(accentColor);
            const secondaryCol = new THREE.Color(accentSecondary);
            const mat = new THREE.PointsMaterial({
              size: 0.18,
              vertexColors: true,
              sizeAttenuation: true,
              transparent: true,
              opacity: 0.7,
              blending: THREE.AdditiveBlending,
              depthWrite: false,
            });
            const points = new THREE.Points(geo, mat);
            scene.add(points);

            // Mouse interaction
            const mouse = new THREE.Vector2(-10, -10);
            const mouse3D = new THREE.Vector3(0, 0, 0);
            const raycaster = new THREE.Raycaster();
            const plane = new THREE.Plane(new THREE.Vector3(0, 0, -1), 0);
            const intersect = new THREE.Vector3();
            const onDocMouseMove = (e: MouseEvent) => {
              mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
              mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
            };
            const onDocMouseLeave = () => {
              mouse.x = -10;
              mouse.y = -10;
            };
            document.addEventListener("mousemove", onDocMouseMove);
            document.addEventListener("mouseleave", onDocMouseLeave);

            // Mouse glow sprite
            const glowGeo = new THREE.BufferGeometry();
            glowGeo.setAttribute(
              "position",
              new THREE.Float32BufferAttribute([0, 0, 0], 3),
            );
            const glowMat = new THREE.PointsMaterial({
              size: 4,
              color: new THREE.Color(accentColor),
              transparent: true,
              opacity: 0.15,
              blending: THREE.AdditiveBlending,
              depthWrite: false,
              sizeAttenuation: true,
            });
            const glowPoint = new THREE.Points(glowGeo, glowMat);
            glowPoint.visible = false;
            scene.add(glowPoint);

            const MOUSE_RADIUS = 8;
            const MOUSE_STRENGTH = 0.015;
            const FRAME_INTERVAL = 1000 / 60;
            let lastFrame = 0;
            let animId: number;

            const animate = (now: number) => {
              animId = requestAnimationFrame(animate);
              if (now - lastFrame < FRAME_INTERVAL) return;
              lastFrame = now;
              const t = now * 0.001;
              const breath = 1 + 0.04 * Math.sin(t * 0.8);

              raycaster.setFromCamera(mouse, camera);
              raycaster.ray.intersectPlane(plane, intersect);
              mouse3D.copy(intersect);
              const mouseActive =
                mouse.x > -2 && mouse.x < 2 && mouse.y > -2 && mouse.y < 2;
              glowPoint.visible = mouseActive;
              if (mouseActive) {
                glowPoint.position.copy(mouse3D);
              }

              for (let i = 0; i < nodeCount; i++) {
                const [bx, by, bz] = nodeBasePos[i];
                const orb = orbitRadius[i];
                const ph = orbitPhase[i];
                const br = breathPhase[i];
                let x = bx + orb * Math.cos(t * 0.6 + ph) * breath;
                let y = by + orb * Math.sin(t * 0.5 + ph * 1.1) * breath;
                let z = bz + orb * 0.5 * Math.sin(t * 0.4 + br) * breath;

                const nScale = 0.4;
                x += nScale * noise3D(x * 0.15, y * 0.15, t * 0.3);
                y += nScale * noise3D(y * 0.15, z * 0.15, t * 0.3);
                z += nScale * noise3D(z * 0.15, x * 0.15, t * 0.3);

                if (mouseActive) {
                  const dx = x - mouse3D.x;
                  const dy = y - mouse3D.y;
                  const dz = z - mouse3D.z;
                  const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);
                  if (dist < MOUSE_RADIUS && dist > 0.01) {
                    const f = (1 - dist / MOUSE_RADIUS) * MOUSE_STRENGTH;
                    x += (dx / dist) * f;
                    y += (dy / dist) * f;
                    z += (dz / dist) * f;
                  }
                }

                posArr[i * 3] = x;
                posArr[i * 3 + 1] = y;
                posArr[i * 3 + 2] = z;
                const depth = (z + 14) / 28;
                const col = isAccent[i] ? secondaryCol : accentCol;
                const alphaMult = 0.4 + 0.6 * depth;
                const pulseMult = isAccent[i]
                  ? 0.7 + 0.3 * Math.sin(t * 2.2 + breathPhase[i])
                  : 1;
                colorArr[i * 3] = col.r * alphaMult * pulseMult;
                colorArr[i * 3 + 1] = col.g * alphaMult * pulseMult;
                colorArr[i * 3 + 2] = col.b * alphaMult * pulseMult;
              }
              geo.attributes.position.needsUpdate = true;
              geo.attributes.color!.needsUpdate = true;

              const flowStep = 0.038;
              for (let fi = 0; fi < flowCount; fi++) {
                let fx = flowPosArr[fi * 3];
                let fy = flowPosArr[fi * 3 + 1];
                let fz = flowPosArr[fi * 3 + 2];
                fx += flowStep * noise3D(fy * 0.15, fz * 0.15, t * 0.3);
                fy += flowStep * noise3D(fz * 0.15 + 23.1, fx * 0.15, t * 0.3);
                fz += flowStep * noise3D(fx * 0.15, fy * 0.15 + 61.4, t * 0.3);
                if (fx > FLOW_WRAP) fx -= FLOW_WRAP * 2;
                else if (fx < -FLOW_WRAP) fx += FLOW_WRAP * 2;
                if (fy > FLOW_WRAP) fy -= FLOW_WRAP * 2;
                else if (fy < -FLOW_WRAP) fy += FLOW_WRAP * 2;
                if (fz > FLOW_WRAP) fz -= FLOW_WRAP * 2;
                else if (fz < -FLOW_WRAP) fz += FLOW_WRAP * 2;
                flowPosArr[fi * 3] = fx;
                flowPosArr[fi * 3 + 1] = fy;
                flowPosArr[fi * 3 + 2] = fz;
              }
              flowGeo.attributes.position.needsUpdate = true;

              for (let c = 0; c < connections.length; c++) {
                const [a, b] = connections[c];
                const ax = posArr[a * 3];
                const ay = posArr[a * 3 + 1];
                const az = posArr[a * 3 + 2];
                const bx = posArr[b * 3];
                const by = posArr[b * 3 + 1];
                const bz = posArr[b * 3 + 2];
                linePositions[c * 6] = ax;
                linePositions[c * 6 + 1] = ay;
                linePositions[c * 6 + 2] = az;
                linePositions[c * 6 + 3] = bx;
                linePositions[c * 6 + 4] = by;
                linePositions[c * 6 + 5] = bz;

                const midX = (ax + bx) * 0.5;
                const midY = (ay + by) * 0.5;
                const midZ = (az + bz) * 0.5;
                const distToMouse = mouseActive
                  ? Math.sqrt(
                      (midX - mouse3D.x) ** 2 +
                        (midY - mouse3D.y) ** 2 +
                        (midZ - mouse3D.z) ** 2,
                    )
                  : 999;
                const brighten =
                  distToMouse < MOUSE_RADIUS * 1.5
                    ? 1 + 0.8 * (1 - distToMouse / (MOUSE_RADIUS * 1.5))
                    : 1;
                const flowPhase = (t * 3 + c * 0.1) % 1;
                const flowPulse = 0.6 + 0.4 * Math.sin(flowPhase * Math.PI * 2);
                const base = Math.min(1, (0.2 + 0.15 * flowPulse) * brighten);
                lineColors[c * 6] = accentCol.r * base;
                lineColors[c * 6 + 1] = accentCol.g * base;
                lineColors[c * 6 + 2] = accentCol.b * base;
                lineColors[c * 6 + 3] = accentCol.r * base;
                lineColors[c * 6 + 4] = accentCol.g * base;
                lineColors[c * 6 + 5] = accentCol.b * base;
              }
              lineGeo.attributes.position.needsUpdate = true;
              lineGeo.attributes.color!.needsUpdate = true;

              camera.position.x +=
                (mouse.x * 2 - camera.position.x * 0.3) * 0.02;
              camera.position.y +=
                (-mouse.y * 1.5 - camera.position.y * 0.3) * 0.02;
              camera.lookAt(0, 0, 0);

              renderer.render(scene, camera);
            };

            canvas.style.opacity = "1";
            canvas.style.transition = "opacity 1.5s ease-out";
            animate(performance.now());

            const onResize = () => {
              camera.aspect = w() / h();
              camera.updateProjectionMatrix();
              renderer.setSize(w(), h());
            };
            window.addEventListener("resize", onResize);

            const cleanObs = new IntersectionObserver(
              (entries) => {
                if (!entries[0]?.isIntersecting) {
                  cancelAnimationFrame(animId);
                } else {
                  lastFrame = 0;
                  animate(performance.now());
                }
              },
              { threshold: 0 },
            );
            cleanObs.observe(canvas);

            const disposeWebGL = () => {
              cancelAnimationFrame(animId);
              cleanObs.disconnect();
              window.removeEventListener("resize", onResize);
              document.removeEventListener("mousemove", onDocMouseMove);
              document.removeEventListener("mouseleave", onDocMouseLeave);
              renderer.dispose();
              scene.traverse((obj: any) => {
                if (obj.geometry) obj.geometry.dispose();
                if (obj.material) {
                  if (Array.isArray(obj.material))
                    obj.material.forEach((m: any) => m.dispose());
                  else obj.material.dispose();
                }
              });
            };
            window.addEventListener("pagehide", disposeWebGL, { once: true });
          } catch (e) {
            console.warn("[hero-webgl] init failed, falling back:", e);
            canvas.style.display = "none";
            const fallback = canvas.parentElement?.querySelector(
              ".hero-static-constellation",
            );
            if (fallback instanceof HTMLElement)
              fallback.style.display = "block";
          }
        }
      }
    </script>
    <script>
      {
        const root = document.documentElement;
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (!prefersReduced) {
          const hour = new Date().getHours();
          let warmth = 0;
          if (hour < 7 || hour > 19) warmth = 0.12;
          else if (hour < 10 || hour > 17) warmth = 0.06;
          else warmth = 0;
          root.style.setProperty("--hu-ambient-warmth", `${warmth}`);
        }

        const updateScrollDepth = () => {
          const scrollH =
            document.documentElement.scrollHeight - window.innerHeight;
          const depth = scrollH > 0 ? Math.min(window.scrollY / scrollH, 1) : 0;
          root.style.setProperty("--hu-scroll-depth", depth.toFixed(3));
        };
        let depthTicking = false;
        window.addEventListener(
          "scroll",
          () => {
            if (!depthTicking) {
              depthTicking = true;
              requestAnimationFrame(() => {
                updateScrollDepth();
                depthTicking = false;
              });
            }
          },
          { passive: true },
        );
        updateScrollDepth();
      }
    </script>
    <script is:inline>
      /* Defer heavy visual effects until after LCP */
      new PerformanceObserver(function (list) {
        list.getEntries().forEach(function () {
          document.documentElement.classList.add("hu-lcp-done");
          document.body.classList.add("hu-ambient-ready");
        });
      }).observe({ type: "largest-contentful-paint", buffered: true });
      /* Fallback for browsers without LCP observer */
      setTimeout(function () {
        document.documentElement.classList.add("hu-lcp-done");
        document.body.classList.add("hu-ambient-ready");
      }, 1500);
    </script>
    <script is:inline>
      (function () {
        var K = "hu-audio-enabled";
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
          return;
        var x = null;
        var ht = 0;
        function on() {
          return localStorage.getItem(K) === "true";
        }
        function ctx() {
          if (!on()) return null;
          if (!x) {
            var AC = window.AudioContext || window["webkitAudioContext"];
            x = new AC();
          }
          if (x.state === "suspended") x.resume();
          return x;
        }
        function pk(c) {
          var t = c.currentTime,
            o = c.createOscillator(),
            g = c.createGain();
          o.type = "sine";
          o.frequency.value = 440;
          g.gain.setValueAtTime(0.06, t);
          g.gain.exponentialRampToValueAtTime(0.0001, t + 0.03);
          o.connect(g);
          g.connect(c.destination);
          o.start(t);
          o.stop(t + 0.031);
        }
        function nv(c) {
          var t = c.currentTime,
            o = c.createOscillator(),
            g = c.createGain();
          o.type = "sine";
          o.frequency.setValueAtTime(300, t);
          o.frequency.linearRampToValueAtTime(500, t + 0.08);
          g.gain.setValueAtTime(0.0001, t);
          g.gain.exponentialRampToValueAtTime(0.05, t + 0.006);
          g.gain.exponentialRampToValueAtTime(0.0001, t + 0.08);
          o.connect(g);
          g.connect(c.destination);
          o.start(t);
          o.stop(t + 0.085);
        }
        function hv(c) {
          var t = c.currentTime,
            o = c.createOscillator(),
            g = c.createGain();
          o.type = "sine";
          o.frequency.value = 600;
          g.gain.setValueAtTime(0.0001, t);
          g.gain.exponentialRampToValueAtTime(0.035, t + 0.002);
          g.gain.exponentialRampToValueAtTime(0.0001, t + 0.015);
          o.connect(g);
          g.connect(c.destination);
          o.start(t);
          o.stop(t + 0.018);
        }
        document.addEventListener("click", function (e) {
          if (!on()) return;
          var c = ctx();
          if (!c) return;
          var el = e.target;
          if (!el || typeof el.closest !== "function") return;
          if (el.closest(".audio-toggle")) return;
          if (el.closest("#site-nav a")) {
            nv(c);
            return;
          }
          if (el.closest(".btn-primary, .btn-outline")) pk(c);
        });
        document.addEventListener("mouseover", function (e) {
          if (!on()) return;
          var c = ctx();
          if (!c) return;
          var el = e.target;
          if (!el || typeof el.closest !== "function") return;
          var card = el.closest(".proof-item");
          if (!card) return;
          if (e.relatedTarget instanceof Node && card.contains(e.relatedTarget))
            return;
          var n = performance.now();
          if (n - ht < 100) return;
          ht = n;
          hv(c);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        if (location.hostname === "localhost") return;
        var s = document.createElement("script");
        s.src = "https://unpkg.com/web-vitals@4/dist/web-vitals.iife.js";
        s.onerror = function () {
          console.warn("[web-vitals] failed to load");
