{
  "ci": {
    "collect": {
      "staticDistDir": "ui/dist",
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.97 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 0.92 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.01 }],
        "total-blocking-time": ["error", { "maxNumericValue": 80 }],
        "interaction-to-next-paint": ["warn", { "maxNumericValue": 150 }],
        "interactive": ["error", { "maxNumericValue": 2500 }]
      }
    }
  }
}
