{
  "ci": {
    "collect": {
      "staticDistDir": "website/dist",
      "numberOfRuns": 5
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.97 }],
        "categories:accessibility": ["error", { "minScore": 0.99 }],
        "categories:best-practices": ["error", { "minScore": 0.97 }],
        "categories:seo": ["error", { "minScore": 0.97 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 1000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.01 }],
        "interactive": ["warn", { "maxNumericValue": 1500 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 100 }]
      },
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*/404\\.html$",
          "assertions": {
            "categories:seo": ["warn", { "minScore": 0.5 }]
          }
        }
      ]
    }
  }
}
