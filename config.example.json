{
  "workspace": "~/.human/workspace",
  "default_provider": "openai",
  "default_model": "gpt-4o",
  "default_temperature": 0.7,

  "providers": [
    {
      "name": "openai",
      "api_key": "YOUR_OPENAI_API_KEY"
    },
    {
      "name": "anthropic",
      "api_key": "YOUR_ANTHROPIC_API_KEY"
    }
  ],

  "channels": {
    "cli": true,
    "default_channel": "cli"
  },

  "memory": {
    "profile": "sqlite_full",
    "backend": "sqlite",
    "auto_save": true,
    "max_entries": 10000
  },

  "agent": {
    "hula": true,
    "max_tool_iterations": 25,
    "max_history_messages": 100
  },

  "reliability": {
    "provider_retries": 2,
    "provider_backoff_ms": 500,
    "fallback_providers": [],
    "model_fallbacks": []
  },

  "autonomy": {
    "level": "supervised",
    "workspace_only": true,
    "max_actions_per_hour": 100
  },

  "gateway": {
    "port": 3000,
    "host": "127.0.0.1",
    "require_pairing": true
  },

  "security": {
    "autonomy_level": 1,
    "sandbox": {
      "backend": "auto"
    },
    "audit": {
      "enabled": true
    }
  },

  "tools": {
    "shell_timeout_secs": 30,
    "max_file_size_bytes": 1048576,
    "web_fetch_max_chars": 100000
  }
}
