      },
      "lineHeight": {
        "$value": "{lineHeight.normal}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.sm}",
        "$type": "dimension"
      }
    },
    "body-lg": {
      "fontSize": {
