---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const bloatItems = [
  "A container runtime",
  "A Python environment",
  "2 GB of RAM",
  "A cloud API key",
  "A stable internet connection",
  "A prayer",
];

const providers = [
  "OpenAI",
  "Anthropic",
  "Gemini",
  "OpenRouter",
  "Ollama",
  "llama.cpp",
  "Groq",
  "Mistral",
  "xAI",
  "DeepSeek",
  "Together",
  "Fireworks",
  "Perplexity",
  "Cohere",
  "LM Studio",
  "vLLM",
  "sglang",
  "Cerebras",
  "SambaNova",
  "Hyperbolic",
];

const channels = [
  "Telegram",
  "Discord",
  "Slack",
  "Signal",
  "iMessage",
  "Matrix",
  "WhatsApp",
  "IRC",
  "Nostr",
  "Email",
  "Line",
  "Mattermost",
];

const tools = [
  "Shell",
  "File Ops",
  "Git",
  "Browser",
  "Memory",
  "Web Search",
  "Cron",
  "HTTP",
  "Hardware",
  "Delegate",
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://h-uman.ai/" />
    <link
      rel="preload"
      href="/fonts/avenir/Avenir-Black.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/fonts/avenir/Avenir-Book.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://github.com" />
    <title>h-uman — not quite human.</title>
    <meta
      name="description"
      content="not quite human. A complete autonomous AI agent runtime in 1,696 kilobytes of pure C. One static binary. Zero dependencies. 50+ providers. Runs on anything with a CPU."
    />
    <link
      rel="preload"
      href={`${base}human.svg`}
      as="image"
      fetchpriority="high"
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${base}favicon-32.png`}
    />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <meta name="theme-color" content="#7AB648" />
    <meta
      property="og:title"
      content="h-uman — not quite human."
    />
    <meta
      property="og:description"
      content="Autonomous AI agent runtime. ~1.7 MB binary. 50+ providers. 34 channels. 67+ tools. Zero dependencies. Pure C."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://h-uman.ai/" />
    <meta property="og:image" content="https://h-uman.ai/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="h-uman — not quite human."
    />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="h-uman" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="h-uman — not quite human."
    />
    <meta
      name="twitter:description"
      content="Autonomous AI agent runtime. ~1.7 MB binary. 50+ providers. 34 channels. 67+ tools. Zero dependencies. Pure C."
    />
    <meta name="twitter:image" content="https://h-uman.ai/og-image.png" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://h-uman.ai/#website",
            name: "h-uman",
            url: "https://h-uman.ai/",
            description: "Autonomous AI agent runtime in 1,696 kilobytes of pure C. One static binary. Zero dependencies. 50+ providers.",
            publisher: { "@id": "https://h-uman.ai/#organization" },
          },
          {
            "@type": "Organization",
            "@id": "https://h-uman.ai/#organization",
            name: "h-uman",
            url: "https://github.com/sethdford/h-uman",
            sameAs: ["https://github.com/sethdford/h-uman"],
          },
          {
            "@type": "SoftwareApplication",
            name: "h-uman",
            description:
              "not quite human. Autonomous AI agent runtime in 1,696 kilobytes of pure C.",
            applicationCategory: "DeveloperApplication",
            operatingSystem: "Cross-platform",
            url: "https://h-uman.ai/",
            license: "https://opensource.org/licenses/MIT",
            offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
            author: { "@id": "https://h-uman.ai/#organization" },
          },
        ],
      })}
    />
    <style is:global>
      /* Critical hero CSS — inline for fast LCP */
      section.relative.min-h-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 36rem;
        margin-left: auto;
        margin-right: auto;
      }
    </style>
    <style is:global>
      /* --color-* aliases for index.astro (maps to --hu-web-* / --hu-* tokens) */
      :root {
        --color-bg: var(--hu-web-bg);
        --color-text: var(--hu-web-text);
        --color-text-secondary: var(--hu-web-text-secondary);
        --color-text-tertiary: var(--hu-web-text-tertiary);
        --color-accent: var(--hu-accent);
        --color-accent-light: var(--hu-accent-light, var(--hu-accent-subtle));
        --color-accent-glow: var(--hu-accent-subtle);
        --color-border: var(--hu-web-border);
        --color-line-stroke: var(--hu-web-line-stroke);
        --color-node-fill: var(--hu-web-node-fill);
        --color-node-stroke: var(--hu-web-node-stroke);
        /* Terminal (dark surface — light border intentional) */
        --color-terminal-bg: var(--hu-web-terminal-bg);
        --color-terminal-chrome: var(--hu-web-terminal-chrome);
        --color-terminal-border: color-mix(in srgb, white 6%, transparent);
        /* Pills */
        --color-pill-provider: var(--hu-web-pill-provider);
        --color-pill-provider-bg: var(--hu-web-pill-provider-bg);
        --color-pill-provider-border: var(--hu-web-pill-provider-border);
        --color-pill-channel: var(--hu-web-pill-channel);
        --color-pill-channel-bg: var(--hu-web-pill-channel-bg);
        --color-pill-channel-border: var(--hu-web-pill-channel-border);
        --color-pill-tool: var(--hu-web-pill-tool);
        --color-pill-tool-bg: var(--hu-web-pill-tool-bg);
        --color-pill-tool-border: var(--hu-web-pill-tool-border);
      }
    </style>
  </head>
  <body
    style="background: var(--color-bg); color: var(--color-text);"
    class="antialiased overflow-x-hidden"
  >
    <div class="hu-particles" id="hu-particles" aria-hidden="true"></div>
    <div class="scroll-progress" id="scroll-progress"></div>
    <div id="custom-cursor" class="custom-cursor" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav />

    <main id="main-content" tabindex="-1">
      {/* ═══ HERO ═══ */}

      <section
        class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-24 overflow-hidden"
      >
        <canvas id="hero-webgl" class="hero-webgl-canvas" aria-hidden="true"
        ></canvas>
        <div class="hero-gradient noise-overlay"></div>
        <div
          class="ambient-coral"
          style="top: 15%; left: 50%; transform: translateX(-50%);"
        >
        </div>
        <div class="ambient-blue" style="top: 30%; right: 10%;"></div>
        <div class="hero-content text-center max-w-3xl mx-auto relative z-10">
          <img
            src={`${base}human.svg`}
            alt="h-uman logo"
            width="512"
            height="512"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="hero-logo w-20 h-20 md:w-24 md:h-24 mx-auto mb-10"
            style={`filter: drop-shadow(0 0 40px var(--color-accent-glow)); animation: float 6s ease-in-out infinite;`}
          />
          <h1
            class="hero-title hero-headline font-sans mb-6"
            style="color: var(--color-text); view-transition-name: page-heading;"
          >
            Bring AI to <span class="text-gradient">every</span> device on&nbsp;Earth.
          </h1>
          <p
            class="hero-tagline text-[clamp(1.1rem,2.2vw,1.35rem)] font-medium mb-6 hero-fade-in"
            style="color: var(--color-text-secondary); letter-spacing: 0.04em;"
          >
            not quite human.
          </p>
          <p
            class="hero-subtitle hero-desc mb-5 hero-fade-in mx-auto"
          >
            An autonomous AI that runs shell commands, manages files, browses the web, and remembers everything — across 50+ AI models and 34 messaging channels. All in <strong
              style="color: var(--color-text)">1,696&nbsp;kilobytes</strong
            > of pure&nbsp;C.
          </p>
          <p
            class="hero-subtitle text-[clamp(0.9rem,1.8vw,1.05rem)] leading-relaxed mb-10 hero-fade-in mx-auto"
            style="color: var(--color-text-tertiary)"
          >
            One static binary. Zero dependencies. Under 30&nbsp;ms cold start. Under 6&nbsp;MB&nbsp;RAM.
          </p>
          <div
            class="hero-buttons flex flex-col sm:flex-row gap-4 justify-center hero-fade-in"
          >
            <a href={`${base}getting-started/installation/`} class="btn-primary"
              >Get Started</a
            >
            <a
              href="https://github.com/sethdford/h-uman"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline">View on GitHub</a
            >
          </div>
          <div class="hero-fade-in mt-8 max-w-lg mx-auto">
            <div
              class="glass glass-enter flex items-center gap-3 pl-5 pr-3 py-3 rounded-xl font-mono text-[13px]"
            >
              <span style="color: var(--color-accent)">$</span>
              <code class="flex-1 overflow-x-auto whitespace-nowrap" style="color: var(--color-text-secondary)">git clone https://github.com/sethdford/h-uman.git</code>
              <button
                class="shrink-0 p-1.5 rounded-lg transition-all hover:scale-110"
                style="color: var(--color-text-tertiary)"
                aria-label="Copy to clipboard"
                onclick="navigator.clipboard.writeText('git clone https://github.com/sethdford/h-uman.git')"
              >
                <svg class="w-4 h-4" viewBox="0 0 256 256" fill="currentColor"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>
              </button>
            </div>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      {/* ═══ THE NUMBERS ═══ */}

      <section class="py-16 md:py-24 px-6 cv-defer">
        <div class="max-w-5xl mx-auto numbers-section">
          <div
            class="numbers-grid glass glass-enter px-4 md:px-8 py-8 md:py-10 grid grid-cols-3 md:grid-cols-6 gap-0"
          >
            {
              [
                { count: 1696, suffix: " KB", label: "Binary" },
                { count: 30, prefix: "<", suffix: " ms", label: "Startup" },
                { count: 4980, suffix: "+", label: "Tests" },
                { count: 50, suffix: "+", label: "Providers" },
                { count: 34, label: "Channels" },
                { count: 67, suffix: "+", label: "Tools" },
              ].map((stat, i, arr) => (
                <div
                  class={`number-item text-center py-6 md:py-0 ${i < arr.length - 1 ? "md:border-r" : ""}`}
                  data-reveal="scale"
                  style={`--ri: ${i}; border-color: var(--color-border)`}
                >
                  <div
                    class="font-sans font-black text-[clamp(2rem,4vw,3rem)] leading-none"
                    style="color: var(--color-text)"
                    data-count={stat.count}
                    data-prefix={stat.prefix || ""}
                    data-suffix={stat.suffix || ""}
                  >
                    {stat.prefix && (
                      <span class="count-prefix">{stat.prefix}</span>
                    )}
                    <span class="count-value">0</span>
                    {stat.suffix && (
                      <span class="count-suffix">{stat.suffix}</span>
                    )}
                  </div>
                  <div
                    class="text-[11px] font-medium mt-2 uppercase tracking-[0.1em]"
                    style="color: var(--color-text-tertiary)"
                  >
                    {stat.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      {/* ═══ THE PROBLEM ═══ */}

      <section
        class="relative py-24 md:py-32 px-6 cv-defer"
      >
        <div class="max-w-5xl mx-auto">
          <div class="grid md:grid-cols-2 gap-16 items-center">
            <div>
              <h2
                class="bloat-title font-sans font-extrabold text-[clamp(2rem,5vw,3.5rem)] mb-6"
                data-reveal
                style="color: var(--color-text); letter-spacing: -0.03em;"
              >
                The dependency<br/><span style="color: var(--color-accent)">problem.</span>
              </h2>
              <div class="bloat-stack flex flex-col items-center gap-3 mb-8">
                {
                  bloatItems.map((item, i) => (
                    <div
                      class={`bloat-card glass glass-enter px-8 py-4 text-[clamp(1rem,2vw,1.25rem)] w-full max-w-md text-center ${i === bloatItems.length - 1 ? "italic" : ""}`}
                      data-reveal="scale"
                      style={`--ri: ${i}; color: ${i === bloatItems.length - 1 ? "var(--color-text-tertiary)" : "var(--color-text-secondary)"}`}
                    >
                      {item}
                    </div>
                  ))
                }
              </div>
              <p
                class="bloat-answer text-[clamp(1.25rem,3vw,1.75rem)]"
                data-reveal
                style="color: var(--color-text)"
              >
                h-uman needs one thing: <span
                  style="color: var(--color-accent)"
                  class="font-semibold">a CPU.</span
                >
              </p>
            </div>
            <div class="dep-tree-svg" id="depTree" data-reveal="scale">
              <svg viewBox="0 0 340 400" fill="none" class="w-full" style="max-height: 420px;" role="img" aria-label="Dependency tree visualization showing 900+ transitive dependencies in typical AI frameworks vs zero in h-uman">
                <circle class="dep-circle root" cx="170" cy="30" data-delay="0"/>
                <text class="dep-label" x="170" y="56" text-anchor="middle" data-delay="100">agent.py</text>
                <line class="dep-node" x1="170" y1="40" x2="60" y2="100" data-delay="200"/>
                <line class="dep-node" x1="170" y1="40" x2="170" y2="100" data-delay="250"/>
                <line class="dep-node" x1="170" y1="40" x2="280" y2="100" data-delay="300"/>
                <circle class="dep-circle" cx="60" cy="105" data-delay="350"/>
                <text class="dep-label" x="60" y="122" text-anchor="middle" data-delay="350">langchain</text>
                <circle class="dep-circle" cx="170" cy="105" data-delay="400"/>
                <text class="dep-label" x="170" y="122" text-anchor="middle" data-delay="400">openai</text>
                <circle class="dep-circle" cx="280" cy="105" data-delay="450"/>
                <text class="dep-label" x="280" y="122" text-anchor="middle" data-delay="450">chromadb</text>
                <line class="dep-node bad" x1="60" y1="115" x2="20" y2="175" data-delay="500"/>
                <line class="dep-node bad" x1="60" y1="115" x2="60" y2="175" data-delay="520"/>
                <line class="dep-node bad" x1="60" y1="115" x2="100" y2="175" data-delay="540"/>
                <line class="dep-node bad" x1="170" y1="115" x2="140" y2="175" data-delay="560"/>
                <line class="dep-node bad" x1="170" y1="115" x2="200" y2="175" data-delay="580"/>
                <line class="dep-node bad" x1="280" y1="115" x2="240" y2="175" data-delay="600"/>
                <line class="dep-node bad" x1="280" y1="115" x2="280" y2="175" data-delay="620"/>
                <line class="dep-node bad" x1="280" y1="115" x2="320" y2="175" data-delay="640"/>
                <circle class="dep-circle" cx="20" cy="180" data-delay="700"/>
                <circle class="dep-circle" cx="60" cy="180" data-delay="720"/>
                <circle class="dep-circle" cx="100" cy="180" data-delay="740"/>
                <circle class="dep-circle" cx="140" cy="180" data-delay="760"/>
                <circle class="dep-circle" cx="200" cy="180" data-delay="780"/>
                <circle class="dep-circle" cx="240" cy="180" data-delay="800"/>
                <circle class="dep-circle" cx="280" cy="180" data-delay="820"/>
                <circle class="dep-circle" cx="320" cy="180" data-delay="840"/>
                <line class="dep-node bad" x1="20" y1="190" x2="10" y2="240" data-delay="900"/>
                <line class="dep-node bad" x1="20" y1="190" x2="35" y2="240" data-delay="910"/>
                <line class="dep-node bad" x1="60" y1="190" x2="50" y2="240" data-delay="920"/>
                <line class="dep-node bad" x1="60" y1="190" x2="75" y2="240" data-delay="930"/>
                <line class="dep-node bad" x1="100" y1="190" x2="90" y2="240" data-delay="940"/>
                <line class="dep-node bad" x1="100" y1="190" x2="115" y2="240" data-delay="950"/>
                <line class="dep-node bad" x1="140" y1="190" x2="130" y2="240" data-delay="960"/>
                <line class="dep-node bad" x1="200" y1="190" x2="190" y2="240" data-delay="970"/>
                <line class="dep-node bad" x1="200" y1="190" x2="215" y2="240" data-delay="980"/>
                <line class="dep-node bad" x1="240" y1="190" x2="230" y2="240" data-delay="990"/>
                <line class="dep-node bad" x1="280" y1="190" x2="265" y2="240" data-delay="1000"/>
                <line class="dep-node bad" x1="280" y1="190" x2="295" y2="240" data-delay="1010"/>
                <line class="dep-node bad" x1="320" y1="190" x2="310" y2="240" data-delay="1020"/>
                <line class="dep-node bad" x1="320" y1="190" x2="335" y2="240" data-delay="1030"/>
                <circle class="dep-circle" cx="10" cy="245" data-delay="1100"/>
                <circle class="dep-circle" cx="35" cy="245" data-delay="1110"/>
                <circle class="dep-circle" cx="50" cy="245" data-delay="1120"/>
                <circle class="dep-circle" cx="75" cy="245" data-delay="1130"/>
                <circle class="dep-circle" cx="90" cy="245" data-delay="1140"/>
                <circle class="dep-circle" cx="115" cy="245" data-delay="1150"/>
                <circle class="dep-circle" cx="130" cy="245" data-delay="1160"/>
                <circle class="dep-circle" cx="190" cy="245" data-delay="1170"/>
                <circle class="dep-circle" cx="215" cy="245" data-delay="1180"/>
                <circle class="dep-circle" cx="230" cy="245" data-delay="1190"/>
                <circle class="dep-circle" cx="265" cy="245" data-delay="1200"/>
                <circle class="dep-circle" cx="295" cy="245" data-delay="1210"/>
                <circle class="dep-circle" cx="310" cy="245" data-delay="1220"/>
                <circle class="dep-circle" cx="335" cy="245" data-delay="1230"/>
                <text class="dep-label" x="170" y="300" text-anchor="middle" font-size="11" data-delay="1400" fill="var(--hu-error, #e86c5d)">900+ dependencies</text>
                <text class="dep-label" x="170" y="320" text-anchor="middle" font-size="9" data-delay="1600">~200 MB installed</text>
                <line x1="120" y1="350" x2="220" y2="350" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4"/>
                <text class="dep-label" x="170" y="380" text-anchor="middle" font-size="11" data-delay="2000" fill="var(--color-accent)">h-uman: 0 dependencies</text>
                <text class="dep-label" x="170" y="396" text-anchor="middle" font-size="9" data-delay="2200">1,696 KB. That's it.</text>
              </svg>
            </div>
          </div>
        </div>
      </section>

      {/* ═══ THE CONTRAST ═══ */}

      <section class="py-12 md:py-20 px-6 cv-defer">
        <div class="max-w-3xl mx-auto">
          <div class="glass glass-enter grid grid-cols-3 gap-0 rounded-2xl overflow-hidden" data-reveal="scale">
            <div class="text-center py-8 md:py-10 px-4 border-r" style="border-color: var(--color-border)">
              <div class="font-black text-[clamp(2rem,4vw,3rem)] leading-none mb-2" style="color: var(--color-accent)">118&times;</div>
              <div class="text-[11px] uppercase tracking-widest font-medium" style="color: var(--color-text-tertiary)">smaller</div>
            </div>
            <div class="text-center py-8 md:py-10 px-4 border-r" style="border-color: var(--color-border)">
              <div class="font-black text-[clamp(2rem,4vw,3rem)] leading-none mb-2" style="color: var(--color-accent)">50&times;</div>
              <div class="text-[11px] uppercase tracking-widest font-medium" style="color: var(--color-text-tertiary)">less RAM</div>
            </div>
            <div class="text-center py-8 md:py-10 px-4">
              <div class="font-black text-[clamp(2rem,4vw,3rem)] leading-none mb-2" style="color: var(--color-accent)">Zero</div>
              <div class="text-[11px] uppercase tracking-widest font-medium" style="color: var(--color-text-tertiary)">dependencies</div>
            </div>
          </div>
          <p class="text-center text-[12px] mt-4" style="color: var(--color-text-tertiary)">
            vs. leading AI agent frameworks
          </p>
        </div>
      </section>

      {/* ═══ CRYSTAL GRID — What's inside 1,696 KB ═══ */}

      <section class="py-16 md:py-32 px-6 cv-defer">
        <div class="max-w-4xl mx-auto text-center">
          <h2
            class="font-sans font-extrabold text-[clamp(2rem,5vw,3.5rem)] mb-4"
            data-reveal
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            What's inside <span style="color: var(--color-accent)">1,696&nbsp;kilobytes?</span>
          </h2>
          <p
            class="text-lg mb-6"
            data-reveal
            style="color: var(--color-text-secondary)"
          >
            Every byte has a purpose. No runtime. No interpreter. No garbage collector. Just compiled&nbsp;C.
          </p>
          <div class="crystal-grid mb-8" id="crystalGrid" data-reveal="scale"></div>
