                    const obj = { val: 0 };
                    gsap.to(obj, {
                      val: target,
                      duration: 1.2,
                      ease: "power3.out",
                      delay: 0.3 + i * 0.1,
                      onUpdate: () => {
                        el.textContent = Math.round(obj.val).toString();
                      },
