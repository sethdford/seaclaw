        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.normal}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.sm}",
        "$type": "dimension"
      }
    },
    "label-lg": {
      "fontSize": {
        "$value": "{fontSize.base}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.medium}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.tight}",
        "$type": "number"
      },
      "letterSpacing": {
