                  <svg width="12" height="12" viewBox="0 0 256 256" fill="currentColor"><path d="M232,56v64a8,8,0,0,1-16,0V75.31l-82.34,82.35a8,8,0,0,1-11.32,0L96,131.31,29.66,197.66a8,8,0,0,1-11.32-11.32l72-72a8,8,0,0,1,11.32,0L128,140.69,204.69,64H160a8,8,0,0,1,0-16h64A8,8,0,0,1,232,56Z"/></svg>
                  Active
                </div>
              </div>
              <div class="text-left p-4 rounded-xl" style="background: rgba(255,255,255, var(--sc-glass-subtle-bg-opacity)); border: 1px solid rgba(255,255,255, var(--sc-glass-standard-bg-opacity));">
                <div class="text-[10px] uppercase tracking-wider mb-2" style="color: var(--sc-text-muted);">Channels</div>
                <div class="text-2xl font-bold mb-1" style="color: var(--sc-text-muted);">
                  <span class="dash-count" data-target="20">0</span>
                </div>
                <div class="flex items-center gap-1 text-[11px]" style="color: var(--sc-success);">
                  <svg width="12" height="12" viewBox="0 0 256 256" fill="currentColor"><path d="M232,56v64a8,8,0,0,1-16,0V75.31l-82.34,82.35a8,8,0,0,1-11.32,0L96,131.31,29.66,197.66a8,8,0,0,1-11.32-11.32l72-72a8,8,0,0,1,11.32,0L128,140.69,204.69,64H160a8,8,0,0,1,0-16h64A8,8,0,0,1,232,56Z"/></svg>
                  Connected
                </div>
              </div>
              <div class="text-left p-4 rounded-xl" style="background: rgba(255,255,255, var(--sc-glass-subtle-bg-opacity)); border: 1px solid rgba(255,255,255, var(--sc-glass-standard-bg-opacity));">
                <div class="text-[10px] uppercase tracking-wider mb-2" style="color: var(--sc-text-muted);">Tools</div>
                <div class="text-2xl font-bold mb-1" style="color: var(--sc-text-muted);">
                  <span class="dash-count" data-target="53">0</span>
                </div>
                <div class="flex items-center gap-1 text-[11px]" style="color: var(--sc-text-muted);">
                  <svg width="12" height="12" viewBox="0 0 256 256" fill="currentColor"><path d="M221.66,133.66l-48,48a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69l-34.35-34.34a8,8,0,0,1,11.32-11.32l48,48A8,8,0,0,1,221.66,133.66Z"/></svg>
                  Stable
                </div>
              </div>
              <div class="text-left p-4 rounded-xl" style="background: rgba(255,255,255, var(--sc-glass-subtle-bg-opacity)); border: 1px solid rgba(255,255,255, var(--sc-glass-standard-bg-opacity));">
                <div class="text-[10px] uppercase tracking-wider mb-2" style="color: var(--sc-text-muted);">Sessions</div>
                <div class="text-2xl font-bold mb-1" style="color: var(--sc-text-muted);">
                  <span class="dash-count" data-target="5">0</span>
                </div>
                <div class="flex items-center gap-1 text-[11px]" style="color: var(--sc-success);">
                  <svg width="12" height="12" viewBox="0 0 256 256" fill="currentColor"><path d="M232,56v64a8,8,0,0,1-16,0V75.31l-82.34,82.35a8,8,0,0,1-11.32,0L96,131.31,29.66,197.66a8,8,0,0,1-11.32-11.32l72-72a8,8,0,0,1,11.32,0L128,140.69,204.69,64H160a8,8,0,0,1,0-16h64A8,8,0,0,1,232,56Z"/></svg>
                  Active
                </div>
              </div>
            </div>
            <div id="dash-activity" class="text-left text-[13px] space-y-2" style="color: var(--sc-text-muted);">
            </div>
          </div>
