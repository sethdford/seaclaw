---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import AnimatedLogo from "../components/AnimatedLogo.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<html lang="en" class="hu-lcp-done">
  <head>
    <script is:inline>
      (function () {
        var s = localStorage.getItem("hu-theme");
        var m = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = s || m;
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://h-uman.ai/brand/" />
    <link
      rel="preload"
      href={`${base}fonts/avenir/Avenir-Black.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href={`${base}fonts/avenir/Avenir-Book.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>Brand — h-uman</title>
    <meta
      name="description"
      content="h-uman brand identity: logo, colors, typography, voice. Human green. Avenir. not quite human."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="theme-color" content="#7AB648" />
    <meta property="og:title" content="Brand — h-uman" />
    <meta
      property="og:description"
      content="h-uman brand identity: logo, colors, typography, voice."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://h-uman.ai/brand/" />

    <style is:global>
      /* --color-* aliases for brand.astro (shortcuts over canonical --hu-* tokens) */
      :root {
        --color-bg: var(--hu-bg);
        --color-text: var(--hu-text);
        --color-text-secondary: var(--hu-text-secondary);
        --color-text-tertiary: var(--hu-text-muted);
        --color-accent: var(--hu-accent);
        --color-accent-light: var(--hu-accent-light, var(--hu-accent-subtle));
        --color-border: var(--hu-border-subtle);
      }
    </style>
  </head>
  <body
    style="background: var(--color-bg); color: var(--color-text);"
    class="antialiased overflow-x-hidden"
  >
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav />

    <main id="main-content" tabindex="-1">
      {/* ═══ 1. Hero ═══ */}
      <section
        class="relative min-h-[70vh] flex flex-col items-center justify-center px-6 pt-24 pb-16 overflow-hidden"
        style="background: var(--hu-bg-surface, #152333);"
      >
        <div
          class="absolute inset-0 opacity-30"
          style="background: radial-gradient(ellipse 80% 50% at 50% 0%, color-mix(in srgb, var(--hu-accent) 25%, transparent), transparent 70%);"
        >
        </div>
        <div class="relative z-10 max-w-5xl mx-auto text-center">
          <div class="mb-8">
            <AnimatedLogo size={160} interactive />
          </div>
          <h1
            class="text-[clamp(3.5rem,10vw,7rem)] font-black leading-[0.95] tracking-tighter mb-4"
            style="font-family: var(--hu-font); color: var(--hu-text);"
          >
            h-uman
          </h1>
          <p
            class="text-[clamp(1.25rem,2.5vw,1.75rem)] font-normal mb-8"
            style="color: var(--hu-text-secondary); letter-spacing: 0.06em;"
          >
            not quite human.
          </p>
          <p
            class="text-[clamp(1rem,1.8vw,1.2rem)] max-w-2xl mx-auto leading-relaxed"
            style="color: var(--hu-text-muted);"
          >
            We built an AI runtime that's honest about what it is. Not trying to
            be human. Not pretending to be anything it's not. Just a fast,
            small, capable runtime that fits anywhere a CPU exists.
          </p>
        </div>
      </section>

      {/* ═══ Section Nav ═══ */}
      <nav class="brand-section-nav" aria-label="Brand guide sections">
        <a href="#name">Name</a>
        <a href="#logo">Logo</a>
        <a href="#color">Color</a>
        <a href="#typography">Typography</a>
        <a href="#voice">Voice</a>
        <a href="#iconography">Icons</a>
        <a href="#motion">Motion</a>
        <a href="#resources">Resources</a>
      </nav>

      {/* ═══ 2. Name & Tagline ═══ */}
      <section id="name" class="py-24 md:py-32 px-6 cv-defer" data-reveal>
        <div class="max-w-5xl mx-auto">
          <h2
            class="text-[clamp(2rem,4vw,3rem)] font-black mb-16"
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            Name & Tagline
          </h2>
          <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
            <div
              class="glass rounded-2xl p-8 md:p-10"
              style="border: 1px solid var(--color-border);"
            >
              <div
                class="text-[clamp(2.5rem,5vw,4rem)] font-black mb-6"
                style="font-family: var(--hu-font); color: var(--color-accent); letter-spacing: -0.02em;"
              >
                h-uman
              </div>
              <p
                class="text-base leading-relaxed"
                style="color: var(--color-text-secondary);"
              >
                The hyphen splits the word, reminding you this is almost—but not
                quite—human. It's a deliberate pause. A breath. A moment of
                honesty before the rest of the word completes.
              </p>
            </div>
            <div
              class="glass rounded-2xl p-8 md:p-10"
              style="border: 1px solid var(--color-border);"
            >
              <div
                class="text-[clamp(1.5rem,3vw,2rem)] font-normal mb-6"
                style="font-family: var(--hu-font); color: var(--color-text);"
              >
                not quite human.
              </div>
              <ul
                class="space-y-3 text-sm"
                style="color: var(--color-text-secondary);"
              >
                <li>Always lowercase.</li>
                <li>Always ends with a period.</li>
                <li>
                  Use em dash when pairing with brand name: <span
                    style="color: var(--color-text);"
                    >h-uman — not quite human.</span
                  >
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      {/* ═══ 3. Logo System ═══ */}
      <section id="logo" class="py-24 md:py-32 px-6 cv-defer" data-reveal>
        <div class="max-w-5xl mx-auto">
          <h2
            class="text-[clamp(2rem,4vw,3rem)] font-black mb-16"
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            Logo System
          </h2>

          <div class="space-y-16">
            {/* Symbol + Clear Space */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Symbol
              </h3>
              <div
                class="rounded-2xl p-12 md:p-16 flex flex-col items-center justify-center min-h-[320px]"
                style="background: var(--hu-bg-surface, #152333);"
              >
                <div
                  class="relative flex items-center justify-center p-16 rounded-xl mb-8"
                  style="background: color-mix(in srgb, var(--hu-accent) 8%, transparent); border: 1px dashed color-mix(in srgb, var(--hu-accent) 30%, transparent);"
                >
                  <span
                    class="absolute top-4 left-4 right-4 bottom-4 border border-dashed rounded-lg opacity-40"
                    style="border-color: var(--hu-accent);"
                    aria-hidden="true"></span>
                  <img
                    src={`${base}human.svg`}
                    alt="h-uman logo"
                    width="160"
                    height="160"
                    class="w-32 h-32 md:w-40 md:h-40 relative z-10"
                    loading="lazy"
                  />
                </div>
                <p class="text-sm" style="color: var(--hu-text-secondary);">
                  Clear space: minimum 1× logo height on all sides
                </p>
              </div>
            </div>

            {/* Lockups */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Lockups
              </h3>
              <div class="grid sm:grid-cols-2 gap-6">
                <div
                  class="rounded-2xl p-10 flex flex-col items-center justify-center gap-4"
                  style="background: var(--hu-bg-surface, #152333);"
                >
                  <div class="flex items-center gap-4">
                    <img
                      src={`${base}human.svg`}
                      alt=""
                      width="48"
                      height="48"
                      class="w-12 h-12"
                      loading="lazy"
                      aria-hidden="true"
                    />
                    <span
                      class="text-2xl font-black"
                      style="font-family: var(--hu-font); color: var(--color-text);"
                      >h-uman</span
                    >
                  </div>
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >Horizontal lockup</span
                  >
                </div>
                <div
                  class="rounded-2xl p-10 flex flex-col items-center justify-center gap-4"
                  style="background: var(--hu-bg-surface, #152333);"
                >
                  <img
                    src={`${base}human.svg`}
                    alt=""
                    width="48"
                    height="48"
                    class="w-12 h-12"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <span
                    class="text-2xl font-black"
                    style="font-family: var(--hu-font); color: var(--color-text);"
                    >h-uman</span
                  >
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >Stacked lockup</span
                  >
                </div>
              </div>
            </div>

            {/* Monochrome & Reversed */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Monochrome & Reversed
              </h3>
              <div class="grid sm:grid-cols-3 gap-6">
                <div
                  class="rounded-xl p-8 flex flex-col items-center justify-center gap-3"
                  style="background: var(--hu-bg-surface, #152333);"
                >
                  <img
                    src={`${base}human.svg`}
                    alt="Full color logo"
                    width="64"
                    height="64"
                    class="w-16 h-16"
                    loading="lazy"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >Full color</span
                  >
                </div>
                <div
                  class="rounded-xl p-8 flex flex-col items-center justify-center gap-3"
                  style="background: var(--hu-bg-surface, #152333);"
                >
                  <img
                    src={`${base}human.svg`}
                    alt="Monochrome logo"
                    width="64"
                    height="64"
                    class="w-16 h-16 brightness-0 invert"
                    loading="lazy"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >Monochrome (white)</span
                  >
                </div>
                <div
                  class="rounded-xl p-8 flex flex-col items-center justify-center gap-3"
                  style="background: var(--hu-color-white, #fffefa);"
                >
                  <img
                    src={`${base}human.svg`}
                    alt="Reversed logo"
                    width="64"
                    height="64"
                    class="w-16 h-16 brightness-0"
                    loading="lazy"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >Monochrome (black)</span
                  >
                </div>
              </div>
            </div>

            {/* Size Minimum */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Minimum Size
              </h3>
              <div class="flex items-end gap-8 flex-wrap">
                <div class="flex flex-col items-center gap-2">
                  <img
                    src={`${base}human.svg`}
                    alt=""
                    width="64"
                    height="64"
                    class="w-16 h-16"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >64px</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2">
                  <img
                    src={`${base}human.svg`}
                    alt=""
                    width="48"
                    height="48"
                    class="w-12 h-12"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >48px</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2">
                  <img
                    src={`${base}human.svg`}
                    alt=""
                    width="32"
                    height="32"
                    class="w-8 h-8"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >32px</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2">
                  <img
                    src={`${base}human.svg`}
                    alt=""
                    width="24"
                    height="24"
                    class="w-6 h-6"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <span class="text-xs" style="color: var(--hu-text-muted);"
                    >24px <svg
                      class="inline w-3.5 h-3.5"
                      viewBox="0 0 256 256"
                      fill="currentColor"
                      aria-hidden="true"
                      ><path
                        d="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM222.93,203.8a8.5,8.5,0,0,1-7.48,4.2H40.55a8.5,8.5,0,0,1-7.48-4.2,7.59,7.59,0,0,1,0-7.72L120.52,44.21a8.75,8.75,0,0,1,15,0l87.45,151.87A7.59,7.59,0,0,1,222.93,203.8ZM120,144V104a8,8,0,0,1,16,0v40a8,8,0,0,1-16,0Zm20,36a12,12,0,1,1-12-12A12,12,0,0,1,140,180Z"
                      ></path></svg
                    > min</span
                  >
                </div>
                <div class="flex flex-col items-center gap-2 opacity-40">
                  <img
                    src={`${base}human.svg`}
                    alt=""
                    width="16"
                    height="16"
                    class="w-4 h-4"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <span class="text-xs" style="color: var(--hu-error);"
                    >16px — too small</span
                  >
                </div>
              </div>
              <p
                class="text-sm mt-4"
                style="color: var(--color-text-secondary);"
              >
                Minimum reproduction size: <strong>24px</strong> (favicon/tab). Below
                24px the mark loses legibility.
              </p>
            </div>

            {/* Misuse */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Misuse
              </h3>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
                <div class="brand-misuse-card">
                  <div
                    class="brand-misuse-demo"
                    style="background: var(--hu-bg-surface, #152333);"
                  >
                    <img
                      src={`${base}human.svg`}
                      alt=""
                      width="48"
                      height="48"
                      class="w-12 h-8"
                      loading="lazy"
                      aria-hidden="true"
                      style="transform: scaleX(1.5);"
                    />
                  </div>
                  <span
                    class="text-xs mt-2 block"
                    style="color: var(--hu-error);">Don't stretch</span
                  >
                </div>
                <div class="brand-misuse-card">
                  <div
                    class="brand-misuse-demo"
                    style="background: var(--hu-bg-surface, #152333);"
                  >
                    <img
                      src={`${base}human.svg`}
                      alt=""
                      width="48"
                      height="48"
                      class="w-12 h-12"
                      loading="lazy"
                      aria-hidden="true"
                      style="opacity: 0.3;"
                    />
                  </div>
                  <span
                    class="text-xs mt-2 block"
                    style="color: var(--hu-error);">Don't reduce opacity</span
                  >
                </div>
                <div class="brand-misuse-card">
                  <div
                    class="brand-misuse-demo"
                    style="background: var(--hu-bg-surface, #152333);"
                  >
                    <img
                      src={`${base}human.svg`}
                      alt=""
                      width="48"
                      height="48"
                      class="w-12 h-12"
                      loading="lazy"
                      aria-hidden="true"
                      style="filter: hue-rotate(90deg);"
                    />
                  </div>
                  <span
                    class="text-xs mt-2 block"
                    style="color: var(--hu-error);">Don't recolor the orb</span
                  >
                </div>
                <div class="brand-misuse-card">
                  <div
                    class="brand-misuse-demo"
                    style="background: var(--hu-bg-surface, #152333);"
                  >
                    <svg
                      viewBox="0 0 100 100"
                      class="w-12 h-12"
                      aria-hidden="true"
                    >
                      <circle cx="50" cy="50" r="40" fill="#5A9A30"></circle>
                      <circle cx="36" cy="47" r="6" fill="white"
                      ></circle><circle cx="38" cy="44" r="2" fill="black"
                      ></circle>
                      <circle cx="64" cy="47" r="6" fill="white"
                      ></circle><circle cx="66" cy="44" r="2" fill="black"
                      ></circle>
                    </svg>
                  </div>
                  <span
                    class="text-xs mt-2 block"
                    style="color: var(--hu-error);">Don't add pupils</span
                  >
                </div>
              </div>
            </div>

            {/* Animation Rules */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Animation Rules
              </h3>
              <div class="grid sm:grid-cols-2 gap-8 mb-8">
                <div
                  class="glass rounded-2xl p-8"
                  style="border: 1px solid var(--color-border);"
                >
                  <div class="flex items-center gap-2 mb-4">
                    <svg
                      class="w-5 h-5"
                      viewBox="0 0 256 256"
                      fill="currentColor"
                      style="color: var(--hu-accent);"
                      aria-hidden="true"
                    >
                      <path
                        d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"
                      ></path>
                    </svg>
                    <span
                      class="text-base font-semibold"
                      style="color: var(--color-text);">Allowed</span
                    >
                  </div>
                  <ul
                    class="space-y-2 text-sm"
                    style="color: var(--color-text-secondary);"
                  >
                    <li>
                      Squash & stretch breathing (non-uniform scale3d, 4s cycle)
                    </li>
                    <li>Double-blink (randomized, 10–23s interval)</li>
                    <li>Eye gaze tracking with 3D tilt on mouse hover</li>
                    <li>Ambient eye drift (subtle, 15s cycle)</li>
                    <li>
                      Micro-saccades (50ms random eye jumps, 30% trigger a quick
                      blink)
                    </li>
                    <li>Glow pulse + glow lag (follows gaze at 0.15x)</li>
                    <li>Ring breathing with staggered parallax</li>
                    <li>
                      Dual ambient pulse rings (4s, staggered 2s apart, fade
                      out)
                    </li>
                    <li>Idle drift (figure-8 translate + micro-rotate)</li>
                    <li>Spring entry animation (scale 0.6 → 1)</li>
                    <li>Hover scale (1.03x) with spring easing</li>
                    <li>Scroll-linked subtle eye shift</li>
                    <li>
                      Must respect <code
                        class="px-1 py-0.5 rounded"
                        style="background: var(--hu-surface-container-high);"
                        >prefers-reduced-motion</code
                      >
                    </li>
                  </ul>
                </div>
                <div
                  class="glass rounded-2xl p-8"
                  style="border: 1px solid var(--color-border);"
                >
                  <div class="flex items-center gap-2 mb-4">
                    <svg
                      class="w-5 h-5"
                      viewBox="0 0 256 256"
                      fill="currentColor"
                      style="color: var(--hu-error);"
                      aria-hidden="true"
                    >
                      <path
                        d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"
                      ></path>
                    </svg>
                    <span
                      class="text-base font-semibold"
                      style="color: var(--color-text);">Not allowed</span
                    >
                  </div>
                  <ul
                    class="space-y-2 text-sm"
                    style="color: var(--color-text-secondary);"
                  >
                    <li>Continuous rotation or spinning</li>
                    <li>Adding pupils, eyelids, or extra features</li>
                    <li>Making eyes uneven or asymmetric</li>
                    <li>Recoloring eyes (always white)</li>
                    <li>Particle/dissolve effects on the orb</li>
                    <li>Bounce, wobble, or playful motion</li>
                  </ul>
                </div>
              </div>

              {/* Animated vs Static comparison */}
              <div class="grid sm:grid-cols-2 gap-8">
                <div
                  class="rounded-2xl p-10 flex flex-col items-center justify-center gap-4"
                  style="background: var(--hu-bg-surface, #152333);"
                >
                  <AnimatedLogo size={100} interactive />
                  <span
                    class="text-sm font-medium"
                    style="color: var(--hu-text-secondary);"
                    >Animated — hero, landing pages</span
                  >
                </div>
                <div
                  class="rounded-2xl p-10 flex flex-col items-center justify-center gap-4"
                  style="background: var(--hu-bg-surface, #152333);"
                >
                  <img
                    src={`${base}human.svg`}
                    alt="Static orb mark"
                    width="100"
                    height="100"
                    class="w-[100px] h-[100px]"
                    loading="lazy"
                  />
                  <span
                    class="text-sm font-medium"
                    style="color: var(--hu-text-secondary);"
                    >Static — nav, footer, favicons</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ═══ 4. Color ═══ */}
      <section id="color" class="py-24 md:py-32 px-6 cv-defer" data-reveal>
        <div class="max-w-5xl mx-auto">
          <h2
            class="text-[clamp(2rem,4vw,3rem)] font-black mb-16"
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            Color
          </h2>
          <div class="space-y-16">
            {/* Primary Color */}
            <div>
              <h3
                class="text-lg font-semibold mb-4"
                style="color: var(--color-text);"
              >
                Human Green (Primary)
              </h3>
              <div
                class="h-32 md:h-40 rounded-2xl mb-4"
                style="background: var(--hu-accent);"
              >
              </div>
