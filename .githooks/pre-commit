#!/bin/sh
# pre-commit: auto-format C files, format check, design token lint.
# Activate: git config core.hooksPath .githooks

CLANG_FMT="clang-format"
if ! command -v "$CLANG_FMT" >/dev/null 2>&1; then
    for p in /opt/homebrew/opt/llvm/bin/clang-format /usr/local/opt/llvm/bin/clang-format; do
        if [ -x "$p" ]; then CLANG_FMT="$p"; break; fi
    done
fi

if [ -d "src" ] && [ -f "CMakeLists.txt" ]; then
    staged_ch=$(git diff --cached --name-only --diff-filter=ACM -- '*.c' '*.h')
    if [ -n "$staged_ch" ]; then
        echo "$staged_ch" | while IFS= read -r f; do
            if grep -qn '	' "$f" 2>/dev/null; then
                echo "Warning: tabs found in $f (project uses spaces)"
            fi
        done
        echo "$staged_ch" | xargs "$CLANG_FMT" -i 2>/dev/null
        echo "$staged_ch" | xargs git add
        if ! echo "$staged_ch" | xargs "$CLANG_FMT" --dry-run -Werror 2>/dev/null; then
            echo "clang-format failed even after auto-format. Check .clang-format config."
            exit 1
        fi
    fi
fi

# Check for declared-but-undefined symbols in staged headers
if [ -d "build" ] && [ -f "build/libseaclaw_core.a" ]; then
    staged_h=$(git diff --cached --name-only --diff-filter=ACM -- 'include/seaclaw/*.h' 'include/seaclaw/**/*.h')
    if [ -n "$staged_h" ]; then
        UNDEFS=$(nm -u build/libseaclaw_core.a 2>/dev/null | grep ' U _sc_' | sort -u || true)
        if [ -n "$UNDEFS" ]; then
            echo "Warning: possibly undefined sc_* symbols in library:"
            echo "$UNDEFS" | head -10
        fi
    fi
fi

# Check design token drift when token sources change
staged_tokens=$(git diff --cached --name-only --diff-filter=ACM -- 'design-tokens/*.tokens.json' 'design-tokens/build.ts')
if [ -n "$staged_tokens" ]; then
  if [ -x "design-tokens/check-drift.sh" ]; then
    echo "Checking design token drift..."
    bash design-tokens/check-drift.sh
    if [ $? -ne 0 ]; then
      echo "Token drift detected. Run: cd design-tokens && npm run build"
      exit 1
    fi
  fi
fi

# Regenerate website assets when SVG sources or generate script change
staged_assets=$(git diff --cached --name-only --diff-filter=ACM -- 'website/public/seaclaw.svg' 'website/public/og-image.svg' 'website/scripts/generate-assets.mjs')
if [ -n "$staged_assets" ]; then
  if command -v node >/dev/null 2>&1 && [ -f "website/scripts/generate-assets.mjs" ]; then
    echo "Regenerating website favicon/OG assets..."
    (cd website && node scripts/generate-assets.mjs)
    git add website/public/favicon-32.png website/public/apple-touch-icon.png website/public/og-image.png 2>/dev/null
  fi
fi

# Lint for raw hex colors in staged CSS/TS/Astro files
if [ -x "scripts/lint-raw-colors.sh" ]; then
    staged_style=$(git diff --cached --name-only --diff-filter=ACM -- '*.css' '*.ts' '*.tsx' '*.astro' | grep -v 'tokens\.' | grep -v 'design-tokens/' || true)
    if [ -n "$staged_style" ]; then
        ./scripts/lint-raw-colors.sh
        if [ $? -ne 0 ]; then
            echo "Raw hex color lint failed. Use --sc-* or --sc-web-* design tokens instead."
            exit 1
        fi
    fi
fi

# Lint for raw values (rgba, durations, breakpoints) in staged UI TS files
staged_ui_ts=$(git diff --cached --name-only --diff-filter=ACM -- 'ui/src/**/*.ts' | grep -v '.test.' | grep -v 'demo-gateway' || true)
if [ -n "$staged_ui_ts" ] && [ -x "ui/scripts/lint-raw-values.sh" ]; then
    echo "Checking design token usage in staged UI files..."
    # Strip ui/ prefix since lint script runs from ui/ dir
    stripped=$(echo "$staged_ui_ts" | sed 's|^ui/||')
    (cd ui && bash scripts/lint-raw-values.sh $stripped)
    if [ $? -ne 0 ]; then
        echo "Token lint failed. Use --sc-* design tokens instead of raw hex/rgba/durations."
        exit 1
    fi
fi
