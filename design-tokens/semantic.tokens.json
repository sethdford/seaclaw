{
  "$description": "Semantic tokens — ocean-aligned theme",
  "$extensions": {
    "seaclaw.colorSpace": "display-p3",
    "seaclaw.p3Colors": {
      "dark.accent": "color(display-p3 0.078 0.722 0.651)",
      "dark.accent-text": "color(display-p3 0.176 0.831 0.749)",
      "dark.accent-hover": "color(display-p3 0.176 0.831 0.749)",
      "dark.accent-strong": "color(display-p3 0.369 0.918 0.831)",
      "dark.accent-secondary": "color(display-p3 0.961 0.620 0.043)",
      "dark.accent-tertiary": "color(display-p3 0.388 0.400 0.945)",
      "dark.success": "color(display-p3 0.063 0.725 0.506)",
      "dark.warning": "color(display-p3 0.918 0.702 0.031)",
      "dark.error": "color(display-p3 0.976 0.439 0.400)",
      "dark.info": "color(display-p3 0.231 0.510 0.965)",
      "dark.focus-ring": "color(display-p3 0.078 0.722 0.651)",
      "dark.link": "color(display-p3 0.176 0.831 0.749)",
      "light.accent": "color(display-p3 0.078 0.722 0.651)",
      "light.accent-text": "color(display-p3 0.051 0.580 0.533)",
      "light.success": "color(display-p3 0.022 0.588 0.412)",
      "light.warning": "color(display-p3 0.792 0.541 0.016)",
      "light.error": "color(display-p3 0.863 0.149 0.149)",
      "light.info": "color(display-p3 0.145 0.388 0.922)"
    }
  },
  "dark": {
    "$description": "Dark theme — deep ocean",
    "bg": { "$value": "{color.neutral.50}", "$type": "color" },
    "bg-inset": { "$value": "{color.neutral.100}", "$type": "color" },
    "bg-surface": { "$value": "{color.neutral.150}", "$type": "color" },
    "bg-elevated": { "$value": "{color.neutral.200}", "$type": "color" },
    "bg-overlay": { "$value": "{color.neutral.250}", "$type": "color" },

    "text": { "$value": "{color.neutral.750}", "$type": "color" },
    "text-muted": { "$value": "{color.neutral.500}", "$type": "color" },
    "text-faint": { "$value": "{color.neutral.400}", "$type": "color" },

    "accent": { "$value": "{color.teal.500}", "$type": "color" },
    "accent-text": {
      "$value": "{color.teal.400}",
      "$type": "color",
      "$description": "Accent color for text on dark backgrounds"
    },
    "accent-hover": { "$value": "{color.teal.400}", "$type": "color" },
    "accent-subtle": { "$value": "{color.teal.dark-subtle}", "$type": "color" },
    "accent-strong": { "$value": "{color.teal.300}", "$type": "color" },
    "on-accent": { "$value": "#071018", "$type": "color" },

    "accent-secondary": { "$value": "{color.amber.500}", "$type": "color" },
    "accent-secondary-text": {
      "$value": "{color.amber.400}",
      "$type": "color",
      "$description": "Amber accent for text on dark backgrounds"
    },
    "accent-secondary-hover": {
      "$value": "{color.amber.400}",
      "$type": "color"
    },
    "accent-secondary-subtle": {
      "$value": "{color.amber.dark-subtle}",
      "$type": "color"
    },
    "accent-secondary-strong": {
      "$value": "{color.amber.300}",
      "$type": "color"
    },
    "on-accent-secondary": { "$value": "#071018", "$type": "color" },

    "accent-tertiary": { "$value": "{color.indigo.500}", "$type": "color" },
    "accent-tertiary-text": {
      "$value": "{color.indigo.400}",
      "$type": "color",
      "$description": "Indigo accent for text on dark backgrounds"
    },
    "accent-tertiary-hover": {
      "$value": "{color.indigo.400}",
      "$type": "color"
    },
    "accent-tertiary-subtle": {
      "$value": "{color.indigo.dark-subtle}",
      "$type": "color"
    },
    "accent-tertiary-strong": {
      "$value": "{color.indigo.300}",
      "$type": "color"
    },
    "on-accent-tertiary": { "$value": "#ffffff", "$type": "color" },

    "border": { "$value": "{color.neutral.300}", "$type": "color" },
    "border-subtle": { "$value": "{color.neutral.200}", "$type": "color" },

    "success": { "$value": "{color.seafoam.500}", "$type": "color" },
    "success-dim": { "$value": "{color.seafoam.dim}", "$type": "color" },
    "warning": { "$value": "{color.yellow.500}", "$type": "color" },
    "warning-dim": { "$value": "{color.yellow.dim}", "$type": "color" },
    "error": { "$value": "{color.coral.500}", "$type": "color" },
    "error-dim": { "$value": "{color.coral.dark-subtle}", "$type": "color" },
    "info": { "$value": "{color.blue.500}", "$type": "color" },
    "info-dim": { "$value": "{color.blue.dim}", "$type": "color" },

    "focus-ring": { "$value": "{color.teal.500}", "$type": "color" },
    "focus-ring-width": { "$value": "2px", "$type": "dimension" },
    "focus-ring-offset": { "$value": "2px", "$type": "dimension" },

    "link": { "$value": "{color.teal.400}", "$type": "color" },
    "link-hover": { "$value": "{color.teal.300}", "$type": "color" },
    "link-active": { "$value": "{color.teal.500}", "$type": "color" },
    "link-visited": { "$value": "{color.teal.600}", "$type": "color" },

    "hover-overlay": {
      "$value": "rgba(255, 255, 255, 0.06)",
      "$type": "color"
    },
    "pressed-overlay": {
      "$value": "rgba(255, 255, 255, 0.10)",
      "$type": "color"
    },
    "disabled-overlay": {
      "$value": "rgba(255, 255, 255, 0.04)",
      "$type": "color"
    },
    "backdrop-overlay": {
      "$value": "rgba(0, 0, 0, 0.6)",
      "$type": "color"
    },

    "shadow-xs": {
      "$value": "0 1px 2px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.06)",
      "$type": "shadow"
    },
    "shadow-sm": {
      "$value": "0 1px 3px rgba(0,0,0,0.35), 0 2px 8px rgba(0,8,20,0.3), inset 0 1px 0 rgba(255,255,255,0.06)",
      "$type": "shadow"
    },
    "shadow-md": {
      "$value": "0 2px 4px rgba(0,0,0,0.3), 0 8px 24px rgba(0,8,20,0.35), inset 0 1px 0 rgba(255,255,255,0.05)",
      "$type": "shadow"
    },
    "shadow-lg": {
      "$value": "0 4px 8px rgba(0,0,0,0.35), 0 16px 48px rgba(0,8,20,0.4), inset 0 1px 0 rgba(255,255,255,0.04)",
      "$type": "shadow"
    },
    "shadow-xl": {
      "$value": "0 8px 16px rgba(0,0,0,0.4), 0 32px 72px rgba(0,8,20,0.45), inset 0 1px 0 rgba(255,255,255,0.04)",
      "$type": "shadow"
    },
    "shadow-card": {
      "$value": "0 1px 3px rgba(0,0,0,0.25), 0 8px 24px rgba(0,8,20,0.25), inset 0 1px 0 rgba(255,255,255,0.06)",
      "$type": "shadow"
    },
    "shadow-glow-accent": {
      "$value": "0 0 0 1px var(--sc-accent-subtle), 0 4px 16px rgba(20,184,166,0.15)",
      "$type": "shadow"
    },
    "shadow-inset": {
      "$value": "inset 0 1px 2px rgba(0,0,0,0.06)",
      "$type": "shadow"
    },
    "surface-gradient": {
      "$value": "linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(0,0,0,0.15) 100%)",
      "$type": "string"
    },
    "surface-glow": {
      "$value": "radial-gradient(ellipse at 50% 0%, rgba(20,184,166,0.1) 0%, transparent 70%)",
      "$type": "string"
    },
    "button-gradient-primary": {
      "$value": "linear-gradient(180deg, rgba(255,255,255,0.15) 0%, rgba(0,0,0,0.2) 100%)",
      "$type": "string"
    },
    "hero-gradient": {
      "$value": "linear-gradient(135deg, rgba(20,184,166,0.14) 0%, rgba(16,185,129,0.08) 50%, transparent 100%)",
      "$type": "string"
    }
  },
  "light": {
    "$description": "Light theme — sandy shore, clear sky, ocean spring day",
    "bg": { "$value": "{color.neutral.900}", "$type": "color" },
    "bg-inset": { "$value": "{color.neutral.800}", "$type": "color" },
    "bg-surface": { "$value": "#ffffff", "$type": "color" },
    "bg-warm": { "$value": "#fafcfe", "$type": "color" },
    "bg-elevated": { "$value": "{color.neutral.850}", "$type": "color" },
    "bg-overlay": { "$value": "{color.neutral.1000}", "$type": "color" },

    "text": { "$value": "#0b1a2a", "$type": "color" },
    "text-muted": { "$value": "#4a6a8a", "$type": "color" },
    "text-faint": { "$value": "{color.neutral.600}", "$type": "color" },

    "accent": { "$value": "#14b8a6", "$type": "color" },
    "accent-text": {
      "$value": "#0d9488",
      "$type": "color",
      "$description": "WCAG AA: accent color for text on light backgrounds (4.5:1 contrast)"
    },
    "accent-hover": { "$value": "{color.teal.light-600}", "$type": "color" },
    "accent-subtle": {
      "$value": "{color.teal.light-subtle}",
      "$type": "color"
    },
    "accent-light": { "$value": "#99f6e4", "$type": "color" },
    "accent-strong": { "$value": "{color.teal.light-400}", "$type": "color" },
    "on-accent": { "$value": "#ffffff", "$type": "color" },

    "accent-secondary": { "$value": "{color.amber.600}", "$type": "color" },
    "accent-secondary-text": {
      "$value": "{color.amber.700}",
      "$type": "color",
      "$description": "WCAG AA: amber accent for text on light backgrounds"
    },
    "accent-secondary-hover": {
      "$value": "{color.amber.light-600}",
      "$type": "color"
    },
    "accent-secondary-subtle": {
      "$value": "{color.amber.light-subtle}",
      "$type": "color"
    },
    "accent-secondary-strong": {
      "$value": "{color.amber.light-400}",
      "$type": "color"
    },
    "on-accent-secondary": { "$value": "#ffffff", "$type": "color" },

    "accent-tertiary": { "$value": "{color.indigo.600}", "$type": "color" },
    "accent-tertiary-text": {
      "$value": "{color.indigo.700}",
      "$type": "color",
      "$description": "WCAG AA: indigo accent for text on light backgrounds"
    },
    "accent-tertiary-hover": {
      "$value": "{color.indigo.light-600}",
      "$type": "color"
    },
    "accent-tertiary-subtle": {
      "$value": "{color.indigo.light-subtle}",
      "$type": "color"
    },
    "accent-tertiary-strong": {
      "$value": "{color.indigo.light-400}",
      "$type": "color"
    },
    "on-accent-tertiary": { "$value": "#ffffff", "$type": "color" },

    "border": { "$value": "{color.neutral.700}", "$type": "color" },
    "border-subtle": { "$value": "{color.neutral.850}", "$type": "color" },

    "success": { "$value": "{color.seafoam.light-500}", "$type": "color" },
    "success-dim": { "$value": "{color.seafoam.light-dim}", "$type": "color" },
    "warning": { "$value": "{color.yellow.light-500}", "$type": "color" },
    "warning-dim": { "$value": "{color.yellow.light-dim}", "$type": "color" },
    "error": { "$value": "{color.coral.light-500}", "$type": "color" },
    "error-dim": { "$value": "{color.coral.light-subtle}", "$type": "color" },
    "info": { "$value": "{color.blue.light-500}", "$type": "color" },
    "info-dim": { "$value": "{color.blue.light-dim}", "$type": "color" },

    "focus-ring": { "$value": "{color.teal.light-500}", "$type": "color" },
    "focus-ring-width": { "$value": "2px", "$type": "dimension" },
    "focus-ring-offset": { "$value": "2px", "$type": "dimension" },

    "link": { "$value": "{color.teal.light-500}", "$type": "color" },
    "link-hover": { "$value": "{color.teal.light-600}", "$type": "color" },
    "link-active": { "$value": "{color.teal.light-400}", "$type": "color" },
    "link-visited": { "$value": "{color.teal.light-600}", "$type": "color" },

    "hover-overlay": { "$value": "rgba(0, 0, 0, 0.04)", "$type": "color" },
    "pressed-overlay": { "$value": "rgba(0, 0, 0, 0.08)", "$type": "color" },
    "disabled-overlay": { "$value": "rgba(0, 0, 0, 0.04)", "$type": "color" },
    "backdrop-overlay": {
      "$value": "rgba(0, 0, 0, 0.3)",
      "$type": "color"
    },

    "shadow-xs": {
      "$value": "0 1px 2px rgba(0,30,60,0.08), inset 0 1px 0 rgba(255,255,255,0.5)",
      "$type": "shadow"
    },
    "shadow-sm": {
      "$value": "0 1px 3px rgba(0,30,60,0.1), 0 2px 6px rgba(0,30,60,0.08), inset 0 1px 0 rgba(255,255,255,0.5)",
      "$type": "shadow"
    },
    "shadow-md": {
      "$value": "0 2px 4px rgba(0,30,60,0.08), 0 8px 20px rgba(0,30,60,0.12), inset 0 1px 0 rgba(255,255,255,0.4)",
      "$type": "shadow"
    },
    "shadow-lg": {
      "$value": "0 4px 8px rgba(0,30,60,0.08), 0 16px 40px rgba(0,30,60,0.14), inset 0 1px 0 rgba(255,255,255,0.3)",
      "$type": "shadow"
    },
    "shadow-xl": {
      "$value": "0 8px 16px rgba(0,30,60,0.1), 0 32px 64px rgba(0,30,60,0.16), inset 0 1px 0 rgba(255,255,255,0.2)",
      "$type": "shadow"
    },
    "shadow-card": {
      "$value": "0 1px 3px rgba(0,30,60,0.08), 0 6px 20px rgba(0,30,60,0.1), inset 0 1px 0 rgba(255,255,255,0.5)",
      "$type": "shadow"
    },
    "shadow-glow-accent": {
      "$value": "0 0 0 1px var(--sc-accent-subtle), 0 4px 16px rgba(20,184,166,0.15)",
      "$type": "shadow"
    },
    "shadow-inset": {
      "$value": "inset 0 1px 2px rgba(0,0,0,0.06)",
      "$type": "shadow"
    },
    "surface-gradient": {
      "$value": "linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(240,244,248,0.6) 100%)",
      "$type": "string"
    },
    "surface-glow": {
      "$value": "radial-gradient(ellipse at 50% 0%, rgba(20,184,166,0.08) 0%, transparent 70%)",
      "$type": "string"
    },
    "button-gradient-primary": {
      "$value": "linear-gradient(180deg, rgba(255,255,255,0.25) 0%, rgba(0,0,0,0.1) 100%)",
      "$type": "string"
    },
    "hero-gradient": {
      "$value": "linear-gradient(135deg, rgba(20,184,166,0.12) 0%, rgba(16,185,129,0.06) 50%, transparent 100%)",
      "$type": "string"
    }
  },
  "high-contrast": {
    "$description": "High contrast mode for accessibility",
    "bg": { "$value": "{color.neutral.0}", "$type": "color" },
    "bg-inset": { "$value": "{color.neutral.0}", "$type": "color" },
    "bg-surface": { "$value": "{color.neutral.100}", "$type": "color" },
    "bg-elevated": { "$value": "{color.neutral.150}", "$type": "color" },
    "bg-overlay": { "$value": "{color.neutral.200}", "$type": "color" },

    "text": { "$value": "{color.neutral.1000}", "$type": "color" },
    "text-muted": { "$value": "{color.neutral.700}", "$type": "color" },
    "text-faint": { "$value": "{color.neutral.600}", "$type": "color" },

    "accent": { "$value": "#2dd4bf", "$type": "color" },
    "accent-text": { "$value": "#0f766e", "$type": "color" },
    "accent-hover": { "$value": "#5eead4", "$type": "color" },
    "accent-subtle": { "$value": "rgba(45, 212, 191, 0.2)", "$type": "color" },
    "accent-strong": { "$value": "#14b8a6", "$type": "color" },
    "on-accent": { "$value": "#000000", "$type": "color" },

    "border": { "$value": "{color.neutral.600}", "$type": "color" },
    "border-subtle": { "$value": "{color.neutral.400}", "$type": "color" },

    "success": { "$value": "#34d399", "$type": "color" },
    "success-dim": { "$value": "rgba(52, 211, 153, 0.2)", "$type": "color" },
    "warning": { "$value": "#fde047", "$type": "color" },
    "warning-dim": { "$value": "rgba(253, 224, 71, 0.2)", "$type": "color" },
    "error": { "$value": "#f87171", "$type": "color" },
    "error-dim": { "$value": "rgba(248, 113, 113, 0.2)", "$type": "color" },
    "info": { "$value": "#60a5fa", "$type": "color" },
    "info-dim": { "$value": "rgba(96, 165, 250, 0.2)", "$type": "color" },

    "focus-ring": { "$value": "#ffffff", "$type": "color" },
    "focus-ring-width": { "$value": "3px", "$type": "dimension" },
    "focus-ring-offset": { "$value": "2px", "$type": "dimension" }
  }
