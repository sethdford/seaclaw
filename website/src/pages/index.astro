    <script>
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      // Show all elements immediately for reduced motion
      if (prefersReducedMotion) {
        document
          .querySelectorAll("[data-reveal], .hu-chapter-reveal")
          .forEach((el) => {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
            (el as HTMLElement).style.transitionDuration = "0s";
          });
        document.querySelectorAll(".opacity-0").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
        });

        const outputEl = document.getElementById("terminal-output");
        if (outputEl) {
          outputEl.innerHTML = [
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-text)">git clone https://github.com/sethdford/h-uman.git</span></div>',
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-text)">cd h-uman && mkdir -p build && cd build</span></div>',
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-text)">cmake .. -DCMAKE_BUILD_TYPE=MinSizeRel -DHU_ENABLE_LTO=ON && cmake --build .</span></div>',
            '<div><span style="color:var(--hu-text-muted)">[100%] Built target human</span></div>',
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-text)">ls -lh human</span></div>',
            '<div><span style="color:var(--hu-text-muted)">-rwxr-xr-x  1 user  staff  </span><span style="color:var(--color-accent)">1750K</span><span style="color:var(--hu-text-muted)">  human</span></div>',
          ].join("");
        }

        document.querySelectorAll("[data-count]").forEach((el) => {
          const target = parseInt((el as HTMLElement).dataset.count || "0");
          const valSpan = el.querySelector(".count-value");
          if (valSpan)
            valSpan.textContent =
              target > 100 ? target.toLocaleString() : target.toString();
        });
        document.querySelectorAll(".dash-count").forEach((el) => {
          el.textContent = (el as HTMLElement).dataset.target || "0";
        });
        // Generate crystal grid for reduced motion
        const rmCrystalGrid = document.getElementById("crystalGrid");
        if (rmCrystalGrid) {
          const rmModules = [
            { name: "core", core: true },
            { name: "json", core: true },
            { name: "http", core: true },
            { name: "str", core: true },
            { name: "arena", core: true },
            { name: "err", core: true },
            { name: "agent" },
            { name: "ctx" },
            { name: "plan" },
            { name: "disp" },
            { name: "comp" },
            { name: "turn" },
            { name: "prov" },
            { name: "chan" },
            { name: "tool" },
            { name: "mem" },
            { name: "sec" },
            { name: "run" },
            { name: "sse" },
            { name: "ws" },
            { name: "log" },
            { name: "cfg" },
            { name: "gw" },
            { name: "cli" },
            { name: "pers" },
            { name: "emb" },
            { name: "sql" },
            { name: "lru" },
            { name: "vec" },
            { name: "obs" },
            {},
            {},
            {},
            {},
            {},
            {},
          ];
          rmModules.forEach((m) => {
            const cell = document.createElement("div");
            cell.className =
              "crystal-cell on" + (m.core ? " core" : m.name ? " filled" : "");
            cell.textContent = m.name || "";
            rmCrystalGrid.appendChild(cell);
          });
        }
        document.querySelectorAll(".crystal-cell").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
          (el as HTMLElement).style.transform = "none";
        });
        document
          .querySelectorAll(".ring-fg")
          .forEach((r) => r.classList.add("on"));
        document
          .querySelectorAll(".dep-tree-svg [data-delay]")
          .forEach((el) => el.classList.add("on"));
        document
          .querySelectorAll(".spectrum-dot")
          .forEach((d) => d.classList.add("on"));
        const dl = document.getElementById("deviceLine");
        if (dl) dl.classList.add("on");
      } else {
        // ═══ Intersection Observer reveal system ═══
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -50px 0px" },
        );
        document
          .querySelectorAll("[data-reveal], .glass-enter, .hu-chapter-reveal")
          .forEach((el) => {
            revealObserver.observe(el);
          });

        // ═══ Nav glass toggle via scroll ═══
        const nav = document.getElementById("site-nav");
        if (nav) {
          const onScroll = () => {
            if (window.scrollY > 80) {
              nav.classList.add("glass-nav");
            } else {
              nav.classList.remove("glass-nav");
            }
          };
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }

        function scheduleDeferredHome(): void {
          const load = (): void => {
            void import("../scripts/home-deferred").then((m) =>
              m.initHomeDeferred(),
            );
          };
          const ric = (
            window as unknown as {
              requestIdleCallback?: (
                cb: () => void,
                opts?: { timeout: number },
              ) => number;
            }
          ).requestIdleCallback;
          const runIdle = (): void => {
            if (typeof ric === "function") ric(load, { timeout: 4000 });
            else setTimeout(load, 0);
          };
          if (document.documentElement.classList.contains("hu-lcp-done")) {
            runIdle();
            return;
          }
          let fired = false;
          const once = (): void => {
            if (fired) return;
            fired = true;
            mo.disconnect();
            clearTimeout(tid);
            runIdle();
          };
          const mo = new MutationObserver(() => {
            if (document.documentElement.classList.contains("hu-lcp-done"))
              once();
          });
          mo.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
          });
          const tid = window.setTimeout(once, 2800);
        }
        scheduleDeferredHome();
      }
