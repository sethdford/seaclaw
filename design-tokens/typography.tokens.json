{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "com.human.platform": "all",
    "com.human.version": "0.5.0"
  },
  "$description": "Typography tokens — font families, sizes, weights, line-heights, letter-spacing, and type roles",
  "fontFamily": {
    "sans": {
      "$value": "'Avenir', 'Avenir Next', 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "$type": "fontFamily",
      "$description": "Avenir (macOS local), Inter (cross-platform web fallback with similar metrics), then system"
    },
    "mono": {
      "$value": "'Geist Mono', ui-monospace, 'SF Mono', monospace",
      "$type": "fontFamily"
    }
  },
  "fontSize": {
    "2xs": {
      "$value": "0.6875rem",
      "$type": "dimension",
      "$description": "11px — smallest readable size, used for badges and secondary metadata"
    },
    "xs": {
      "$value": "0.75rem",
      "$type": "dimension",
      "$description": "12px — captions, timestamps"
    },
    "sm": {
      "$value": "0.875rem",
      "$type": "dimension",
      "$description": "14px — secondary text, labels"
    },
    "base": {
      "$value": "1rem",
      "$type": "dimension",
      "$description": "16px — body text (matches Claude, Apple, ChatGPT)"
    },
    "lg": {
      "$value": "clamp(1.125rem, 1.5vw, 1.25rem)",
      "$type": "dimension",
      "$description": "Fluid 18-20px — large body, emphasized text"
    },
    "xl": {
      "$value": "clamp(1.375rem, 2vw, 1.625rem)",
      "$type": "dimension",
      "$description": "Fluid 22-26px — section headers"
    },
    "2xl": {
      "$value": "clamp(1.5rem, 3vw, 2rem)",
      "$type": "dimension",
      "$description": "Fluid 24-32px — page headers"
    },
    "3xl": {
      "$value": "clamp(1.75rem, 4vw, 2.5rem)",
      "$type": "dimension",
      "$description": "Fluid 28-40px — display text"
    },
    "hero": {
      "$value": "clamp(2rem, 5vw, 3.5rem)",
      "$type": "dimension",
      "$description": "Fluid 32-56px — hero headlines"
    }
  },
  "fontWeight": {
    "light": {
      "$value": 300,
      "$type": "number",
      "$description": "Avenir Light"
    },
    "normal": {
      "$value": 400,
      "$type": "number",
      "$description": "Avenir Book"
    },
    "medium": {
      "$value": 500,
      "$type": "number",
      "$description": "Avenir Medium"
    },
    "semibold": {
      "$value": 600,
      "$type": "number",
      "$description": "Avenir Medium (aliased)"
    },
    "bold": {
      "$value": 700,
      "$type": "number",
      "$description": "Avenir Heavy"
    },
    "black": {
      "$value": 900,
      "$type": "number",
      "$description": "Avenir Black"
    }
  },
  "lineHeight": {
    "none": {
      "$value": 1,
      "$type": "number"
    },
    "tight": {
      "$value": 1.25,
      "$type": "number"
    },
    "snug": {
      "$value": 1.375,
      "$type": "number"
    },
    "normal": {
      "$value": 1.5,
      "$type": "number"
    },
    "relaxed": {
      "$value": 1.75,
      "$type": "number"
    }
  },
  "letterSpacing": {
    "$description": "Optical size compensation — tighter tracking at larger sizes",
    "2xs": {
      "$value": "0.03em",
      "$type": "dimension"
    },
    "xs": {
      "$value": "0.02em",
      "$type": "dimension"
    },
    "sm": {
      "$value": "0.01em",
      "$type": "dimension"
    },
    "base": {
      "$value": "0em",
      "$type": "dimension"
    },
    "lg": {
      "$value": "0em",
      "$type": "dimension"
    },
    "xl": {
      "$value": "-0.01em",
      "$type": "dimension"
    },
    "2xl": {
      "$value": "-0.02em",
      "$type": "dimension"
    },
    "hero": {
      "$value": "-0.04em",
      "$type": "dimension"
    }
  },
  "typeRole": {
    "$description": "Named type roles — paired size, weight, lineHeight, and tracking",
    "display-lg": {
      "fontSize": {
        "$value": "{fontSize.hero}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.black}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.tight}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.hero}",
        "$type": "dimension"
      }
    },
    "display-md": {
      "fontSize": {
        "$value": "{fontSize.3xl}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.bold}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.tight}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.2xl}",
        "$type": "dimension"
      }
    },
    "headline-lg": {
      "fontSize": {
        "$value": "{fontSize.2xl}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.bold}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.snug}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.2xl}",
        "$type": "dimension"
      }
    },
    "headline-md": {
      "fontSize": {
        "$value": "{fontSize.xl}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.semibold}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.snug}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.xl}",
        "$type": "dimension"
      }
    },
    "headline-sm": {
      "fontSize": {
        "$value": "{fontSize.lg}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.semibold}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.snug}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.lg}",
        "$type": "dimension"
      }
