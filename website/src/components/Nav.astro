---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all"
  style="transition-duration: var(--hu-duration-moderate); view-transition-name: nav-bar"
  aria-label="Main navigation"
>
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between" style="min-height: 56px; max-height: 56px">
    <a href={`${base}`} class="flex items-center gap-3 group">
      <img
        src={`${base}human.svg`}
        alt="h-uman logo"
        width="28"
        height="28"
        class="w-7 h-7 transition-transform group-hover:scale-110"
        style="transition-duration: var(--hu-duration-moderate); view-transition-name: site-logo"
        loading="lazy"
        decoding="async"
      />
      <span
        class="text-[15px] font-semibold tracking-tight"
        style="color: var(--hu-web-text)">h-uman</span
      >
    </a>
    <div class="flex items-center gap-8">
      <div class="hidden md:flex items-center gap-6">
        <a href="#use-cases" class="nav-link text-[13px] transition-colors"
          >Use Cases</a
        >
        <a href="#architecture" class="nav-link text-[13px] transition-colors"
          >Architecture</a
        >
        <a
          href={`${base}brand/`}
          class="nav-link text-[13px] transition-colors">Brand</a
        >
        <a
          href={`${base}design/`}
          class="nav-link text-[13px] transition-colors">Design</a
        >
        <a
          href={`${base}getting-started/installation/`}
          class="nav-link text-[13px] transition-colors">Docs</a
        >
      </div>
      <a
        href="https://github.com/sethdford/h-uman"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link transition-colors"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 256 256"
          ><path
            d="M208.31,75.68A59.78,59.78,0,0,0,202.93,28,8,8,0,0,0,196,24a59.75,59.75,0,0,0-48,24H124A59.75,59.75,0,0,0,76,24a8,8,0,0,0-6.93,4,59.78,59.78,0,0,0-5.38,47.68A58.14,58.14,0,0,0,56,104v8a56.06,56.06,0,0,0,48.44,55.47A39.8,39.8,0,0,0,96,192v8H72a24,24,0,0,1-24-24A40,40,0,0,0,8,136a8,8,0,0,0,0,16,24,24,0,0,1,24,24,40,40,0,0,0,40,40H96v16a8,8,0,0,0,16,0V192a24,24,0,0,1,48,0v40a8,8,0,0,0,16,0V192a39.8,39.8,0,0,0-8.42-24.53A56.06,56.06,0,0,0,216,112v-8A58.14,58.14,0,0,0,208.31,75.68ZM200,112a40,40,0,0,1-40,40H112a40,40,0,0,1-40-40v-8a41.74,41.74,0,0,1,6.9-22.48A8,8,0,0,0,80,73.55a43.81,43.81,0,0,1,.79-23.87,43.83,43.83,0,0,1,32.32,20.06A8,8,0,0,0,119.82,72h32.35a8,8,0,0,0,6.74-3.69,43.83,43.83,0,0,1,32.32-20.06A43.81,43.81,0,0,1,192,72.05a8,8,0,0,0,1.14,7.7A41.74,41.74,0,0,1,200,104Z"
          ></path></svg
        >
      </a>
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden flex items-center justify-center w-8 h-8 nav-link"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        popovertarget="mobile-menu"
      >
        <svg
          class="hamburger-icon w-5 h-5"
          fill="currentColor"
          viewBox="0 0 256 256"
          ><path
            d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"
          ></path></svg
        >
        <svg
          class="close-icon w-5 h-5 hidden"
          fill="currentColor"
          viewBox="0 0 256 256"
          ><path
            d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"
          ></path></svg
        >
      </button>
    </div>
  </div>
  <div
    id="mobile-menu"
    class="mobile-menu-popover md:hidden"
    popover="auto"
    style="background: var(--hu-web-surface-elevated); backdrop-filter: blur(24px) saturate(1.8); -webkit-backdrop-filter: blur(24px) saturate(1.8); border-bottom: 1px solid var(--hu-web-border);"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
      <a
        href="#use-cases"
        class="mobile-menu-link text-[15px] py-2 transition-colors"
        style="color: var(--hu-web-text-secondary)">Use Cases</a
      >
      <a
        href="#architecture"
        class="mobile-menu-link text-[15px] py-2 transition-colors"
        style="color: var(--hu-web-text-secondary)">Architecture</a
      >
      <a
        href={`${base}brand/`}
        class="mobile-menu-link text-[15px] py-2 transition-colors"
        style="color: var(--hu-web-text-secondary)">Brand</a
      >
      <a
        href={`${base}design/`}
        class="mobile-menu-link text-[15px] py-2 transition-colors"
        style="color: var(--hu-web-text-secondary)">Design</a
      >
      <a
        href={`${base}getting-started/installation/`}
        class="mobile-menu-link text-[15px] py-2 transition-colors"
        style="color: var(--hu-web-text-secondary)">Docs</a
      >
    </div>
  </div>
</nav>

<style>
  .nav-link {
    color: var(--hu-web-text-secondary);
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--hu-web-text);
  }
  .mobile-menu-popover {
    position: fixed;
    top: 56px;
    left: 0;
    right: 0;
    margin: 0;
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburger = btn?.querySelector(".hamburger-icon");
  const closeIcon = btn?.querySelector(".close-icon");

  const supportsPopover = "showPopover" in document.createElement("div");

  function setExpanded(open: boolean) {
    btn?.setAttribute("aria-expanded", String(open));
    btn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    hamburger?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  }

  if (supportsPopover && menu) {
    menu.addEventListener("toggle", () => {
      setExpanded(menu.matches(":popover-open"));
    });
    menu.querySelectorAll(".mobile-menu-link").forEach((link) => {
      link.addEventListener("click", () => menu.hidePopover());
    });
  } else {
    if (menu) menu.classList.add("hidden");
    btn?.addEventListener("click", () => {
      const open = menu?.classList.toggle("hidden") === false;
      setExpanded(open);
    });
    menu?.querySelectorAll(".mobile-menu-link").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        setExpanded(false);
      });
    });
  }
</script>
