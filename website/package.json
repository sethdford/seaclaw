{
  "name": "website",
  "type": "module",
  "version": "0.5.0",
  "scripts": {
    "check": "astro check",
    "predev": "node scripts/generate-assets.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "(cd ../design-tokens && npm run build) || echo 'WARN: design-tokens build failed, using cached output' && cd ../website && node scripts/generate-assets.mjs",
    "build": "astro build",
    "generate-assets": "node scripts/generate-assets.mjs",
    "preview": "astro preview",
    "lint": "astro check",
    "format": "prettier --write 'src/**/*.{astro,ts,css,mdx,md}'",
    "format:check": "prettier --check 'src/**/*.{astro,ts,css,mdx,md}'",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.38.2",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.4",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "~5.9.3"
  }
}
