        "$value": "{fontSize.lg}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.semibold}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.snug}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.lg}",
