{
  "ci": {
    "collect": {
      "staticDistDir": "website/dist",
      "numberOfRuns": 5
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.98 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 1500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.05 }],
        "interactive": ["warn", { "maxNumericValue": 2000 }]
      },
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*/404\\.html$",
          "assertions": {
            "categories:seo": ["warn", { "minScore": 0.5 }]
          }
        }
      ]
    }
  }
}
