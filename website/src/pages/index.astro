---
// Standalone landing page — no Starlight layout
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SeaClaw — Null overhead. Null compromise. 100% C.</title>
    <meta name="description" content="239 KB binary. Less than 5 MB RAM. Boots in 2ms. AI assistant runtime in C11. Zero dependencies. Runs on anything." />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased selection:bg-red-600/40 selection:text-white">
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex flex-col items-center justify-center px-4 py-20 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(204,0,0,0.12),transparent)]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_120%,rgba(139,0,0,0.08),transparent)]" />
      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <img
          src={`${base}seaclaw.svg`}
          alt="SeaClaw"
          class="w-20 h-20 md:w-24 md:h-24 mx-auto mb-6 drop-shadow-[0_0_12px_rgba(204,0,0,0.4)] transition-transform duration-300 hover:scale-110"
        />
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-4">
          SeaClaw
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 font-medium mb-2">
          Null overhead. Null compromise. 100% C. 100% Agnostic.
        </p>
        <p class="text-base md:text-lg text-slate-400 mb-10">
          239 KB binary. &lt; 5 MB RAM. Boots in 2ms. Runs on anything with a CPU.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={`${base}getting-started/installation/`}
            class="inline-flex items-center justify-center px-8 py-3 rounded-lg font-semibold bg-red-600 hover:bg-red-500 text-white transition-all duration-200 hover:shadow-lg hover:shadow-red-900/30 hover:-translate-y-0.5"
          >
            Get Started
          </a>
          <a
            href="https://github.com/sethdford/seaclaw"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3 rounded-lg font-semibold bg-slate-800 hover:bg-slate-700 text-slate-200 border border-slate-600/50 transition-all duration-200 hover:border-red-500/30 hover:-translate-y-0.5"
          >
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="py-16 px-4 border-y border-slate-800/60 bg-slate-900/50">
      <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-500">239 KB</div>
          <div class="text-sm text-slate-400 mt-1">Binary Size</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-500">1,791</div>
          <div class="text-sm text-slate-400 mt-1">Tests</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-500">50+</div>
          <div class="text-sm text-slate-400 mt-1">Providers</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-500">20</div>
          <div class="text-sm text-slate-400 mt-1">Channels</div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-24 px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-16">
          Built for the edge. Built to last.
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <article class="group p-6 rounded-xl bg-slate-900/80 border border-slate-800/60 hover:border-red-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-red-900/5 hover:-translate-y-1">
            <h3 class="text-lg font-semibold text-red-500 mb-2">Impossibly Small</h3>
            <p class="text-slate-400">239 KB static binary. No runtime, no VM, no framework.</p>
          </article>
          <article class="group p-6 rounded-xl bg-slate-900/80 border border-slate-800/60 hover:border-red-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-red-900/5 hover:-translate-y-1">
            <h3 class="text-lg font-semibold text-red-500 mb-2">Instant Startup</h3>
            <p class="text-slate-400">&lt;2 ms on Apple Silicon, &lt;8 ms on 0.8 GHz edge hardware.</p>
          </article>
          <article class="group p-6 rounded-xl bg-slate-900/80 border border-slate-800/60 hover:border-red-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-red-900/5 hover:-translate-y-1">
            <h3 class="text-lg font-semibold text-red-500 mb-2">True Portability</h3>
            <p class="text-slate-400">One binary across ARM, x86, RISC-V. Drop it anywhere.</p>
          </article>
          <article class="group p-6 rounded-xl bg-slate-900/80 border border-slate-800/60 hover:border-red-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-red-900/5 hover:-translate-y-1">
            <h3 class="text-lg font-semibold text-red-500 mb-2">Secure by Default</h3>
            <p class="text-slate-400">Pairing, sandboxing, encrypted secrets, workspace scoping.</p>
          </article>
          <article class="group p-6 rounded-xl bg-slate-900/80 border border-slate-800/60 hover:border-red-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-red-900/5 hover:-translate-y-1">
            <h3 class="text-lg font-semibold text-red-500 mb-2">Fully Swappable</h3>
            <p class="text-slate-400">Every subsystem is a vtable interface. Swap anything via config.</p>
          </article>
          <article class="group p-6 rounded-xl bg-slate-900/80 border border-slate-800/60 hover:border-red-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-red-900/5 hover:-translate-y-1">
            <h3 class="text-lg font-semibold text-red-500 mb-2">Local LLM Ready</h3>
            <p class="text-slate-400">llama.cpp, Ollama, LM Studio, vLLM — run fully offline.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Benchmark Section -->
    <section id="benchmark" class="py-24 px-4 bg-slate-900/30">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-12">
          The numbers don't lie
        </h2>
        <div class="overflow-x-auto rounded-xl border border-slate-700/60">
          <table class="w-full text-sm md:text-base">
            <thead>
              <tr class="border-b border-slate-700">
                <th class="text-left py-4 px-4 font-semibold text-slate-300 bg-slate-800/50"></th>
                <th class="py-4 px-4 font-semibold text-slate-400">OpenClaw</th>
                <th class="py-4 px-4 font-semibold text-slate-400">NanoBot</th>
                <th class="py-4 px-4 font-semibold text-slate-400">PicoClaw</th>
                <th class="py-4 px-4 font-semibold text-slate-400">ZeroClaw</th>
                <th class="py-4 px-4 font-semibold text-red-500 bg-red-500/5">SeaClaw</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-700/50">
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="py-4 px-4 font-medium text-slate-300">Language</td>
                <td class="py-4 px-4 text-slate-400">TypeScript</td>
                <td class="py-4 px-4 text-slate-400">Python</td>
                <td class="py-4 px-4 text-slate-400">Go</td>
                <td class="py-4 px-4 text-slate-400">Rust</td>
                <td class="py-4 px-4 font-bold text-red-500 bg-red-500/5">C</td>
              </tr>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="py-4 px-4 font-medium text-slate-300">RAM</td>
                <td class="py-4 px-4 text-slate-400">&gt;1 GB</td>
                <td class="py-4 px-4 text-slate-400">&gt;100 MB</td>
                <td class="py-4 px-4 text-slate-400">&lt;10 MB</td>
                <td class="py-4 px-4 text-slate-400">&lt;5 MB</td>
                <td class="py-4 px-4 font-bold text-red-500 bg-red-500/5">&lt;5 MB</td>
              </tr>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="py-4 px-4 font-medium text-slate-300">Startup (0.8 GHz)</td>
                <td class="py-4 px-4 text-slate-400">&gt;500s</td>
                <td class="py-4 px-4 text-slate-400">&gt;30s</td>
                <td class="py-4 px-4 text-slate-400">&lt;1s</td>
                <td class="py-4 px-4 text-slate-400">&lt;10ms</td>
                <td class="py-4 px-4 font-bold text-red-500 bg-red-500/5">&lt;8ms</td>
              </tr>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="py-4 px-4 font-medium text-slate-300">Binary Size</td>
                <td class="py-4 px-4 text-slate-400">~28 MB</td>
                <td class="py-4 px-4 text-slate-400">N/A</td>
                <td class="py-4 px-4 text-slate-400">~8 MB</td>
                <td class="py-4 px-4 text-slate-400">3.4 MB</td>
                <td class="py-4 px-4 font-bold text-red-500 bg-red-500/5">239 KB</td>
              </tr>
              <tr class="hover:bg-slate-800/30 transition-colors">
                <td class="py-4 px-4 font-medium text-slate-300">Tests</td>
                <td class="py-4 px-4 text-slate-400">—</td>
                <td class="py-4 px-4 text-slate-400">—</td>
                <td class="py-4 px-4 text-slate-400">—</td>
                <td class="py-4 px-4 text-slate-400">1,017</td>
                <td class="py-4 px-4 font-bold text-red-500 bg-red-500/5">1,791</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Architecture Section -->
    <section id="architecture" class="py-24 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-6">
          Vtable-driven. Modular. Swappable.
        </h2>
        <p class="text-center text-slate-400 mb-12 max-w-2xl mx-auto">
          Every subsystem implements a clear interface. Swap providers, channels, memory backends, tools, or runtimes via config — no recompile.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Providers</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Channels</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Memory</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Tools</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Security</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Runtime</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Tunnels</div>
          <div class="py-3 px-4 rounded-lg bg-slate-800/60 border border-slate-700/50 text-center font-medium text-slate-200 hover:border-red-500/40 transition-colors">Peripherals</div>
        </div>
      </div>
    </section>

    <!-- Quick Start Section -->
    <section id="quick-start" class="py-24 px-4 bg-slate-900/30">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-6">
          Quick Start
        </h2>
        <p class="text-center text-slate-400 mb-8">
          Clone, build, onboard, run. No containers. No interpreters.
        </p>
        <div class="rounded-xl overflow-hidden border border-slate-700/60 bg-slate-950">
          <div class="flex items-center gap-2 px-4 py-2 bg-slate-800/80 border-b border-slate-700/60">
            <span class="w-3 h-3 rounded-full bg-red-500/80" />
            <span class="w-3 h-3 rounded-full bg-amber-500/60" />
            <span class="w-3 h-3 rounded-full bg-emerald-500/60" />
            <span class="text-xs text-slate-500 ml-2">terminal</span>
          </div>
          <pre class="p-6 overflow-x-auto text-sm md:text-base text-slate-300 font-mono leading-relaxed"><code>git clone https://github.com/sethdford/seaclaw.git
cd seaclaw && mkdir -p build && cd build
cmake .. -DCMAKE_BUILD_TYPE=MinSizeRel -DSC_ENABLE_LTO=ON
cmake --build .
./seaclaw onboard --interactive
./seaclaw agent</code></pre>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 px-4 border-t border-slate-800/60">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-slate-400 text-sm md:text-base mb-4">
          SeaClaw — Zero overhead. Zero compromise. Deploy anywhere. Swap anything.
        </p>
        <p class="text-slate-500 text-xs mb-4">MIT License</p>
        <a
          href="https://github.com/sethdford/seaclaw"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-slate-400 hover:text-red-500 transition-colors text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
