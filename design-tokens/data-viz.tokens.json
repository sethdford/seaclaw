{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "com.human.platform": "all",
    "com.human.version": "0.5.0"
  },
  "$description": "Data visualization tokens — chart colors, series palettes, and visualization spacing",
  "chart": {
    "categorical": {
      "1": {
        "$value": "{color.human.500}",
        "$type": "color",
        "$description": "Primary — Human green"
      },
      "2": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Secondary — Steel blue"
      },
      "3": {
        "$value": "{color.amber.500}",
        "$type": "color",
        "$description": "Tertiary — Amber"
      },
      "4": {
        "$value": "{color.coral.500}",
        "$type": "color",
        "$description": "Quaternary — Coral"
      },
      "5": {
        "$value": "{color.teal.500}",
        "$type": "color",
        "$description": "Quinary — Teal"
      },
      "6": {
        "$value": "{color.blue.300}",
        "$type": "color",
        "$description": "Light steel blue"
      },
      "7": {
        "$value": "{color.amber.300}",
        "$type": "color",
        "$description": "Light amber"
      },
      "8": {
        "$value": "{color.human.300}",
        "$type": "color",
        "$description": "Light green"
      },
      "9": {
        "$value": "{color.viz-extended.forest}",
        "$type": "color",
        "$description": "Extended — deep forest"
      },
      "10": {
        "$value": "{color.viz-extended.cyan}",
        "$type": "color",
        "$description": "Extended — bright cyan"
      },
      "11": {
        "$value": "{color.viz-extended.violet}",
        "$type": "color",
        "$description": "Extended — violet"
      },
      "12": {
        "$value": "{color.viz-extended.chartreuse}",
        "$type": "color",
        "$description": "Extended — chartreuse"
      },
      "13": {
        "$value": "{color.viz-extended.gold}",
        "$type": "color",
        "$description": "Extended — gold yellow"
      },
      "14": {
        "$value": "{color.viz-extended.orange}",
        "$type": "color",
        "$description": "Extended — vivid orange"
      },
      "15": {
        "$value": "{color.viz-extended.crimson}",
        "$type": "color",
        "$description": "Extended — crimson (series only)"
      },
      "16": {
        "$value": "{color.viz-extended.azure}",
        "$type": "color",
        "$description": "Extended — azure blue"
      },
      "$description": "Ordered categorical series — 16 colors: core 1–8 plus viz-extended for dense charts"
    },
    "sequential": {
      "100": {
        "$value": "{color.human.100}",
        "$type": "color"
      },
      "200": {
        "$value": "{color.human.200}",
        "$type": "color"
      },
      "300": {
        "$value": "{color.human.300}",
        "$type": "color"
      },
      "400": {
        "$value": "{color.human.400}",
        "$type": "color"
      },
      "500": {
        "$value": "{color.human.500}",
        "$type": "color"
      },
      "600": {
        "$value": "{color.human.600}",
        "$type": "color"
      },
      "700": {
        "$value": "{color.human.700}",
        "$type": "color"
      },
      "800": {
        "$value": "{color.human.800}",
        "$type": "color"
      },
      "$description": "Sequential ramp — single hue from light to dark for ordered data"
    },
    "diverging": {
      "$description": "Diverging palette — positive to negative via neutral midpoint",
      "positive": {
        "$value": "{color.human.500}",
        "$type": "color"
      },
      "neutral": {
        "$value": "{color.neutral.500}",
        "$type": "color"
      },
      "negative": {
        "$value": "{color.coral.500}",
        "$type": "color"
      }
    },
    "status": {
      "$description": "Semantic status colors for chart elements",
      "success": {
        "$value": "{color.human.500}",
        "$type": "color"
      },
      "warning": {
        "$value": "{color.amber.500}",
        "$type": "color"
      },
      "error": {
        "$value": "{color.coral.500}",
        "$type": "color"
      },
      "info": {
        "$value": "{color.blue.500}",
        "$type": "color"
      },
      "muted": {
        "$value": "{color.neutral.500}",
        "$type": "color"
      }
    },
    "brand": {
      "$value": "{color.human.500}",
      "$type": "color",
      "$description": "Default single-color chart fill"
    }
  },
  "spacing": {
    "$description": "Chart-specific spacing tokens",
    "bar-gap": {
      "$value": "4px",
      "$type": "dimension"
    },
    "bar-radius": {
      "$value": "3px",
      "$type": "dimension"
    },
    "axis-padding": {
      "$value": "8px",
      "$type": "dimension"
    },
    "legend-gap": {
      "$value": "12px",
      "$type": "dimension"
    },
    "tooltip-padding": {
      "$value": "8px 12px",
      "$type": "dimension"
    }
  }
}
