{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "com.human.platform": "all",
    "com.human.version": "0.5.0"
  },
  "$description": "Responsive breakpoint tokens",
  "breakpoint": {
    "sm": {
      "$value": "480px",
      "$type": "dimension",
      "$description": "Small — compact mobile"
    },
    "md": {
      "$value": "640px",
      "$type": "dimension",
      "$description": "Medium — mobile landscape"
    },
    "lg": {
      "$value": "768px",
      "$type": "dimension",
      "$description": "Large — tablets"
    },
    "xl": {
      "$value": "1024px",
      "$type": "dimension",
      "$description": "Extra-large — desktop"
    },
    "2xl": {
      "$value": "1536px",
      "$type": "dimension",
      "$description": "2x extra-large — ultrawide"
    }
  }
}
