{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$extensions": {
    "com.human.platform": "all",
    "com.human.version": "0.5.0"
  },
  "$description": "Liquid Glass tokens — three tiers of glass depth inspired by Apple visionOS Liquid Glass, adapted for web/native",
  "glass": {
    "subtle": {
      "blur": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Lightest frosted glass"
      },
      "saturate": {
        "$value": "120%",
        "$type": "string",
        "$description": "Low saturation boost"
      },
      "bg-opacity": {
        "$value": 0.04,
        "$type": "number",
        "$description": "Nearly transparent"
      },
      "border-opacity": {
        "$value": 0.05,
        "$type": "number",
        "$description": "Barely visible border"
      },
      "inset-opacity": {
        "$value": 0,
        "$type": "number",
        "$description": "No inset highlight"
      },
      "tint-opacity": {
        "$value": 0.02,
        "$type": "number",
        "$description": "Minimal environment tint"
      },
      "refraction-scale": {
        "$value": 0,
        "$type": "number",
        "$description": "No refraction at subtle tier"
      },
      "$description": "Backgrounds, nav chrome, ambient panels — z.raised (100)"
    },
    "standard": {
      "blur": {
        "$value": "24px",
        "$type": "dimension",
        "$description": "Standard frosted glass"
      },
      "saturate": {
        "$value": "180%",
        "$type": "string",
        "$description": "Moderate saturation boost"
      },
      "bg-opacity": {
        "$value": 0.06,
        "$type": "number",
        "$description": "Slightly visible"
      },
      "border-opacity": {
        "$value": 0.08,
        "$type": "number",
        "$description": "Subtle border"
      },
      "inset-opacity": {
        "$value": 0.06,
        "$type": "number",
        "$description": "Subtle top highlight"
      },
      "tint-opacity": {
        "$value": 0.04,
        "$type": "number",
        "$description": "Subtle environment tint"
      },
      "refraction-scale": {
        "$value": 2,
        "$type": "number",
        "$description": "Light refraction distortion"
      },
      "$description": "Cards, panels, interactive surfaces — z.dropdown (1000)"
    },
    "prominent": {
      "blur": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Heavy frosted glass with refraction"
      },
      "saturate": {
        "$value": "200%",
        "$type": "string",
        "$description": "Strong saturation boost"
      },
      "bg-opacity": {
        "$value": 0.08,
        "$type": "number",
        "$description": "More visible"
      },
      "border-opacity": {
        "$value": 0.12,
        "$type": "number",
        "$description": "Visible chromatic border"
      },
      "inset-opacity": {
        "$value": 0.1,
        "$type": "number",
        "$description": "Strong top highlight"
      },
      "tint-opacity": {
        "$value": 0.06,
        "$type": "number",
        "$description": "Noticeable environment tint"
      },
      "refraction-scale": {
        "$value": 3,
        "$type": "number",
        "$description": "Visible refraction distortion"
      },
      "$description": "Modals, sheets, hero elements, overlays — z.modal (1300)"
    },
    "chat": {
      "$description": "Chat-specific glass — blue-tinted for sessions panel and message actions",
      "blur": {
        "$value": "24px",
        "$type": "dimension"
      },
      "saturate": {
        "$value": "180%",
        "$type": "string"
      },
      "bg-opacity": {
        "$value": 0.85,
        "$type": "number",
        "$description": "Higher opacity for readability"
      },
      "border-opacity": {
        "$value": 0.08,
        "$type": "number"
      },
      "actions-bg-opacity": {
        "$value": 0.9,
        "$type": "number",
        "$description": "Message actions toolbar"
      },
      "actions-blur": {
        "$value": "16px",
        "$type": "dimension"
      }
    },
    "border-color": {
      "$value": "rgba(255, 255, 255, 0.08)",
      "$type": "color",
      "$description": "Default glass surface border color — emitted as --hu-glass-border-color"
    }
  },
  "dynamic-light": {
    "$description": "Light source simulation for glass surfaces — cursor/gyroscope-driven",
    "angle": {
      "$value": "225deg",
      "$type": "string",
      "$description": "Default light source angle (top-left)"
    },
    "intensity": {
      "$value": 0.15,
      "$type": "number",
      "$description": "Specular highlight base intensity"
    },
    "spread": {
      "$value": "60%",
      "$type": "string",
      "$description": "Specular highlight spread radius"
    },
    "color-dark": {
      "$value": "rgba(255,255,255,0.12)",
      "$type": "color",
      "$description": "Specular highlight color (dark theme)"
    },
    "color-light": {
      "$value": "rgba(255,255,255,0.18)",
      "$type": "color",
      "$description": "Specular highlight color (light theme)"
    },
    "ambient": {
      "$value": 0.04,
      "$type": "number",
      "$description": "Ambient light floor — minimum specular even without interaction"
    }
  },
  "vibrancy": {
    "$description": "Auto-contrast enhancement for content on glass surfaces",
    "text-boost": {
      "$value": 1.15,
      "$type": "number",
      "$description": "Text contrast multiplier on glass"
    },
    "icon-boost": {
      "$value": 1.2,
      "$type": "number",
      "$description": "Icon contrast multiplier on glass"
    },
    "backdrop-brightness": {
      "$value": 1.08,
      "$type": "number",
      "$description": "Brightness boost in backdrop-filter"
    },
    "text-shadow": {
      "$value": "0 0 8px rgba(0,0,0,0.5)",
      "$type": "string",
      "$description": "Subtle text shadow for legibility on glass"
    }
  },
  "interactive": {
    "$description": "Glass-specific interaction feedback — complements micro-physics",
    "press-blur-delta": {
      "$value": "-4px",
      "$type": "string",
      "$description": "Blur decreases on press (glass compresses)"
    },
    "press-scale": {
      "$value": 0.98,
      "$type": "number",
      "$description": "Scale factor on press"
    },
    "press-saturate-boost": {
      "$value": "20%",
      "$type": "string",
      "$description": "Saturation increase on press"
    },
    "hover-specular-boost": {
      "$value": 1.4,
      "$type": "number",
      "$description": "Specular intensity multiplier on hover"
    },
    "hover-border-glow": {
      "$value": "0 0 0 1px rgba(255,255,255,0.08)",
      "$type": "string",
      "$description": "Border glow on hover"
    },
    "focus-glow-spread": {
      "$value": "8px",
      "$type": "string",
      "$description": "Fidelity green glow spread on focus"
    },
    "focus-glow-color": {
      "$value": "rgba(122,182,72,0.35)",
      "$type": "color",
      "$description": "Focus glow color (Fidelity green)"
    },
    "transition-duration": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Glass state transition duration"
    }
  },
  "choreography": {
    "$description": "Glass-specific motion — blur and saturation animate on enter/exit/state transitions instead of snapping. Grounded in Apple Liquid Glass reveal patterns.",
    "enter-duration": {
      "$value": "350ms",
      "$type": "duration",
      "$description": "Glass surface appear — blur builds up gradually"
    },
    "enter-easing": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier",
      "$description": "M3 emphasize — dramatic deceleration for glass reveal"
    },
    "exit-duration": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Glass surface dismiss — faster than enter"
    },
    "exit-easing": {
      "$value": "cubic-bezier(0.55, 0, 1, 0.45)",
      "$type": "cubicBezier",
      "$description": "Ease-in for glass dismissal"
    },
    "blur-from": {
      "$value": "0px",
      "$type": "dimension",
      "$description": "Blur starts at zero and builds to tier value on enter"
    },
    "saturate-from": {
      "$value": "100%",
      "$type": "string",
      "$description": "Saturation starts at normal and builds to tier value on enter"
    },
    "state-duration": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Blur/saturation transition between interactive states (hover, press)"
    },
    "state-easing": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier",
      "$description": "M3 emphasize for state transitions"
    }
  },
  "material": {
    "$description": "Apple-style material tiers — named after visionOS material densities",
    "ultra-thin": {
      "bg-opacity": {
        "$value": 0.02,
        "$type": "number"
      },
      "blur": {
        "$value": "8px",
        "$type": "dimension"
      },
      "saturate": {
        "$value": "110%",
        "$type": "string"
      },
      "$description": "Ultra-thin material — barely perceptible, background chrome"
    },
    "thin": {
      "bg-opacity": {
        "$value": 0.04,
        "$type": "number"
      },
      "blur": {
        "$value": "16px",
        "$type": "dimension"
      },
      "saturate": {
        "$value": "140%",
        "$type": "string"
      },
      "$description": "Thin material — nav bars, toolbars"
    },
    "regular": {
      "bg-opacity": {
        "$value": 0.06,
        "$type": "number"
      },
      "blur": {
        "$value": "24px",
        "$type": "dimension"
      },
      "saturate": {
        "$value": "180%",
        "$type": "string"
      },
      "$description": "Regular material — cards, panels, sidebars"
    },
    "thick": {
      "bg-opacity": {
        "$value": 0.1,
        "$type": "number"
      },
      "blur": {
        "$value": "32px",
        "$type": "dimension"
      },
      "saturate": {
        "$value": "200%",
        "$type": "string"
      },
      "$description": "Thick material — modals, sheets, prominent overlays"
    }
  }
}
