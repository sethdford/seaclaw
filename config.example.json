{
  "workspace": "~/.human/workspace",
  "default_provider": "anthropic",
  "default_model": "claude-3-5-sonnet-20241022",
  "default_temperature": 0.7,

  "providers": [
    {
      "name": "anthropic",
      "api_key": "YOUR_ANTHROPIC_API_KEY",
      "native_tools": true
    },
    {
      "name": "openai",
      "api_key": "YOUR_OPENAI_API_KEY"
    },
    {
      "name": "google",
      "api_key": "YOUR_GOOGLE_AI_API_KEY"
    },
    {
      "name": "cartesia",
      "api_key": "YOUR_CARTESIA_API_KEY"
    }
  ],

  "channels": {
    "cli": true,
    "default_channel": "cli"
  },

  "memory": {
    "profile": "sqlite_full",
    "backend": "sqlite",
    "auto_save": true,
    "max_entries": 10000
  },

  "agent": {
    "hula": true,
    "max_tool_iterations": 25,
    "max_history_messages": 100,
    "permission_level": 2,
    "session_auto_save": true,
    "session_dir": "~/.human/sessions",
    "discover_instructions": true,
    "compaction_use_structured": true
  },

  "hooks": {
    "enabled": true,
    "hooks": [
      {
        "event": "pre_tool_execute",
        "name": "audit_logger",
        "command": "/usr/local/bin/audit-tool.sh",
        "timeout_sec": 5,
        "required": false
      },
      {
        "event": "post_tool_execute",
        "name": "result_validator",
        "command": "/usr/local/bin/validate-result.sh",
        "timeout_sec": 3,
        "required": false
      }
    ]
  },

  "mcp": {
    "enabled": true,
    "servers": [
      {
        "name": "filesystem",
        "transport_type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
        "auto_connect": true,
        "timeout_ms": 30000
      },
      {
        "name": "github",
        "transport_type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "auto_connect": false,
        "timeout_ms": 30000
      }
    ]
  },

  "reliability": {
    "provider_retries": 2,
    "provider_backoff_ms": 500,
    "fallback_providers": [],
    "model_fallbacks": []
  },

  "autonomy": {
    "level": "supervised",
    "workspace_only": true,
    "max_actions_per_hour": 100
  },

  "gateway": {
    "port": 3000,
    "host": "127.0.0.1",
    "require_pairing": true
  },

  "security": {
    "autonomy_level": 1,
    "sandbox": {
      "backend": "auto"
    },
    "audit": {
      "enabled": true
    }
  },

  "voice": {
    "mode": "gemini_live",
    "realtime_model": "gemini-3.1-flash-live-preview",
    "realtime_voice": "Puck",
    "vertex_region": "us-central1",
    "vertex_project": "YOUR_GCP_PROJECT"
  },

  "tools": {
    "shell_timeout_secs": 30,
    "max_file_size_bytes": 1048576,
    "web_fetch_max_chars": 100000
  }
}
