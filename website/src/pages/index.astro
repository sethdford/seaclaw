    <script is:inline define:vars={{ chapterCount }}>
      {
        var chapterNav = document.querySelector(".chapter-nav");
        if (chapterNav) {
          var dots = Array.from(chapterNav.querySelectorAll(".chapter-dot"));
          var sections = [];
          for (var i = 1; i <= chapterCount; i++) {
            var el = document.getElementById("chapter-" + i);
            if (el) sections.push(el);
          }
          if (sections.length && dots.length) {
            var mobileInd = document.getElementById("mobile-chapter-ind");
            var pips = mobileInd
              ? Array.from(mobileInd.querySelectorAll(".chapter-pip"))
              : [];
            var setActive = function (index) {
              dots.forEach(function (d, i) {
                var on = i === index;
                d.classList.toggle("active", on);
                var inner = d.querySelector(".chapter-dot-inner");
                if (inner) inner.classList.toggle("active", on);
              });
              pips.forEach(function (p, i) {
                p.classList.toggle("active", i === index);
              });
              if (mobileInd) mobileInd.classList.add("visible");
            };
            var obs = new IntersectionObserver(
              function (entries) {
                entries.forEach(function (entry) {
                  if (!entry.isIntersecting) return;
                  var idx = sections.indexOf(entry.target);
                  if (idx >= 0) setActive(idx);
                });
              },
              { threshold: 0, rootMargin: "-42% 0px -42% 0px" },
            );
            sections.forEach(function (s) {
              obs.observe(s);
            });
            setActive(0);
          }
        }
      }
    </script>
    <script>
