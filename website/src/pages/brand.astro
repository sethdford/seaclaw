      {/* ═══ 8. Motion ═══ */}
      <section id="motion" class="py-24 md:py-32 px-6 cv-defer" data-reveal>
        <div class="max-w-5xl mx-auto">
          <h2
            class="text-[clamp(2rem,4vw,3rem)] font-black mb-16"
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            Motion
          </h2>
          <p class="text-lg mb-12" style="color: var(--color-text-secondary);">
            h-uman motion is <strong style="color: var(--color-text);"
              >purposeful, restrained, and spring-first</strong
            >. Every animation communicates state change. Nothing moves for
            decoration alone.
          </p>

          <div class="space-y-12">
            {/* Principles */}
            <div class="grid md:grid-cols-3 gap-6">
              <div
                class="glass rounded-2xl p-8"
                style="border: 1px solid var(--color-border);"
              >
                <h3
                  class="text-base font-semibold mb-3"
                  style="color: var(--color-text);"
                >
                  Spring-First
                </h3>
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  Prefer spring physics over bezier curves. Springs feel natural
                  because they have velocity and overshoot — real objects behave
                  this way.
                </p>
              </div>
              <div
                class="glass rounded-2xl p-8"
                style="border: 1px solid var(--color-border);"
              >
                <h3
                  class="text-base font-semibold mb-3"
                  style="color: var(--color-text);"
                >
                  Purposeful
                </h3>
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  Every animation communicates: entrance, exit, state change, or
                  spatial relationship. If you can't name the purpose, remove
                  the animation.
                </p>
              </div>
              <div
                class="glass rounded-2xl p-8"
                style="border: 1px solid var(--color-border);"
              >
                <h3
                  class="text-base font-semibold mb-3"
                  style="color: var(--color-text);"
                >
                  Restrained
                </h3>
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  Maximum duration: 700ms. Typical: 200-400ms. Use compositor
                  properties only (transform, opacity, filter). Always respect <code
                    class="px-1 py-0.5 rounded text-xs"
                    style="background: var(--hu-surface-container-high);"
                    >prefers-reduced-motion</code
                  >.
                </p>
              </div>
            </div>

            {/* Duration Scale */}
            <div>
              <h3
                class="text-lg font-semibold mb-6"
                style="color: var(--color-text);"
              >
                Duration Scale
              </h3>
              <div class="space-y-4">
                {
                  [
                    {
                      name: "Instant",
                      token: "--hu-duration-instant",
                      value: "50ms",
                      width: "5%",
                    },
                    {
                      name: "Fast",
                      token: "--hu-duration-fast",
                      value: "100ms",
                      width: "14%",
                    },
                    {
                      name: "Normal",
                      token: "--hu-duration-normal",
                      value: "200ms",
                      width: "28%",
                    },
                    {
                      name: "Slow",
                      token: "--hu-duration-slow",
                      value: "400ms",
                      width: "57%",
                    },
                    {
                      name: "Slower",
                      token: "--hu-duration-slower",
                      value: "700ms",
                      width: "100%",
                    },
                  ].map((dur) => (
                    <div class="flex items-center gap-4">
                      <span
                        class="text-sm w-16 shrink-0"
                        style="color: var(--color-text);"
                      >
                        {dur.name}
                      </span>
                      <div
                        class="flex-1 h-8 rounded-lg overflow-hidden"
                        style="background: var(--hu-surface-container);"
                      >
                        <div
                          class="h-full rounded-lg flex items-center justify-end px-3"
                          style={`width: ${dur.width}; background: color-mix(in srgb, var(--hu-accent) 30%, transparent);`}
                        >
                          <span
                            class="text-xs font-mono"
                            style="color: var(--hu-accent);"
                          >
                            {dur.value}
                          </span>
                        </div>
                      </div>
                      <code
                        class="text-xs hidden sm:block shrink-0"
                        style="color: var(--color-text-tertiary);"
                      >
                        {dur.token}
                      </code>
                    </div>
                  ))
                }
              </div>
            </div>

            {/* Signature */}
            <div
              class="glass rounded-2xl p-8"
              style="border: 1px solid var(--color-border);"
            >
              <h3
                class="text-base font-semibold mb-4"
                style="color: var(--color-text);"
              >
                What "h-uman motion" feels like
              </h3>
              <ul
                class="space-y-2 text-sm"
                style="color: var(--color-text-secondary);"
              >
                <li>
                  Elements arrive with slight overshoot, then settle — like a
                  ball landing on a surface
                </li>
                <li>Exits are faster than entrances (200ms out vs 300ms in)</li>
                <li>
                  Staggered reveals cascade top-to-bottom, 50ms apart, capped at
                  300ms total
                </li>
                <li>
                  No bounce, no wobble, no playfulness — this is infrastructure
                  software
                </li>
                <li>
                  Focus rings appear instantly; content transitions smoothly
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

