    <script>
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      // Show all elements immediately for reduced motion
      if (prefersReducedMotion) {
        document.querySelectorAll("[data-reveal]").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
          (el as HTMLElement).style.transform = "none";
          (el as HTMLElement).style.transitionDuration = "0s";
        });
        document.querySelectorAll(".opacity-0").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
        });

        const outputEl = document.getElementById("terminal-output");
        if (outputEl) {
          outputEl.innerHTML = [
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-web-text)">git clone https://github.com/sethdford/h-uman.git</span></div>',
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-web-text)">cd h-uman && mkdir -p build && cd build</span></div>',
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-web-text)">cmake .. -DCMAKE_BUILD_TYPE=MinSizeRel -DHU_ENABLE_LTO=ON && cmake --build .</span></div>',
            '<div><span style="color:var(--hu-web-text-tertiary)">[100%] Built target human</span></div>',
            '<div><span style="color:var(--color-accent)">$ </span><span style="color:var(--hu-web-text)">ls -lh human</span></div>',
            '<div><span style="color:var(--hu-web-text-tertiary)">-rwxr-xr-x  1 user  staff  </span><span style="color:var(--color-accent)">1696K</span><span style="color:var(--hu-web-text-tertiary)">  human</span></div>',
          ].join("");
        }

        document.querySelectorAll("[data-count]").forEach((el) => {
          const target = parseInt((el as HTMLElement).dataset.count || "0");
          const valSpan = el.querySelector(".count-value");
          if (valSpan)
            valSpan.textContent =
              target > 100 ? target.toLocaleString() : target.toString();
        });
        document.querySelectorAll(".dash-count").forEach((el) => {
          el.textContent = (el as HTMLElement).dataset.target || "0";
        });
        // Generate crystal grid for reduced motion
        const rmCrystalGrid = document.getElementById("crystalGrid");
        if (rmCrystalGrid) {
          const rmModules = [
            { name: "core", core: true }, { name: "json", core: true },
            { name: "http", core: true }, { name: "str", core: true },
            { name: "arena", core: true }, { name: "err", core: true },
            { name: "agent" }, { name: "ctx" }, { name: "plan" },
            { name: "disp" }, { name: "comp" }, { name: "turn" },
            { name: "prov" }, { name: "chan" }, { name: "tool" },
            { name: "mem" }, { name: "sec" }, { name: "run" },
            { name: "sse" }, { name: "ws" }, { name: "log" },
            { name: "cfg" }, { name: "gw" }, { name: "cli" },
            { name: "pers" }, { name: "emb" }, { name: "sql" },
            { name: "lru" }, { name: "vec" }, { name: "obs" },
            {}, {}, {}, {}, {}, {},
          ];
          rmModules.forEach((m) => {
            const cell = document.createElement("div");
            cell.className = "crystal-cell on" + (m.core ? " core" : m.name ? " filled" : "");
            cell.textContent = m.name || "";
            rmCrystalGrid.appendChild(cell);
          });
        }
        document
          .querySelectorAll(".crystal-cell")
          .forEach((el) => {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
          });
        document.querySelectorAll(".ring-fg").forEach((r) => r.classList.add("on"));
        document.querySelectorAll(".dep-tree-svg [data-delay]").forEach((el) => el.classList.add("on"));
        document.querySelectorAll(".spectrum-dot").forEach((d) => d.classList.add("on"));
        const dl = document.getElementById("deviceLine");
        if (dl) dl.classList.add("on");
      } else {
        // ═══ Intersection Observer reveal system ═══
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -50px 0px" },
        );
        document
          .querySelectorAll("[data-reveal], .glass-enter")
          .forEach((el) => {
            revealObserver.observe(el);
          });

        // ═══ Nav glass toggle via scroll ═══
        const nav = document.getElementById("site-nav");
        if (nav) {
          const onScroll = () => {
            if (window.scrollY > 80) {
              nav.classList.add("glass-nav");
            } else {
              nav.classList.remove("glass-nav");
            }
          };
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }

        // ═══ Count-up numbers (lazy GSAP) ═══
        const numbersGrid = document.querySelector(".numbers-grid");
        if (numbersGrid) {
          const numbersObs = new IntersectionObserver(
            async (entries) => {
              if (!entries[0]?.isIntersecting) return;
              numbersObs.disconnect();
              const { gsap } = await import("gsap");
              document.querySelectorAll(".number-item").forEach((item, i) => {
                const el = item.querySelector("[data-count]") as HTMLElement;
                if (!el) return;
                const target = parseInt(el.dataset.count || "0");
                const valSpan = el.querySelector(".count-value");
                if (!valSpan) return;
                const obj = { val: 0 };
                gsap.to(obj, {
                  val: target,
                  duration: 1.5,
                  ease: "power3.out",
                  delay: i * 0.08,
                  onUpdate: () => {
                    valSpan.textContent =
                      target > 100
                        ? Math.round(obj.val).toLocaleString()
                        : Math.round(obj.val).toString();
                  },
                  onComplete: () => {
                    gsap.fromTo(
                      item,
                      { scale: 1 },
                      {
                        scale: 1.04,
                        duration: 0.15,
                        yoyo: true,
                        repeat: 1,
                        ease: "power2.out",
                      },
                    );
                  },
                });
              });
            },
            { threshold: 0.15 },
          );
          numbersObs.observe(numbersGrid);
        }

        // ═══ Architecture SVG line drawing (lazy GSAP) ═══
        const archDiagram = document.getElementById("arch-diagram");
        if (archDiagram) {
          const archObs = new IntersectionObserver(
            async (entries) => {
              if (!entries[0]?.isIntersecting) return;
              archObs.disconnect();
              const { gsap } = await import("gsap");
              const archTl = gsap.timeline({
                defaults: { ease: "power3.out" },
              });
              archTl
                .to("#arch-core", { opacity: 1, duration: 0.6 })
                .fromTo(
                  ".arch-line",
                  {
                    attr: {
                      "stroke-dasharray": "200",
                      "stroke-dashoffset": "200",
                    },
                  },
                  {
                    attr: {
                      "stroke-dashoffset": "0",
                      stroke: "var(--color-accent)",
                    },
                    duration: 0.7,
                    stagger: 0.06,
                  },
                  0.3,
                )
                .to(
                  ".arch-node",
                  { opacity: 1, duration: 0.5, stagger: 0.08 },
                  0.6,
                );
            },
            { threshold: 0.15 },
          );
