#compdef human
# Zsh completion for human
# Source with: fpath=(/path/to/human/completions $fpath) && autoload -U compinit && compinit
# Or copy to: ~/.zsh/completions/_human

_human() {
    local context state
    typeset -A opt_args

    _arguments -C -s -S \
        '(-v --version)'{-v,--version}'[Show version information]' \
        '(-h --help)'{-h,--help}'[Show help information]' \
        '(--mcp)'--mcp'[Run as MCP server]' \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            _describe 'command' '(
                agent:Start interactive agent session
                agents:Manage named agent definitions
                gateway:Start webhook gateway server
                mcp:Run as MCP server \(stdin/stdout JSON-RPC\)
                service:Run as background service
                service-loop:Run service loop in foreground
                status:Show runtime status
                onboard:Interactive setup wizard
                setup:Local / on-device model setup
                doctor:Run system diagnostics
                cron:Manage scheduled tasks
                channel:Channel management
                calibrate:Analyze messaging patterns and calibrate persona
                config:Configuration reference \(schema\)
                skills:Skill discovery and integration
                hardware:Hardware peripheral management
                hula:Run a HuLa program \(parse, validate, execute, trace\)
                migrate:Migrate memory backends
                memory:Memory operations
                workspace:Workspace management
                capabilities:Show available capabilities
                models:List available models
                auth:Authentication management
                update:Check for updates
                version:Show version information
                help:Show help information
                init:Initialize configuration
                paperclip:Paperclip agent integration
                persona:Persona management
                research:Run research agent
                plugins:Plugin management
                pwa:PWA browser automation
                sandbox:Sandbox management
                eval:Run evaluation harness
                feed:Feed management
                ml:ML training and experiments
            )'
            ;;
        args)
            case $words[2] in
                cron)
                    _describe 'cron subcommand' '(
                        list:List scheduled tasks
                        add:Add scheduled task
                        remove:Remove scheduled task
                    )'
                    ;;
                channel)
                    _describe 'channel subcommand' '(
                        list:List configured channels
                        status:Channel health status
                        start:Start channel
                        stop:Stop channel
                    )'
                    ;;
                hardware)
                    _describe 'hardware subcommand' '(
                        list:List detected hardware
                        info:Board information
                        scan:Scan for hardware
                        flash:Flash firmware
                        monitor:Monitor serial
                    )'
                    ;;
                memory)
                    _describe 'memory subcommand' '(
                        stats:Memory statistics
                        count:Entry count
                        list:List memory entries
                        search:Search memory
                        get:Get entry by key
                        forget:Forget entry
                    )'
                    ;;
                workspace)
                    _describe 'workspace subcommand' '(
                        show:Show current workspace
                        set:Set workspace path
                    )'
                    ;;
                models)
                    _describe 'models subcommand' '(
                        list:List available models
                        info:Model information
                        benchmark:Benchmark model
                    )'
                    ;;
                auth)
                    _describe 'auth subcommand' '(
                        login:Login to provider
                        status:Auth status
                        logout:Logout from provider
                    )'
                    ;;
                skills)
                    _describe 'skills subcommand' '(
                        list:List installed skills
                        search:Search skill registry
                        install:Install a skill
                        uninstall:Uninstall a skill
                        update:Update all installed skills
                        info:Show skill details
                        publish:Publish a skill
                    )'
                    ;;
                migrate)
                    _describe 'migrate subcommand' '(
                        sqlite:Migrate from SQLite backend
                        markdown:Migrate from markdown backend
                        --dry-run:Preview without writing
                    )'
                    ;;
                capabilities)
                    _describe 'capabilities option' '(
                        --json:Output capabilities as JSON
                    )'
                    ;;
                update)
                    _describe 'update option' '(
                        --check:Check only, do not update
                    )'
                    ;;
                persona)
                    _describe 'persona subcommand' '(
                        create:Create a persona
                        show:Show persona details
                        list:List personas
                        delete:Delete a persona
                        validate:Validate persona JSON
                        feedback:Apply feedback
                        export:Export persona
                        import:Import persona
                        merge:Merge personas
                    )'
                    ;;
                sandbox)
                    _describe 'sandbox subcommand' '(
                        list:List sandbox backends
                        status:Sandbox status
                    )'
                    ;;
                paperclip)
                    _describe 'paperclip subcommand' '(
                        heartbeat:Send heartbeat
                    )'
                    ;;
            esac
            ;;
    esac
}

_human "$@"
