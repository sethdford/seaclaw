#!/bin/sh
# pre-push: run the full test suite before pushing.
# Activate: git config core.hooksPath .githooks
# Note: ASan and coverage are CI-only (too slow for local hooks).

JOBS=$(nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || echo 4)
BUILD_DIR="build-check"

if [ -f "CMakeLists.txt" ]; then
    echo "Running seaclaw tests..."
    mkdir -p "$BUILD_DIR"
    cd "$BUILD_DIR" || exit 1
    if [ ! -f "CMakeCache.txt" ]; then
        cmake .. -DCMAKE_BUILD_TYPE=Debug -DSC_ENABLE_ALL_CHANNELS=ON -DSC_ENABLE_CURL=ON 2>/dev/null
    fi
    cmake --build . -j"$JOBS" 2>&1 | tail -3
    if [ $? -ne 0 ]; then
        echo "Build failed. Fix before pushing."
        exit 1
    fi
    ./seaclaw_tests
    if [ $? -ne 0 ]; then
        echo "Tests failed. Fix before pushing."
        exit 1
    fi
    cd ..

    # Auto-sync stats in AGENTS.md, README.md, and STUBS.md
    if [ -x "scripts/update-stats.sh" ]; then
        echo "Syncing project stats..."
        bash scripts/update-stats.sh --apply 2>/dev/null || true
    fi
else
    echo "No build system found. Skipping pre-push tests."
fi
