---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import { Cpu, Zap, Globe, Shield, Blocks, Wifi } from "@lucide/astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const providers = [
  "OpenAI", "Anthropic", "Gemini", "OpenRouter", "Ollama", "llama.cpp",
  "Groq", "Mistral", "xAI", "DeepSeek", "Together", "Fireworks",
  "Perplexity", "Cohere", "LM Studio", "vLLM", "sglang", "Cerebras",
  "SambaNova", "Hyperbolic",
];
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SeaClaw — Intelligence infrastructure that disappears.</title>
    <meta name="description" content="239 KB binary. Under 5 MB RAM. Under 2ms startup. Autonomous AI assistant runtime in C11. Zero dependencies. 50+ providers. Runs on anything." />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta property="og:title" content="SeaClaw" />
    <meta property="og:description" content="Intelligence infrastructure that disappears. 239 KB. Under 5 MB RAM. 50+ providers." />
    <meta property="og:type" content="website" />
  </head>
  <body class="bg-[#09090b] text-zinc-50 antialiased overflow-x-hidden">
    <Nav />

    {/* ── Hero ── */}
    <section class="relative min-h-screen flex flex-col items-center justify-center px-6">
      <div class="hero-content text-center max-w-3xl mx-auto">
        <img
          src={`${base}seaclaw.svg`}
          alt="SeaClaw"
          class="hero-logo w-16 h-16 md:w-20 md:h-20 mx-auto mb-8 opacity-0"
          style="filter: drop-shadow(0 0 20px rgba(239,68,68,0.3))"
        />
        <h1 class="hero-title text-[clamp(3rem,8vw,6rem)] font-bold tracking-[-0.03em] leading-[0.95] text-white mb-6 opacity-0">
          SeaClaw
        </h1>
        <p class="hero-sub text-[clamp(1.125rem,2.5vw,1.5rem)] text-zinc-400 font-normal leading-relaxed mb-12 opacity-0">
          Intelligence infrastructure that disappears.
        </p>
        <div class="hero-buttons flex flex-col sm:flex-row gap-4 justify-center opacity-0">
          <a
            href={`${base}getting-started/installation/`}
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-full text-[15px] font-medium bg-red-500 hover:bg-red-400 text-white transition-all duration-200 hover:shadow-[0_0_30px_rgba(239,68,68,0.3)]"
          >
            Get Started
          </a>
          <a
            href="https://github.com/sethdford/seaclaw"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-full text-[15px] font-medium text-zinc-300 border border-zinc-700/60 hover:border-zinc-500 transition-all duration-200 hover:text-white"
          >
            View Source
          </a>
        </div>
      </div>
    </section>

    {/* ── Numbers ── */}
    <section class="py-32 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="numbers-grid grid grid-cols-2 md:grid-cols-4 gap-0">
          <div class="number-item text-center py-8 md:py-0 md:border-r border-zinc-800/40">
            <div class="text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-white leading-none" data-count="239" data-suffix=" KB">
              <span class="count-value">0</span><span class="count-suffix"> KB</span>
            </div>
            <div class="text-[13px] text-zinc-500 mt-3 uppercase tracking-[0.1em]">Binary</div>
          </div>
          <div class="number-item text-center py-8 md:py-0 md:border-r border-zinc-800/40">
            <div class="text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-white leading-none" data-count="2" data-prefix="<" data-suffix=" ms">
              <span class="count-prefix">&lt;</span><span class="count-value">0</span><span class="count-suffix"> ms</span>
            </div>
            <div class="text-[13px] text-zinc-500 mt-3 uppercase tracking-[0.1em]">Startup</div>
          </div>
          <div class="number-item text-center py-8 md:py-0 md:border-r border-zinc-800/40">
            <div class="text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-white leading-none" data-count="1791">
              <span class="count-value">0</span>
            </div>
            <div class="text-[13px] text-zinc-500 mt-3 uppercase tracking-[0.1em]">Tests</div>
          </div>
          <div class="number-item text-center py-8 md:py-0">
            <div class="text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-white leading-none" data-count="50" data-suffix="+">
              <span class="count-value">0</span><span class="count-suffix">+</span>
            </div>
            <div class="text-[13px] text-zinc-500 mt-3 uppercase tracking-[0.1em]">Providers</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Features ── */}
    <section id="features" class="py-32 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="feature-title text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.02em] text-white mb-20 opacity-0">
          Built for the edge.
        </h2>
        <div class="grid md:grid-cols-2 gap-x-16 gap-y-14">
          <div class="feature-card group opacity-0 border-l-2 border-transparent hover:border-red-500/60 pl-6 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <Cpu class="w-5 h-5 text-zinc-500 group-hover:text-red-500 transition-colors" strokeWidth={1.5} />
              <h3 class="text-lg font-semibold text-white">239 KB</h3>
            </div>
            <p class="text-[15px] text-zinc-400 leading-relaxed">Static binary. No runtime, no VM, no framework. Just your code and libc.</p>
          </div>
          <div class="feature-card group opacity-0 border-l-2 border-transparent hover:border-red-500/60 pl-6 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <Zap class="w-5 h-5 text-zinc-500 group-hover:text-red-500 transition-colors" strokeWidth={1.5} />
              <h3 class="text-lg font-semibold text-white">Instant</h3>
            </div>
            <p class="text-[15px] text-zinc-400 leading-relaxed">Under 2 ms startup on Apple Silicon. Under 8 ms at 0.8 GHz edge hardware.</p>
          </div>
          <div class="feature-card group opacity-0 border-l-2 border-transparent hover:border-red-500/60 pl-6 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <Globe class="w-5 h-5 text-zinc-500 group-hover:text-red-500 transition-colors" strokeWidth={1.5} />
              <h3 class="text-lg font-semibold text-white">Portable</h3>
            </div>
            <p class="text-[15px] text-zinc-400 leading-relaxed">One binary. ARM, x86, RISC-V. Drop it on any hardware and it runs.</p>
          </div>
          <div class="feature-card group opacity-0 border-l-2 border-transparent hover:border-red-500/60 pl-6 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <Shield class="w-5 h-5 text-zinc-500 group-hover:text-red-500 transition-colors" strokeWidth={1.5} />
              <h3 class="text-lg font-semibold text-white">Secure</h3>
            </div>
            <p class="text-[15px] text-zinc-400 leading-relaxed">Pairing, sandboxing, encrypted secrets, workspace scoping. Deny-by-default.</p>
          </div>
          <div class="feature-card group opacity-0 border-l-2 border-transparent hover:border-red-500/60 pl-6 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <Blocks class="w-5 h-5 text-zinc-500 group-hover:text-red-500 transition-colors" strokeWidth={1.5} />
              <h3 class="text-lg font-semibold text-white">Modular</h3>
            </div>
            <p class="text-[15px] text-zinc-400 leading-relaxed">Every subsystem is a vtable interface. Swap providers, channels, memory, tools via config.</p>
          </div>
          <div class="feature-card group opacity-0 border-l-2 border-transparent hover:border-red-500/60 pl-6 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <Wifi class="w-5 h-5 text-zinc-500 group-hover:text-red-500 transition-colors" strokeWidth={1.5} />
              <h3 class="text-lg font-semibold text-white">Offline</h3>
            </div>
            <p class="text-[15px] text-zinc-400 leading-relaxed">llama.cpp, Ollama, LM Studio, vLLM. Run fully local with no cloud dependency.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Architecture ── */}
    <section id="architecture" class="py-32 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="arch-title text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.02em] text-white mb-4 opacity-0">
          Swap anything.
        </h2>
        <p class="arch-sub text-lg text-zinc-400 mb-20 opacity-0">Every subsystem is a vtable interface.</p>

        <svg id="arch-diagram" viewBox="0 0 600 600" class="w-full max-w-lg mx-auto" xmlns="http://www.w3.org/2000/svg">
          <line class="arch-line" x1="300" y1="300" x2="300" y2="100" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="441" y2="159" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="500" y2="300" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="441" y2="441" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="300" y2="500" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="159" y2="441" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="100" y2="300" stroke="#27272a" stroke-width="1" />
          <line class="arch-line" x1="300" y1="300" x2="159" y2="159" stroke="#27272a" stroke-width="1" />

          <g id="arch-core" class="opacity-0">
            <circle cx="300" cy="300" r="44" fill="#18181b" stroke="#ef4444" stroke-width="1.5" />
            <text x="300" y="296" text-anchor="middle" fill="#fafafa" font-size="11" font-weight="600" font-family="var(--font-sans)">SeaClaw</text>
            <text x="300" y="312" text-anchor="middle" fill="#a1a1aa" font-size="9" font-family="var(--font-sans)">Core</text>
          </g>

          <g class="arch-node opacity-0" data-label="50+ AI model backends">
            <circle cx="300" cy="100" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="300" y="104" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Providers</text>
          </g>
          <g class="arch-node opacity-0" data-label="20 messaging integrations">
            <circle cx="441" cy="159" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="441" y="163" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Channels</text>
          </g>
          <g class="arch-node opacity-0" data-label="SQLite + vector + FTS5">
            <circle cx="500" cy="300" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="500" y="304" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Memory</text>
          </g>
          <g class="arch-node opacity-0" data-label="30+ built-in capabilities">
            <circle cx="441" cy="441" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="441" y="445" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Tools</text>
          </g>
          <g class="arch-node opacity-0" data-label="Sandbox + secrets + audit">
            <circle cx="300" cy="500" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="300" y="504" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Security</text>
          </g>
          <g class="arch-node opacity-0" data-label="Native, Docker, WASM">
            <circle cx="159" cy="441" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="159" y="445" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Runtime</text>
          </g>
          <g class="arch-node opacity-0" data-label="Cloudflare, Tailscale, ngrok">
            <circle cx="100" cy="300" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="100" y="304" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Tunnels</text>
          </g>
          <g class="arch-node opacity-0" data-label="Arduino, STM32, RPi GPIO">
            <circle cx="159" cy="159" r="30" fill="#18181b" stroke="#27272a" stroke-width="1" />
            <text x="159" y="163" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="var(--font-sans)">Hardware</text>
          </g>
        </svg>
      </div>
    </section>

    {/* ── Terminal ── */}
    <section class="py-32 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="terminal-title text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.02em] text-white mb-4 text-center opacity-0">
          Clone. Build. Run.
        </h2>
        <p class="terminal-sub text-lg text-zinc-400 mb-12 text-center opacity-0">No containers. No interpreters. No dependencies.</p>
        <div id="terminal" class="rounded-2xl overflow-hidden border border-zinc-800/60 bg-[#0c0c0e] opacity-0">
          <div class="flex items-center gap-2 px-5 py-3.5 bg-zinc-900/80 border-b border-zinc-800/60">
            <span class="w-3 h-3 rounded-full bg-zinc-700"></span>
            <span class="w-3 h-3 rounded-full bg-zinc-700"></span>
            <span class="w-3 h-3 rounded-full bg-zinc-700"></span>
            <span class="text-[11px] text-zinc-600 ml-2 font-mono">terminal</span>
          </div>
          <div id="terminal-output" class="p-6 font-mono text-[13px] md:text-sm leading-[1.8] min-h-[280px]">
          </div>
        </div>
      </div>
    </section>

    {/* ── Providers ── */}
    <section class="py-32 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="providers-title text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.02em] text-white mb-16 opacity-0">
          50+ providers. Your choice.
        </h2>
        <div class="flex flex-wrap gap-3" id="provider-grid">
          {providers.map((name) => (
            <span class="provider-pill opacity-0 px-4 py-2 rounded-full text-[13px] text-zinc-400 bg-zinc-900 border border-zinc-800/50 hover:border-zinc-600 hover:text-zinc-200 transition-all duration-200 cursor-default">
              {name}
            </span>
          ))}
          <span class="provider-pill opacity-0 px-4 py-2 rounded-full text-[13px] text-zinc-500 bg-zinc-900/50 border border-zinc-800/30 italic">
            and 30+ more...
          </span>
        </div>
      </div>
    </section>

    {/* ── Final CTA ── */}
    <section class="py-40 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="cta-title text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-[-0.03em] text-white leading-[0.95] mb-4 opacity-0">
          Deploy anywhere.
        </h2>
        <p class="cta-sub text-[clamp(1.5rem,4vw,3rem)] font-bold tracking-[-0.02em] text-zinc-500 mb-14 opacity-0">
          Swap anything.
        </p>
        <div class="cta-buttons flex flex-col sm:flex-row gap-4 justify-center opacity-0">
          <a
            href={`${base}getting-started/installation/`}
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-full text-[15px] font-medium bg-red-500 hover:bg-red-400 text-white transition-all duration-200 hover:shadow-[0_0_30px_rgba(239,68,68,0.3)]"
          >
            Read the Docs
          </a>
          <a
            href="https://github.com/sethdford/seaclaw"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-full text-[15px] font-medium text-zinc-300 border border-zinc-700/60 hover:border-zinc-500 transition-all duration-200 hover:text-white"
          >
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    {/* ── Footer ── */}
    <footer class="py-12 px-6 border-t border-zinc-800/40">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <img src={`${base}seaclaw.svg`} alt="" class="w-5 h-5" />
          <span class="text-[13px] text-zinc-500">SeaClaw</span>
        </div>
        <div class="flex items-center gap-6 text-[13px] text-zinc-600">
          <span>MIT License</span>
          <span>Made with C11</span>
          <a href="https://github.com/sethdford/seaclaw" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-400 transition-colors">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);
      gsap.config({ nullTargetWarn: false });

      const ctx = gsap.context(() => {

        // ── Nav: backdrop on scroll
        ScrollTrigger.create({
          start: "top -80",
          onEnter: () => {
            const nav = document.getElementById("site-nav");
            if (nav) {
              nav.style.backgroundColor = "rgba(9,9,11,0.8)";
              nav.style.backdropFilter = "blur(24px)";
              nav.style.webkitBackdropFilter = "blur(24px)";
              nav.style.borderBottom = "1px solid rgba(39,39,42,0.4)";
            }
          },
          onLeaveBack: () => {
            const nav = document.getElementById("site-nav");
            if (nav) {
              nav.style.backgroundColor = "";
              nav.style.backdropFilter = "";
              nav.style.webkitBackdropFilter = "";
              nav.style.borderBottom = "";
            }
          },
        });

        // ── Hero sequence
        const heroTl = gsap.timeline({ defaults: { ease: "power2.out" } });
        heroTl
          .to(".hero-logo", { opacity: 1, scale: 1, duration: 0.8 }, 0.3)
          .fromTo(".hero-title", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8 }, 0.5)
          .fromTo(".hero-sub", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.8 }, 0.7)
          .fromTo(".hero-buttons", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.8 }, 0.9);

        // ── Numbers: counter animation
        const numberItems = document.querySelectorAll(".number-item");
        numberItems.forEach((item, i) => {
          const el = item.querySelector("[data-count]") as HTMLElement;
          if (!el) return;
          const target = parseInt(el.dataset.count || "0");
          const valSpan = el.querySelector(".count-value");
          if (!valSpan) return;

          const obj = { val: 0 };
          gsap.fromTo(item, { opacity: 0, y: 30 }, {
            opacity: 1, y: 0, duration: 0.6, delay: i * 0.12,
            scrollTrigger: { trigger: ".numbers-grid", start: "top 80%" },
          });
          gsap.to(obj, {
            val: target,
            duration: 1.5,
            ease: "power2.out",
            delay: i * 0.12,
            scrollTrigger: { trigger: ".numbers-grid", start: "top 80%" },
            onUpdate: () => {
              valSpan.textContent = target > 100
                ? Math.round(obj.val).toLocaleString()
                : Math.round(obj.val).toString();
            },
          });
        });

        // ── Features: stagger reveal
        gsap.fromTo(".feature-title", { opacity: 0, y: 30 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".feature-title", start: "top 85%" },
        });
        gsap.fromTo(".feature-card", { opacity: 0, y: 40 }, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.1,
          scrollTrigger: { trigger: ".feature-card", start: "top 80%" },
        });

        // ── Architecture: diagram animation
        const archTl = gsap.timeline({
          scrollTrigger: { trigger: "#arch-diagram", start: "top 75%" },
          defaults: { ease: "power2.out" },
        });
        gsap.fromTo(".arch-title", { opacity: 0, y: 30 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".arch-title", start: "top 85%" },
        });
        gsap.fromTo(".arch-sub", { opacity: 0, y: 20 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".arch-sub", start: "top 85%" },
        });

        archTl
          .to("#arch-core", { opacity: 1, duration: 0.5 })
          .fromTo(".arch-line", { attr: { "stroke-dasharray": "200", "stroke-dashoffset": "200" } },
            { attr: { "stroke-dashoffset": "0" }, duration: 0.6, stagger: 0.06 }, 0.3)
          .to(".arch-node", { opacity: 1, duration: 0.4, stagger: 0.08 }, 0.6);

        document.querySelectorAll(".arch-node").forEach((node) => {
          node.addEventListener("mouseenter", () => {
            const circle = node.querySelector("circle");
            if (circle) gsap.to(circle, { attr: { stroke: "#ef4444" }, duration: 0.2 });
          });
          node.addEventListener("mouseleave", () => {
            const circle = node.querySelector("circle");
            if (circle) gsap.to(circle, { attr: { stroke: "#27272a" }, duration: 0.2 });
          });
        });

        // ── Terminal: typing animation
        gsap.fromTo(".terminal-title", { opacity: 0, y: 30 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".terminal-title", start: "top 85%" },
        });
        gsap.fromTo(".terminal-sub", { opacity: 0, y: 20 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".terminal-sub", start: "top 85%" },
        });

        const terminalEl = document.getElementById("terminal");
        const outputEl = document.getElementById("terminal-output");
        if (terminalEl && outputEl) {
          let terminalPlayed = false;
          ScrollTrigger.create({
            trigger: terminalEl,
            start: "top 80%",
            onEnter: () => {
              if (terminalPlayed) return;
              terminalPlayed = true;
              gsap.to(terminalEl, { opacity: 1, duration: 0.5 });
              typeTerminal(outputEl);
            },
          });
        }

        interface TermLine {
          prompt: boolean;
          text: string;
          highlights?: Array<{ text: string; className: string }>;
        }

        function typeTerminal(container: HTMLElement) {
          const lines: TermLine[] = [
            { prompt: true, text: "git clone https://github.com/sethdford/seaclaw.git" },
            { prompt: true, text: "cd seaclaw && mkdir -p build && cd build" },
            { prompt: true, text: "cmake .. -DCMAKE_BUILD_TYPE=MinSizeRel" },
            { prompt: true, text: "cmake --build ." },
            { prompt: true, text: "ls -lh seaclaw" },
            { prompt: false, text: "-rwxr-xr-x  1 user  staff  239K  seaclaw", highlights: [{ text: "239K", className: "text-red-400" }] },
            { prompt: true, text: "./seaclaw doctor" },
            { prompt: false, text: "[doctor] provider (llamacpp): ok", highlights: [{ text: "ok", className: "text-red-400" }] },
            { prompt: false, text: "[doctor] memory engine: sqlite" },
          ];

          let lineIdx = 0;
          function nextLine() {
            if (lineIdx >= lines.length) return;
            const line = lines[lineIdx];
            const div = document.createElement("div");
            div.className = "terminal-line";

            if (line.prompt) {
              const promptSpan = document.createElement("span");
              promptSpan.className = "text-zinc-600";
              promptSpan.textContent = "$ ";
              div.appendChild(promptSpan);
              const textSpan = document.createElement("span");
              textSpan.className = "text-zinc-300";
              div.appendChild(textSpan);
              container.appendChild(div);

              let charIdx = 0;
              const typeChar = () => {
                if (charIdx < line.text.length) {
                  textSpan.textContent += line.text[charIdx];
                  charIdx++;
                  setTimeout(typeChar, 18);
                } else {
                  lineIdx++;
                  setTimeout(nextLine, 300);
                }
              };
              typeChar();
            } else {
              const wrapper = document.createElement("span");
              wrapper.className = "text-zinc-500";

              if (line.highlights && line.highlights.length > 0) {
                let remaining = line.text;
                for (const hl of line.highlights) {
                  const idx = remaining.indexOf(hl.text);
                  if (idx >= 0) {
                    if (idx > 0) {
                      wrapper.appendChild(document.createTextNode(remaining.slice(0, idx)));
                    }
                    const hlSpan = document.createElement("span");
                    hlSpan.className = hl.className;
                    hlSpan.textContent = hl.text;
                    wrapper.appendChild(hlSpan);
                    remaining = remaining.slice(idx + hl.text.length);
                  }
                }
                if (remaining) {
                  wrapper.appendChild(document.createTextNode(remaining));
                }
              } else {
                wrapper.textContent = line.text;
              }

              div.appendChild(wrapper);
              div.style.opacity = "0";
              container.appendChild(div);
              gsap.to(div, { opacity: 1, duration: 0.3 });
              lineIdx++;
              setTimeout(nextLine, 200);
            }
          }
          nextLine();
        }

        // ── Providers: scatter in
        gsap.fromTo(".providers-title", { opacity: 0, y: 30 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".providers-title", start: "top 85%" },
        });
        gsap.fromTo(".provider-pill", { opacity: 0, scale: 0.8 }, {
          opacity: 1, scale: 1, duration: 0.4,
          stagger: { each: 0.03, from: "random" },
          scrollTrigger: { trigger: "#provider-grid", start: "top 80%" },
        });

        // ── Final CTA
        gsap.fromTo(".cta-title", { opacity: 0, y: 40 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".cta-title", start: "top 80%" },
        });
        gsap.fromTo(".cta-sub", { opacity: 0, y: 30 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".cta-sub", start: "top 85%" },
        });
        gsap.fromTo(".cta-buttons", { opacity: 0, y: 20 }, {
          opacity: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: ".cta-buttons", start: "top 85%" },
        });

      });
    </script>
  </body>
</html>
