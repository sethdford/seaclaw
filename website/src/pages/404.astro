---
import "../styles/global.css";
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<html lang="en" class="hu-lcp-done">
  <head>
    <script is:inline>
      (function () {
        var s = localStorage.getItem("hu-theme");
        var m = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = s || m;
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — not quite found. | h-uman</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body
    style="background: var(--hu-bg); color: var(--hu-text);"
    class="antialiased"
  >
    <a href="#main-content" class="skip-link">Skip to content</a>
    <main
      id="main-content"
      tabindex="-1"
      class="min-h-screen flex flex-col items-center justify-center px-6 text-center"
    >
      <img
        src={`${base}human.svg`}
        alt="h-uman logo"
        width="80"
        height="80"
        class="w-16 h-16 mb-8 opacity-40"
        loading="lazy"
        decoding="async"
      />
      <h1
        class="font-sans font-black text-[clamp(4rem,12vw,8rem)] leading-none mb-4"
        style="color: var(--hu-text); letter-spacing: -0.05em; opacity: 0.12;"
      >
        404
      </h1>
      <p class="text-xl font-medium mb-2" style="color: var(--hu-text)">
        Page not found
      </p>
      <p
        class="text-base mb-10 max-w-md"
        style="color: var(--hu-text-secondary)"
      >
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={`${base}`}
          class="inline-flex items-center justify-center px-6 py-3 rounded-full text-[15px] font-semibold transition-all"
          style="background: var(--hu-accent); color: var(--hu-on-accent);"
        >
          Back to Home
        </a>
        <a
          href={`${base}getting-started/installation/`}
          class="inline-flex items-center justify-center px-6 py-3 rounded-full text-[15px] font-medium transition-all"
          style="color: var(--hu-text-secondary); border: 1px solid var(--hu-border);"
        >
          Read the Docs
        </a>
      </div>
    </main>
  </body>
</html>
