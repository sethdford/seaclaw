---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

const iconMonitor =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M208,40H48A24,24,0,0,0,24,64V176a24,24,0,0,0,24,24H108v16H80a8,8,0,0,0,0,16h96a8,8,0,0,0,0-16H148V200h60a24,24,0,0,0,24-24V64A24,24,0,0,0,208,40ZM48,56H208a8,8,0,0,1,8,8V160H40V64A8,8,0,0,1,48,56ZM208,184H48a8,8,0,0,1-8-8v-0H216v0A8,8,0,0,1,208,184Z"/></svg>';
const iconCircuitBoard =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M208,36H48A12,12,0,0,0,36,48V208a12,12,0,0,0,12,12H208a12,12,0,0,0,12-12V48A12,12,0,0,0,208,36Zm-4,168H52V52H204ZM116,96a12,12,0,1,1-12-12A12,12,0,0,1,116,96Zm64,64a12,12,0,1,1-12-12A12,12,0,0,1,180,160Z"/></svg>';
const iconCloud =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M160,40A88.09,88.09,0,0,0,81.29,88.68,64,64,0,1,0,72,216h88a88,88,0,0,0,0-176Zm0,160H72a48,48,0,0,1,0-96c1.1,0,2.2,0,3.29.11A88,88,0,0,0,72,128a8,8,0,0,0,16,0,72,72,0,1,1,72,72Z"/></svg>';
const iconCpu =
  '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M152,96H104a8,8,0,0,0-8,8v48a8,8,0,0,0,8,8h48a8,8,0,0,0,8-8V104A8,8,0,0,0,152,96Zm-8,48H112V112h32ZM224,120H208V96a24,24,0,0,0-24-24H160V48a8,8,0,0,0-16,0V72H112V48a8,8,0,0,0-16,0V72H72A24,24,0,0,0,48,96v24H32a8,8,0,0,0,0,16H48v16H32a8,8,0,0,0,0,16H48v16a24,24,0,0,0,24,24H96v24a8,8,0,0,0,16,0V208h32v24a8,8,0,0,0,16,0V208h24a24,24,0,0,0,24-24V160h16a8,8,0,0,0,0-16H208V128h16a8,8,0,0,0,0-16Zm-32,64a8,8,0,0,1-8,8H72a8,8,0,0,1-8-8V96a8,8,0,0,1,8-8H184a8,8,0,0,1,8,8Z"/></svg>';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const bloatItems = [
  "A container runtime",
  "A Python environment",
  "2 GB of RAM",
  "A cloud API key",
  "A stable internet connection",
  "A prayer",
];

const providers = [
  "OpenAI",
  "Anthropic",
  "Gemini",
  "OpenRouter",
  "Ollama",
  "llama.cpp",
  "Groq",
  "Mistral",
  "xAI",
  "DeepSeek",
  "Together",
  "Fireworks",
  "Perplexity",
  "Cohere",
  "LM Studio",
  "vLLM",
  "sglang",
  "Cerebras",
  "SambaNova",
  "Hyperbolic",
];

const channels = [
  "Telegram",
  "Discord",
  "Slack",
  "Signal",
  "iMessage",
  "Matrix",
  "WhatsApp",
  "IRC",
  "Nostr",
  "Email",
  "Line",
  "Mattermost",
];

const tools = [
  "Shell",
  "File Ops",
  "Git",
  "Browser",
  "Memory",
  "Web Search",
  "Cron",
  "HTTP",
  "Hardware",
  "Delegate",
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://h-uman.ai/" />
    <link
      rel="preload"
      href="/fonts/avenir/Avenir-Black.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/fonts/avenir/Avenir-Book.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="low"
    />
    <link
      rel="preload"
      href="/fonts/avenir/Avenir-Heavy.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="low"
    />
    <title>Human — Bring AI to every device on Earth</title>
    <meta
      name="description"
      content="A complete autonomous AI agent runtime in 528 kilobytes of pure C. One static binary. Zero dependencies. 50+ providers. Runs on anything with a CPU."
    />
    <link
      rel="preload"
      href={`${base}human.svg`}
      as="image"
      fetchpriority="high"
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${base}favicon-32.png`}
    />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <meta name="theme-color" content="#7AB648" />
    <meta
      property="og:title"
      content="Human — Bring AI to every device on Earth"
    />
    <meta
      property="og:description"
      content="~528 KB binary. 50+ AI providers. 34 channels. 67+ tools. Zero dependencies. Pure C."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://h-uman.ai/" />
    <meta property="og:image" content="https://h-uman.ai/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Human - Autonomous AI agent runtime"
    />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Human" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Human — Bring AI to every device on Earth"
    />
    <meta
      name="twitter:description"
      content="~528 KB binary. 50+ AI providers. 34 channels. 67+ tools. Zero dependencies. Pure C."
    />
    <meta name="twitter:image" content="https://h-uman.ai/og-image.png" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Human",
        description:
          "A complete autonomous AI agent runtime in 528 kilobytes of pure C.",
        applicationCategory: "DeveloperApplication",
        operatingSystem: "Cross-platform",
        url: "https://h-uman.ai/",
        license: "https://opensource.org/licenses/MIT",
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
        author: {
          "@type": "Organization",
          name: "Human",
          url: "https://github.com/sethdford/h-uman",
        },
      })}
    />
    <style is:global>
      /* --color-* aliases for index.astro (maps to --hu-web-* / --hu-* tokens) */
      :root {
        --color-bg: var(--hu-web-bg);
        --color-text: var(--hu-web-text);
        --color-text-secondary: var(--hu-web-text-secondary);
        --color-text-tertiary: var(--hu-web-text-tertiary);
        --color-accent: var(--hu-accent);
        --color-accent-light: var(--hu-accent-light, var(--hu-accent-subtle));
        --color-accent-glow: var(--hu-accent-subtle);
        --color-border: var(--hu-web-border);
        --color-line-stroke: var(--hu-web-line-stroke);
        --color-node-fill: var(--hu-web-node-fill);
        --color-node-stroke: var(--hu-web-node-stroke);
        /* Terminal (dark surface — light border intentional) */
        --color-terminal-bg: var(--hu-web-terminal-bg);
        --color-terminal-chrome: var(--hu-web-terminal-chrome);
        --color-terminal-border: rgba(255, 255, 255, 0.06);
        /* Pills */
        --color-pill-provider: var(--hu-web-pill-provider);
        --color-pill-provider-bg: var(--hu-web-pill-provider-bg);
        --color-pill-provider-border: var(--hu-web-pill-provider-border);
        --color-pill-channel: var(--hu-web-pill-channel);
        --color-pill-channel-bg: var(--hu-web-pill-channel-bg);
        --color-pill-channel-border: var(--hu-web-pill-channel-border);
        --color-pill-tool: var(--hu-web-pill-tool);
        --color-pill-tool-bg: var(--hu-web-pill-tool-bg);
        --color-pill-tool-border: var(--hu-web-pill-tool-border);
      }
    </style>
  </head>
  <body
    style="background: var(--color-bg); color: var(--color-text);"
    class="antialiased overflow-x-hidden"
  >
    <div class="scroll-progress" id="scroll-progress"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav />

    <main id="main-content">
      {/* ═══ HERO ═══ */}

      <section
        class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-24 overflow-hidden"
      >
        <div class="hero-gradient noise-overlay"></div>
        <div
          class="ambient-coral"
          style="top: 15%; left: 50%; transform: translateX(-50%);"
        >
        </div>
        <div class="ambient-blue" style="top: 30%; right: 10%;"></div>
        <div class="hero-content text-center max-w-3xl mx-auto relative z-10">
          <img
            src={`${base}human.svg`}
            alt="Human logo"
            width="512"
            height="512"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="hero-logo w-20 h-20 md:w-24 md:h-24 mx-auto mb-10"
            style={`filter: drop-shadow(0 0 40px var(--color-accent-glow)); animation: float 6s ease-in-out infinite;`}
          />
          <h1
            class="hero-headline font-sans font-black text-[clamp(2.5rem,7vw,4.5rem)] leading-[1.05] mb-6"
            style="color: var(--color-text); letter-spacing: -0.04em; font-weight: 900;"
          >
            Bring AI to <span class="text-gradient">every</span> device on&nbsp;Earth.
          </h1>
          <p
            class="hero-desc text-[clamp(1.05rem,2.2vw,1.3rem)] leading-relaxed mb-10 hero-fade-in max-w-2xl mx-auto"
            style="color: var(--color-text-secondary)"
          >
            A complete autonomous AI agent runtime in <strong
              style="color: var(--color-text)">528&nbsp;kilobytes</strong
            > of pure&nbsp;C.<br />
            One static binary. Zero dependencies. Boots in under 2&nbsp;milliseconds.
          </p>
          <div
            class="hero-buttons flex flex-col sm:flex-row gap-4 justify-center hero-fade-in"
          >
            <a href={`${base}getting-started/installation/`} class="btn-primary"
              >Get Started</a
            >
            <a
              href="https://github.com/sethdford/h-uman"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline">View on GitHub</a
            >
          </div>
        </div>
      </section>

      {/* ═══ THE NUMBERS ═══ */}

      <section class="py-16 md:py-24 px-6">
        <div class="max-w-5xl mx-auto">
          <div
            class="numbers-grid glass px-4 md:px-8 py-8 md:py-10 grid grid-cols-3 md:grid-cols-6 gap-0"
          >
            {
              [
                { count: 528, suffix: " KB", label: "Binary" },
                { count: 2, prefix: "<", suffix: " ms", label: "Startup" },
                { count: 3795, label: "Tests" },
                { count: 50, suffix: "+", label: "Providers" },
                { count: 34, label: "Channels" },
                { count: 67, suffix: "+", label: "Tools" },
              ].map((stat, i, arr) => (
                <div
                  class={`number-item text-center py-6 md:py-0 ${i < arr.length - 1 ? "md:border-r" : ""}`}
                  data-reveal="scale"
                  style={`--ri: ${i}; border-color: var(--color-border)`}
                >
                  <div
                    class="font-sans font-black text-[clamp(2rem,4vw,3rem)] leading-none"
                    style="color: var(--color-text)"
                    data-count={stat.count}
                    data-prefix={stat.prefix || ""}
                    data-suffix={stat.suffix || ""}
                  >
                    {stat.prefix && (
                      <span class="count-prefix">{stat.prefix}</span>
                    )}
                    <span class="count-value">0</span>
                    {stat.suffix && (
                      <span class="count-suffix">{stat.suffix}</span>
                    )}
                  </div>
                  <div
                    class="text-[11px] font-medium mt-2 uppercase tracking-[0.1em]"
                    style="color: var(--color-text-tertiary)"
                  >
                    {stat.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      {/* ═══ THE PROBLEM ═══ */}

      <section
        class="relative min-h-[85vh] flex flex-col items-center justify-center px-6"
      >
        <div class="max-w-2xl mx-auto text-center">
          <h2
            class="bloat-title font-sans font-extrabold text-[clamp(2rem,5vw,3.5rem)] mb-16"
            data-reveal
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            To run an AI assistant today, you need...
          </h2>
          <div class="bloat-stack flex flex-col items-center gap-3 mb-12">
            {
              bloatItems.map((item, i) => (
                <div
                  class={`bloat-card glass px-8 py-4 text-[clamp(1rem,2vw,1.25rem)] w-full max-w-md text-center ${i === bloatItems.length - 1 ? "italic" : ""}`}
                  data-reveal="scale"
                  style={`--ri: ${i}; color: ${i === bloatItems.length - 1 ? "var(--color-text-tertiary)" : "var(--color-text-secondary)"}`}
                >
                  {item}
                </div>
              ))
            }
          </div>
          <p
            class="bloat-answer text-[clamp(1.25rem,3vw,1.75rem)]"
            data-reveal
            style="color: var(--color-text)"
          >
            Human needs one thing: <span
              style="color: var(--color-accent)"
              class="font-semibold">a CPU.</span
            >
          </p>
        </div>
      </section>

      {/* ═══ DEVICE SPECTRUM ═══ */}

      <section id="use-cases" class="py-16 md:py-32 px-6">
        <div class="max-w-5xl mx-auto">
          <h2
            class="spectrum-title font-sans font-extrabold text-[clamp(2rem,5vw,3.5rem)] mb-4 text-center"
            data-reveal
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            From data centers to five-dollar boards.
          </h2>
          <p
            class="spectrum-sub text-lg mb-16 text-center"
            data-reveal
            style="color: var(--color-text-secondary)"
          >
            The same static binary. The same config. Every device.
          </p>
          <div class="grid md:grid-cols-4 gap-5">
            {
              [
                {
                  icon: iconCloud,
                  title: "Cloud",
                  desc: "Docker, WASM, Cloudflare Workers. Full gateway with webhooks, tunnels, and multi-channel routing.",
                },
                {
                  icon: iconMonitor,
                  title: "Workstation",
                  desc: "macOS, Linux, Windows. Interactive TUI, local Ollama/llama.cpp. No cloud dependency.",
                },
                {
                  icon: iconCircuitBoard,
                  title: "Edge",
                  desc: "Raspberry Pi, ARM SBCs. Under 5 MB RAM. Under 2 ms startup. Runs headless on boot.",
                },
                {
                  icon: iconCpu,
                  title: "Embedded",
                  desc: "Arduino, STM32, Nucleo. Serial JSON protocol. Hardware peripherals via vtable interface.",
                },
              ].map(({ icon, title, desc }, i) => (
                <div
                  class="spectrum-card card-glow card-spotlight glass px-6 py-8 text-center transition-all duration-300 hover:-translate-y-1"
                  data-reveal="scale-up"
                  style={`--ri: ${i}; --tw-shadow: var(--hu-shadow-md);`}
                >
                  <span
                    class="w-8 h-8 mx-auto mb-4 flex items-center justify-center [&>svg]:flex-shrink-0"
                    style="color: var(--color-text-tertiary)"
                    set:html={icon}
                  />
                  <h3
                    class="text-lg font-semibold mb-3"
                    style="color: var(--color-text)"
                  >
                    {title}
                  </h3>
                  <p
                    class="text-[14px] leading-relaxed"
                    style="color: var(--color-text-secondary)"
                  >
                    {desc}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      {/* ═══ ARCHITECTURE ═══ */}

      <section id="architecture" class="relative py-16 md:py-32 px-6">
        <div class="ambient-coral" style="top: 20%; left: 10%;"></div>
        <div class="ambient-blue" style="bottom: 10%; right: 15%;"></div>
        <div class="max-w-4xl mx-auto text-center">
          <h2
            class="arch-title hu-scroll-reveal font-sans font-extrabold text-[clamp(2rem,5vw,3.5rem)] mb-4"
            data-reveal
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            Swap anything. Lock in nothing.
          </h2>
          <p
            class="arch-sub hu-scroll-reveal text-lg mb-20"
            data-reveal
            style="color: var(--color-text-secondary)"
          >
            Every subsystem is a vtable interface. Change any layer with a
            config edit.
          </p>

          <svg
            id="arch-diagram"
            viewBox="0 0 600 600"
            width="600"
            height="600"
            class="hu-scroll-scale w-full max-w-lg mx-auto"
            style="aspect-ratio: 1;"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-label="Human architecture diagram showing 8 swappable subsystems"
          >
            <defs>
              <filter
                id="node-shadow"
                x="-20%"
                y="-20%"
                width="140%"
                height="140%"
              >
                <feDropShadow
                  dx="0"
                  dy="2"
                  stdDeviation="4"
                  flood-color="rgba(0,0,0,0.06)"></feDropShadow>
              </filter>
            </defs>

            {
              [
                [300, 100],
                [441, 159],
                [500, 300],
                [441, 441],
                [300, 500],
                [159, 441],
                [100, 300],
                [159, 159],
              ].map(([x, y]) => (
                <line
                  class="arch-line"
                  x1="300"
                  y1="300"
                  x2={x}
                  y2={y}
                  stroke="var(--color-line-stroke)"
                  stroke-width="1"
                />
              ))
            }

            <g id="arch-core" class="opacity-0">
              <circle
                cx="300"
                cy="300"
                r="44"
                fill="var(--color-node-fill)"
                stroke="var(--color-accent)"
                stroke-width="1.5"
                filter="url(#node-shadow)"></circle>
              <text
                x="300"
                y="296"
                text-anchor="middle"
                fill="var(--color-text)"
                font-size="11"
                font-weight="600"
                font-family="var(--font-sans)">Human</text
              >
              <text
                x="300"
                y="312"
                text-anchor="middle"
                fill="var(--color-text-secondary)"
                font-size="9"
                font-family="var(--font-sans)">Core</text
              >
            </g>

            {
              [
                {
                  cx: 300,
                  cy: 100,
                  label: "Providers",
                  tip: "50+ AI model providers: OpenAI, Anthropic, Ollama, and more",
                },
                {
                  cx: 441,
                  cy: 159,
                  label: "Channels",
                  tip: "33 messaging channels: Telegram, Discord, Slack, iMessage",
                },
                {
                  cx: 500,
                  cy: 300,
                  label: "Memory",
                  tip: "SQLite + FTS5 + vector embeddings for persistent context",
                },
                {
                  cx: 441,
                  cy: 441,
                  label: "Tools",
                  tip: "67+ tools: shell, files, git, browser, web search, hardware",
                },
                {
                  cx: 300,
                  cy: 500,
                  label: "Security",
                  tip: "Sandbox, AEAD encryption, path traversal protection",
                },
                {
                  cx: 159,
                  cy: 441,
                  label: "Runtime",
                  tip: "Native, Docker, WASM, Cloudflare Workers",
                },
                {
                  cx: 100,
                  cy: 300,
                  label: "Tunnels",
                  tip: "Cloudflare, ngrok, Tailscale for webhook exposure",
                },
                {
                  cx: 159,
                  cy: 159,
                  label: "Hardware",
                  tip: "Arduino, STM32, Raspberry Pi peripherals",
                },
              ].map(({ cx, cy, label, tip }) => (
                <g class="arch-node opacity-0" style="cursor: pointer;">
                  <title>{tip}</title>
                  <circle
                    cx={cx}
                    cy={cy}
                    r="30"
                    fill="var(--color-node-fill)"
                    stroke="var(--color-node-stroke)"
                    stroke-width="1"
                    filter="url(#node-shadow)"
                  />
                  <text
                    x={cx}
                    y={cy + 4}
                    text-anchor="middle"
                    fill="var(--color-text-secondary)"
                    font-size="10"
                    font-family="var(--font-sans)"
                  >
                    {label}
                  </text>
                </g>
              ))
            }
          </svg>
        </div>
      </section>

      {/* ═══ ECOSYSTEM ═══ */}

      <section class="py-16 md:py-32 px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h2
            class="providers-title hu-scroll-reveal font-sans font-extrabold text-[clamp(2rem,5vw,3.5rem)] mb-4"
            data-reveal
            style="color: var(--color-text); letter-spacing: -0.03em;"
          >
            50+ providers. 34 channels. 67+ tools.
          </h2>
          <p
            class="providers-sub text-lg mb-16"
            data-reveal
            style="color: var(--color-text-secondary)"
          >
            Connect to any AI model. Reach users on any platform.
          </p>
          <div class="flex flex-wrap gap-3 justify-center" id="provider-grid">
            {
              providers.map((name, i) => (
                <span
                  class="provider-pill px-4 py-2 rounded-full text-[13px] transition-all duration-200 cursor-default backdrop-blur-sm"
                  data-reveal="pill"
                  style={`--ri: ${i}; color: var(--color-pill-provider); background: var(--color-pill-provider-bg); border: 1px solid var(--color-pill-provider-border)`}
                >
                  {name}
                </span>
              ))
            }
            {
              channels.map((name, i) => (
                <span
                  class="provider-pill px-4 py-2 rounded-full text-[13px] transition-all duration-200 cursor-default backdrop-blur-sm"
                  data-reveal="pill"
