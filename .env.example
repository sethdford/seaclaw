# Copy to `.env` and fill in. File `.env` is gitignored.
#
# Load before running tools that expect env vars:
#   set -a && source .env && set +a
#
# Human’s runtime config is still primarily ~/.human/config.json — this file is
# for shell-only tools (e.g. adversarial harness) and optional provider env vars.

# --- Optional: match what your Human provider expects ---
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# --- scripts/adversarial-eval-harness.py (OpenAI-compatible HTTP API) ---
# Use your Gemini key + Google’s OpenAI-compat endpoint, or any OpenAI key + https://api.openai.com/v1
# ADV_EVAL_API_KEY=
# ADV_EVAL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# ADV_EVAL_MODEL=gemini-2.0-flash

# HUMAN_BIN=/absolute/path/to/human
