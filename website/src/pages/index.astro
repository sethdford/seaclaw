---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import AnimatedLogo from "../components/AnimatedLogo.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const bloatItems = [
  "A container runtime",
  "A Python environment",
  "2 GB of RAM",
  "A cloud API key",
  "A stable internet connection",
  "A prayer",
];

const providers = [
  "OpenAI",
  "Anthropic",
  "Gemini",
  "OpenRouter",
  "Ollama",
  "llama.cpp",
  "Groq",
  "Mistral",
  "xAI",
  "DeepSeek",
  "Together",
  "Fireworks",
  "Perplexity",
  "Cohere",
  "LM Studio",
  "vLLM",
  "sglang",
  "Cerebras",
  "SambaNova",
  "Hyperbolic",
];

const channels = [
  "Telegram",
  "Discord",
  "Slack",
  "Signal",
  "iMessage",
  "Matrix",
  "WhatsApp",
  "IRC",
  "Nostr",
  "Email",
  "Line",
  "Mattermost",
];

const tools = [
  "Shell",
  "File Ops",
  "Git",
  "Browser",
  "Memory",
  "Web Search",
  "Cron",
  "HTTP",
  "Hardware",
  "Delegate",
];
---

<html lang="en">
  <head>
    <script is:inline>
      (function () {
        var s = localStorage.getItem("hu-theme");
        var m = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = s || m;
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://h-uman.ai/" />
    <link
      rel="preload"
      href={`${base}fonts/avenir/Avenir-Black.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href={`${base}fonts/avenir/Avenir-Book.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>h-uman — almost human.</title>
    <meta
      name="description"
      content="almost human. A complete autonomous AI agent runtime in 1,750 kilobytes of pure C. One static binary. Zero dependencies. 50+ providers. Runs on anything with a CPU."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={`${base}favicon-32.png`}
    />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <meta name="theme-color" content="#7AB648" />
    <meta property="og:title" content="h-uman — almost human." />
    <meta
      property="og:description"
      content="Autonomous AI agent runtime. ~1.7 MB binary. 50+ providers. 38 channels. 83+ tools. Zero dependencies. Pure C."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://h-uman.ai/" />
    <meta property="og:image" content="https://h-uman.ai/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="h-uman — almost human." />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="h-uman" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="h-uman — almost human." />
    <meta
      name="twitter:description"
      content="Autonomous AI agent runtime. ~1.7 MB binary. 50+ providers. 38 channels. 83+ tools. Zero dependencies. Pure C."
    />
    <meta name="twitter:image" content="https://h-uman.ai/og-image.png" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://h-uman.ai/#website",
            name: "h-uman",
            url: "https://h-uman.ai/",
            description:
              "Autonomous AI agent runtime in 1,750 kilobytes of pure C. One static binary. Zero dependencies. 50+ providers.",
            publisher: { "@id": "https://h-uman.ai/#organization" },
          },
          {
            "@type": "Organization",
            "@id": "https://h-uman.ai/#organization",
            name: "h-uman",
            url: "https://github.com/sethdford/h-uman",
            sameAs: ["https://github.com/sethdford/h-uman"],
          },
          {
            "@type": "SoftwareApplication",
            name: "h-uman",
            description:
              "almost human. Autonomous AI agent runtime in 1,750 kilobytes of pure C.",
            applicationCategory: "DeveloperApplication",
            operatingSystem: "Cross-platform",
            url: "https://h-uman.ai/",
            license: "https://opensource.org/licenses/MIT",
            offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
            author: { "@id": "https://h-uman.ai/#organization" },
          },
        ],
      })}
    />
    <style is:global>
      /* Critical hero CSS — inline for fast LCP (paint before external CSS) */
      :root {
        --color-bg-inline: var(--hu-bg, #fafaf9);
      }
      [data-theme="dark"] {
        --color-bg-inline: var(--hu-bg, #0a0a0a);
      }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme="light"]) {
          --color-bg-inline: var(--hu-bg, #0a0a0a);
        }
      }
      body {
        font-family: var(
          --font-sans,
          "Avenir",
          "Avenir Next",
          -apple-system,
          BlinkMacSystemFont,
          system-ui,
          sans-serif
        );
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: var(--color-bg-inline);
      }
      section.relative.min-h-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 56rem;
        margin-left: auto;
        margin-right: auto;
      }
      .hero-wordmark {
        font-size: clamp(4rem, 12vw, 9rem);
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1;
      }
      .hero-logo,
      .hero-headline {
        opacity: 1;
        transform: none;
      }
      .tagline-text {
        display: inline-block;
        transition:
          opacity 0.4s ease,
          transform 0.4s ease;
      }
      .tagline-text.hu-fidget-out {
        opacity: 0;
        transform: translateY(4px);
      }
      .hero-desc,
      .hero-mission,
      .hero-proof,
      .hero-buttons,
      .hero-fade-in {
        opacity: 0;
      }
      /* Below-fold: defer layout/paint until near viewport (hero / LCP stays prioritized) */
      main > section:not(:first-of-type),
      footer.site-footer {
        content-visibility: auto;
      }
      #hero-webgl.hero-webgl-canvas {
        will-change: transform, opacity;
      }
      @media (prefers-reduced-motion: reduce) {
        #hero-webgl.hero-webgl-canvas {
          will-change: auto;
        }
      }
    </style>
    <style is:global>
      /* --color-* aliases for index.astro (shortcuts over canonical --hu-* tokens) */
      :root {
        --color-bg: var(--hu-bg);
        --color-text: var(--hu-text);
        --color-text-secondary: var(--hu-text-secondary);
        --color-text-tertiary: var(--hu-text-muted);
        --color-accent: var(--hu-accent);
        --color-accent-light: var(--hu-accent-light, var(--hu-accent-subtle));
        --color-accent-glow: var(--hu-accent-subtle);
        --color-border: var(--hu-border-subtle);
        --color-line-stroke: var(--hu-border-subtle);
        --color-node-fill: color-mix(
          in srgb,
          var(--hu-bg-surface) 80%,
          transparent
        );
        --color-node-stroke: color-mix(in srgb, var(--hu-text) 8%, transparent);
        /* Terminal panel: dynamic neutrals stay dark on light pages */
        --color-terminal-bg: var(--hu-dynamic-neutral-200);
        --color-terminal-chrome: var(--hu-dynamic-neutral-300);
        --color-terminal-border: color-mix(in srgb, white 6%, transparent);
        /* Pills — status / chart-adjacent semantic colors */
        --color-pill-provider: var(--hu-info);
        --color-pill-provider-bg: var(--hu-info-dim);
        --color-pill-provider-border: color-mix(
          in srgb,
          var(--hu-info) 22%,
          transparent
        );
        --color-pill-channel: var(--hu-success);
        --color-pill-channel-bg: var(--hu-success-dim);
        --color-pill-channel-border: color-mix(
          in srgb,
          var(--hu-success) 22%,
          transparent
        );
        --color-pill-tool: var(--hu-warning);
        --color-pill-tool-bg: var(--hu-warning-dim);
        --color-pill-tool-border: color-mix(
          in srgb,
          var(--hu-warning) 22%,
          transparent
        );
      }
    </style>
  </head>
  <body
    style="background: var(--color-bg); color: var(--color-text);"
    class="antialiased overflow-x-hidden"
  >
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav />

    <main id="main-content" tabindex="-1">
      {/* ═══ HERO ═══ */}

      <section
        id="chapter-1"
        class="relative min-h-screen flex flex-col items-center justify-center px-4 sm:px-6 pt-20 sm:pt-24 overflow-hidden hu-film-grain"
        aria-label="Hero"
      >
        <div class="hu-particles" id="hu-particles" aria-hidden="true"></div>
        <div id="custom-cursor" class="custom-cursor" aria-hidden="true"></div>
        <canvas id="hero-webgl" class="hero-webgl-canvas" aria-hidden="true"
        ></canvas>
        <div class="hero-content text-center max-w-4xl mx-auto relative z-10">
          <div class="hero-orb-wrapper mb-6 md:mb-8">
            <AnimatedLogo size={220} interactive />
          </div>
          <div
            class="hero-wordmark-row hero-logo flex items-center justify-center mb-8"
          >
            <span
              class="hero-wordmark font-sans"
              style="color: var(--color-text); view-transition-name: page-heading;"
              aria-hidden="true">h-uman</span
            >
          </div>
          <h1 class="sr-only">h-uman — almost human.</h1>
          <p
            class="hero-tagline hero-headline font-sans"
            id="hero-tagline"
            style="color: var(--color-text-secondary); letter-spacing: 0.06em;"
          >
            <span class="tagline-text" aria-live="polite">almost human.</span>
          </p>
          <p class="hero-mission hero-desc hero-fade-in mx-auto">
            Bring AI to <span class="text-gradient">every</span> device on Earth.
          </p>
          <div
            class="hero-proof hero-fade-in flex flex-wrap justify-center gap-x-4 sm:gap-x-6 gap-y-2 mb-8 sm:mb-10"
          >
            <span style="color: var(--color-text-tertiary)"
              ><strong style="color: var(--color-text)">1,750&nbsp;KB</strong> binary</span
            >
            <span style="color: var(--color-text-tertiary)" aria-hidden="true"
              >&middot;</span
            >
            <span style="color: var(--color-text-tertiary)"
              ><strong style="color: var(--color-text)"
                >&lt;&nbsp;6&nbsp;MB</strong
              > RAM</span
            >
            <span style="color: var(--color-text-tertiary)" aria-hidden="true"
              >&middot;</span
            >
            <span style="color: var(--color-text-tertiary)"
              ><strong style="color: var(--color-text)"
                >&lt;&nbsp;30&nbsp;ms</strong
              > startup</span
            >
            <span style="color: var(--color-text-tertiary)" aria-hidden="true"
              >&middot;</span
            >
            <span style="color: var(--color-text-tertiary)"
              ><strong style="color: var(--color-text)">0</strong> dependencies</span
            >
          </div>
          <div
            class="hero-badges hero-fade-in flex flex-wrap justify-center gap-2 mb-8"
          >
            <img
              src="https://img.shields.io/github/stars/sethdford/h-uman?style=flat-square&color=7AB648&label=stars"
              alt="GitHub stars"
              height="20"
              style="aspect-ratio: auto;"
              loading="lazy"
              decoding="async"
            />
            <img
              src="https://img.shields.io/badge/license-MIT-7AB648?style=flat-square"
              alt="MIT License"
              height="20"
              style="aspect-ratio: auto;"
              loading="lazy"
              decoding="async"
            />
            <img
              src="https://img.shields.io/badge/binary-1%2C750_KB-7AB648?style=flat-square"
              alt="Binary size: 1,750 KB"
              height="20"
              style="aspect-ratio: auto;"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div
            class="hero-buttons flex flex-col sm:flex-row gap-4 justify-center hero-fade-in"
          >
            <a href={`${base}getting-started/installation/`} class="btn-primary"
              >Get Started</a
            >
            <a
              href="https://github.com/sethdford/h-uman"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline">View on GitHub</a
            >
          </div>
          <div class="hero-fade-in mt-8 max-w-lg mx-auto">
            <div
              class="glass glass-enter flex items-center gap-3 pl-5 pr-3 py-3 rounded-xl font-mono text-sm"
            >
              <span style="color: var(--color-accent)">$</span>
              <code
                class="flex-1 overflow-x-auto whitespace-nowrap"
                style="color: var(--color-text-secondary)"
                >git clone https://github.com/sethdford/h-uman.git</code
              >
              <button
                type="button"
                class="shrink-0 p-1.5 rounded-lg transition-all hover:scale-110"
                style="color: var(--color-text-tertiary)"
                aria-label="Copy to clipboard"
                onclick="navigator.clipboard.writeText('git clone https://github.com/sethdford/h-uman.git')"
              >
                <svg class="w-4 h-4" viewBox="0 0 256 256" fill="currentColor"
                  ><path
                    d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"
                  ></path></svg
                >
              </button>
            </div>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto w-full mt-12 mb-6 relative z-10 numbers-section"
        >
          <div
            class="numbers-grid glass glass-enter px-4 md:px-8 py-8 md:py-10 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-0"
          >
            {
              [
                { count: 1750, suffix: " KB", label: "Binary" },
                { count: 30, prefix: "<", suffix: " ms", label: "Startup" },
                { count: 4980, suffix: "+", label: "Tests" },
                { count: 50, suffix: "+", label: "Providers" },
                { count: 38, label: "Channels" },
                { count: 83, suffix: "+", label: "Tools" },
              ].map((stat, i, arr) => (
                <div
                  class={`number-item text-center py-4 sm:py-6 md:py-0 ${i < arr.length - 1 ? "md:border-r" : ""}`}
                  data-reveal="scale"
                  style={`--ri: ${i}; border-color: var(--color-border)`}
                >
                  <div
                    class="hu-metric-counter font-sans font-black text-[clamp(2rem,4vw,3rem)] leading-none"
                    style="color: var(--color-text)"
                    data-count={stat.count}
                    data-prefix={stat.prefix || ""}
                    data-suffix={stat.suffix || ""}
                  >
                    {stat.prefix && (
                      <span class="count-prefix">{stat.prefix}</span>
                    )}
                    <span class="count-value">0</span>
                    {stat.suffix && (
                      <span class="count-suffix">{stat.suffix}</span>
                    )}
                  </div>
                  <div
                    class="text-xs font-medium mt-2 uppercase tracking-[0.1em]"
                    style="color: var(--color-text-tertiary)"
                  >
                    {stat.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="hero-fade-in max-w-5xl mx-auto w-full relative z-10 px-6">
          <p
            class="social-proof-label text-xs font-semibold uppercase tracking-[0.15em] mb-8 text-center"
            style="color: var(--color-text-tertiary)"
          >
            Built for
          </p>
          <div
            class="proof-grid grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4 md:gap-6"
          >
            {
              [
                {
                  icon: "M117.31,134l-72,64a8,8,0,1,1-10.63-12L100,128,34.69,70A8,8,0,0,1,45.31,58l72,64A8,8,0,0,1,117.31,134ZM216,184H120a8,8,0,0,0,0,16h96a8,8,0,0,0,0-16Z",
                  label: "CLI Automation",
                },
                {
                  icon: "M208,40H48A16,16,0,0,0,32,56v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40Zm0,64H48V56H208ZM208,136H48a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V152A16,16,0,0,0,208,136Zm0,64H48V152H208Zm-36-40a12,12,0,1,1-12,12A12,12,0,0,1,172,160Zm-36,0a12,12,0,1,1-12,12A12,12,0,0,1,136,160Zm36-96a12,12,0,1,1-12,12A12,12,0,0,1,172,64Zm-36,0a12,12,0,1,1-12,12A12,12,0,0,1,136,64Z",
                  label: "DevOps",
                },
                {
                  icon: "M208,40H48A16,16,0,0,0,32,56V72a16,16,0,0,0,16,16H80V56a8,8,0,0,1,16,0V72h48V56a8,8,0,0,1,16,0V72h32a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40Zm0,64H48a16,16,0,0,0-16,16v16a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V120A16,16,0,0,0,208,104Zm0,64H48a16,16,0,0,0-16,16v16a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V184A16,16,0,0,0,208,168ZM56,112H72v8a8,8,0,0,1-16,0v-8Zm0,64H72v8a8,8,0,0,1-16,0v-8Zm128-64h16v8a8,8,0,0,1-16,0v-8Zm0,64h16v8a8,8,0,0,1-16,0v-8Zm-48-64h16v8a8,8,0,0,1-16,0v-8Zm0,64h16v8a8,8,0,0,1-16,0v-8Z",
                  label: "IoT",
                },
                {
                  icon: "M208,40H48A16,16,0,0,0,32,56v58.77c0,89.61,75.82,119.34,91,124.39a15.53,15.53,0,0,0,10,0c15.2-5.05,91-34.78,91-124.39V56A16,16,0,0,0,208,40Zm0,74.79c0,78.42-66.35,104.62-80,109.18-13.53-4.52-80-30.69-80-109.18V56H208Z",
                  label: "Security",
                },
                {
                  icon: "M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z",
                  label: "Research",
                },
                {
                  icon: "M224,200h-8V40a8,8,0,0,0-16,0V200H168V96a8,8,0,0,0-16,0V200H104V136a8,8,0,0,0-16,0v64H40V168a8,8,0,0,0-16,0v32H16a8,8,0,0,0,0,16H224a8,8,0,0,0,0-16Z",
                  label: "Enterprise",
                },
              ].map(({ icon, label }, i) => (
                <div
                  class="proof-item glass glass-enter flex flex-col items-center gap-3 px-4 py-6 rounded-xl"
                  data-reveal="scale"
                  style={`--ri: ${i}`}
                >
                  <svg
                    class="w-8 h-8 shrink-0"
                    viewBox="0 0 256 256"
                    fill="currentColor"
                    style="color: var(--color-accent)"
                    aria-hidden="true"
                  >
                    <path d={icon} />
                  </svg>
                  <span
                    class="text-sm font-medium text-center"
                    style="color: var(--color-text-secondary)"
                  >
                    {label}
                  </span>
                </div>
              ))
            }
          </div>
          <div class="github-badge mt-10 flex justify-center">
            <a
              href="https://github.com/sethdford/h-uman"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub stars"
            >
              <img
                src="https://img.shields.io/github/stars/sethdford/h-uman?style=social"
                alt="GitHub stars"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                width="96"
                height="20"
              />
            </a>
          </div>
        </div>
      </section>

      {/* ═══ INTERACTIVE DEMO (Terminal replay) ═══ */}
      <section
        id="chapter-2"
        class="demo-section relative hu-chapter-reveal py-24 md:py-32 px-6 cv-defer"
        aria-label="Product demo"
      >
        <div class="max-w-5xl mx-auto">
          <h2
            class="font-sans font-black text-[clamp(2rem,4vw,3rem)] mb-8 text-center"
            style="color: var(--color-text); letter-spacing: -0.03em;"
            data-reveal
          >
            See it in action
          </h2>
          <div
            class="terminal-demo rounded-xl overflow-hidden"
            aria-label="Terminal demonstration"
            data-reveal="scale"
            style="background: var(--color-terminal-bg); box-shadow: var(--hu-shadow-lg);"
          >
            <div
              class="terminal-header flex items-center gap-2 px-4 py-3"
              style="background: var(--color-terminal-chrome); border-bottom: 1px solid var(--color-terminal-border);"
            >
              <span
                class="terminal-dot red w-3 h-3 rounded-full shrink-0"
                style="background: var(--hu-terminal-close)"></span>
              <span
                class="terminal-dot yellow w-3 h-3 rounded-full shrink-0"
