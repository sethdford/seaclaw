      }
    },
    "body-md": {
      "fontSize": {
        "$value": "{fontSize.base}",
        "$type": "dimension"
      },
      "fontWeight": {
        "$value": "{fontWeight.normal}",
        "$type": "number"
      },
      "lineHeight": {
        "$value": "{lineHeight.normal}",
        "$type": "number"
      },
      "letterSpacing": {
        "$value": "{letterSpacing.base}",
