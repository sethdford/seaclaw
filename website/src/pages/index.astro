    <footer class="py-12 px-6" style="border-top: 1px solid var(--sc-web-border)">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <img src={`${base}seaclaw.svg`} alt="SeaClaw logo" width="512" height="512" class="w-5 h-5" loading="lazy" decoding="async" />
